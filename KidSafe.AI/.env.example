# Copy to .env and fill in values

# Model backend: custom (KidSafe Keras model) | stub (testing only)
MODEL_BACKEND=custom

# Toxicity thresholds (SDD §4.1)
# score < FLAGGED              → Safe
# FLAGGED ≤ score < BLOCKED   → Watch  (message masked)
# score ≥ BLOCKED             → Review (message blocked)
FLAGGED_THRESHOLD=0.5
BLOCKED_THRESHOLD=0.8
