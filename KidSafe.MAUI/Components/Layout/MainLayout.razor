@inherits LayoutComponentBase
@inject SidebarService Sidebar
@implements IDisposable

<div class="layout-shell @(Sidebar.IsDarkMode ? "dark" : "")">
    @Body
</div>

@code {
    protected override void OnInitialized()
    {
        Sidebar.Init();
        Sidebar.OnChange += StateHasChanged;
    }

    public void Dispose() => Sidebar.OnChange -= StateHasChanged;
}
