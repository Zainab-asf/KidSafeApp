@page "/admin"
@inject ApiService Api
@inject AuthStateService AuthState
@inject SidebarService Sidebar
@inject NavigationManager Nav

<div class="app-root portal-admin">

    <AppSidebar>
        <NavContent>
            <NavGroup Title="Management">
                @foreach (var (tab, iconClass, label) in _tabs)
                {
                    var hasBadge = tab == "Pending" && _pendingUsers.Count > 0;
                    <button class="nav-item @(_activeTab == tab ? "active" : "")"
                            @onclick="() => SetTab(tab)">
                        <span class="ni"><i class="bi @iconClass"></i></span>
                        <span>@label</span>
                        @if (hasBadge) { <span class="nb">@_pendingUsers.Count</span> }
                    </button>
                }
            </NavGroup>
        </NavContent>
    </AppSidebar>

    <!-- ── Main area ── -->
    <div class="main-area">
        <!-- Top header -->
        <header class="top-header">
            <button class="sidebar-toggle" @onclick="Sidebar.ToggleDrawer" title="Menu">
                <i class="bi bi-list"></i>
            </button>
            <div class="header-search">
                <span class="search-icon"><i class="bi bi-search"></i></span>
                <input type="text" placeholder="Search users, complaints…" />
            </div>
            <div class="header-actions">
                <button class="header-btn" @onclick="LoadData" title="Refresh">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
                <div class="header-profile">
                    <div class="hp-avatar" style="font-size:1.2rem;display:flex;align-items:center;justify-content:center">
                        <i class="bi bi-shield-fill" style="color:var(--green)"></i>
                    </div>
                    <div>
                        <div class="hp-name">Admin</div>
                        <div class="hp-role">KidSafe</div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page content -->
        <div class="page-content">

            <!-- Profile card -->
            <DashboardProfileCard IconClass="bi-shield-fill"
                Name="@(AuthState.CurrentUser?.DisplayName ?? "Administrator")"
                Role="System Administrator"
                Meta="@($"{_allUsers.Count} users · {_classes.Count} classes · {_parentLinks.Count} parent links")">
                <Actions>
                    <button class="btn btn-sm btn-outline" @onclick='() => Nav.NavigateTo("/profile")'><i class="bi bi-person-circle"></i> Profile</button>
                    <button class="btn btn-sm btn-outline" @onclick='() => SetTab("Classes")'><i class="bi bi-journal-bookmark-fill"></i> Classes</button>
                </Actions>
            </DashboardProfileCard>

            <!-- Page heading -->
            <div class="page-head">
                <h1>Admin Dashboard</h1>
                <p>Manage users, classes, parent-child links, and review flagged content</p>
            </div>

            <!-- Stats row -->
            @if (_stats != null)
            {
                <div class="grid-4" style="margin-bottom:1.5rem">
                    <StatCard IconClass="bi-people-fill"      Value="@_allUsers.Count.ToString()"       Label="Total Users" Color="green"  />
                    <StatCard IconClass="bi-hourglass-split"  Value="@_stats.PendingTeachers.ToString()" Label="Pending"     Color="gold"   />
                    <StatCard IconClass="bi-slash-circle-fill" Value="@_stats.TotalReview.ToString()"   Label="Blocked"     Color="coral"  />
                    <StatCard IconClass="bi-clipboard2-fill"  Value="@_stats.TotalComplaints.ToString()" Label="Complaints"  Color="purple" />
                </div>
            }

            <!-- Tabs -->
            <div class="page-tabs" style="margin-bottom:1.25rem">
                @foreach (var (tab, iconCls, label) in _tabs)
                {
                    <button class="ptab @(_activeTab == tab ? "active" : "")"
                            @onclick="() => SetTab(tab)">
                        <i class="bi @iconCls"></i> @label
                    </button>
                }
            </div>

            @if (_loading)
            {
                <div class="loading-block"><div class="spinner"></div></div>
            }
            else
            {

            <!-- ── PENDING ── -->
            @if (_activeTab == "Pending")
            {
                @if (!_pendingUsers.Any())
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-check-circle-fill" style="color:var(--green)"></i></div>
                        <div class="empty-txt">No pending approvals</div>
                        <div class="empty-sub">All accounts are reviewed</div>
                    </div>
                }
                else
                {
                    @foreach (var u in _pendingUsers)
                    {
                        <div class="user-row">
                            <div class="user-av" style="font-size:1.2rem;display:flex;align-items:center;justify-content:center"><i class="bi @RoleIconClass(u.Role)"></i></div>
                            <div class="user-info">
                                <div class="user-name">@u.DisplayName</div>
                                <div class="user-email">@u.Email · @u.Role</div>
                            </div>
                            <div class="user-acts">
                                <button class="btn btn-sm btn-ghost" @onclick="() => Approve(u.Id)"><i class="bi bi-check-circle-fill" style="color:var(--green)"></i> Approve</button>
                                <button class="btn btn-sm btn-danger-o" @onclick="() => Disable(u.Id)"><i class="bi bi-x-circle-fill"></i> Reject</button>
                            </div>
                        </div>
                    }
                }
            }

            <!-- ── STUDENTS ── -->
            @if (_activeTab == "Students")
            {
                <div class="sec-hd">
                    <h2><i class="bi bi-person-fill"></i> Students</h2>
                    <button class="btn btn-sm btn-primary" @onclick="OpenCreateChild">+ Add Student</button>
                </div>
                @foreach (var u in _allUsers.Where(u => u.Role == "Child")) { @UserRow(u) }
                @if (!_allUsers.Any(u => u.Role == "Child"))
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-person-fill" style="font-size:2rem"></i></div>
                        <div class="empty-txt">No students yet</div>
                    </div>
                }
            }

            <!-- ── TEACHERS ── -->
            @if (_activeTab == "Teachers")
            {
                <div class="sec-hd">
                    <h2><i class="bi bi-mortarboard-fill"></i> Teachers</h2>
                    <button class="btn btn-sm btn-primary" @onclick="OpenCreateTeacher">+ Add Teacher</button>
                </div>
                @foreach (var u in _allUsers.Where(u => u.Role == "Teacher")) { @UserRow(u) }
                @if (!_allUsers.Any(u => u.Role == "Teacher"))
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-mortarboard-fill" style="font-size:2rem"></i></div>
                        <div class="empty-txt">No teachers yet</div>
                    </div>
                }
            }

            <!-- ── PARENTS ── -->
            @if (_activeTab == "Parents")
            {
                <div class="sec-hd">
                    <h2><i class="bi bi-people-fill"></i> Parents</h2>
                    <button class="btn btn-sm btn-primary" @onclick="OpenCreateParent">+ Add Parent</button>
                </div>
                @foreach (var u in _allUsers.Where(u => u.Role == "Parent")) { @UserRow(u) }
                @if (!_allUsers.Any(u => u.Role == "Parent"))
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-people-fill" style="font-size:2rem"></i></div>
                        <div class="empty-txt">No parents yet</div>
                    </div>
                }
            }

            <!-- ── FLAGGED ── -->
            @if (_activeTab == "Flagged")
            {
                <div class="sec-hd"><h2><i class="bi bi-exclamation-triangle-fill"></i> Flagged Messages</h2></div>
                @if (!_flaggedMessages.Any())
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-shield-check-fill" style="font-size:2rem;color:var(--green)"></i></div>
                        <div class="empty-txt">No flagged messages</div>
                        <div class="empty-sub">Classroom is safe!</div>
                    </div>
                }
                else
                {
                    <div class="tbl-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Message</th>
                                    <th>Label</th>
                                    <th>Score</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in _flaggedMessages)
                                {
                                    <tr>
                                        <td><span style="font-weight:600">@m.SenderName</span></td>
                                        <td style="max-width:260px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@m.MaskedMessage</td>
                                        <td>
                                            <span class="badge @(m.Label == "Review" ? "badge-red" : "badge-gold")">@m.Label</span>
                                        </td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:.5rem">
                                                <div class="score-bar-mini">
                                                    <div class="score-fill-mini @(m.Score>=.8?"hi":m.Score>=.5?"md":"lo")"
                                                         style="width:@((int)(m.Score*100))%"></div>
                                                </div>
                                                <span style="font-size:.72rem;font-weight:700">@m.Score.ToString("P0")</span>
                                            </div>
                                        </td>
                                        <td style="font-size:.72rem;color:var(--text-m)">@m.Timestamp.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }

            <!-- ── COMPLAINTS ── -->
            @if (_activeTab == "Complaints")
            {
                <div class="sec-hd"><h2><i class="bi bi-clipboard2-fill"></i> Complaints</h2></div>
                @if (!_complaints.Any())
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-inbox-fill" style="font-size:2rem"></i></div>
                        <div class="empty-txt">No complaints filed</div>
                    </div>
                }
                else
                {
                    @foreach (var c in _complaints)
                    {
                        <div class="card card-flat card-sm" style="margin-bottom:.65rem">
                            <div style="display:flex;align-items:flex-start;gap:.75rem">
                                <div style="flex:1">
                                    <div style="font-weight:700;font-size:.85rem;margin-bottom:.25rem">@c.Description</div>
                                    <div style="font-size:.72rem;color:var(--text-m)">@c.Timestamp.ToLocalTime().ToString("MMM dd, HH:mm")</div>
                                </div>
                                <span class="badge @StatusBadge(c.Status)">@c.Status</span>
                            </div>
                            @if (c.Status == "submitted")
                            {
                                <div style="display:flex;gap:.5rem;margin-top:.75rem">
                                    <button class="btn btn-sm btn-outline" @onclick="() => MarkUnderReview(c.Id)">Under Review</button>
                                    <button class="btn btn-sm btn-ghost" @onclick="() => MarkResolved(c.Id)"><i class="bi bi-check-circle-fill" style="color:var(--green)"></i> Resolve</button>
                                </div>
                            }
                        </div>
                    }
                }
            }

            <!-- ── CLASSES ── -->
            @if (_activeTab == "Classes")
            {
                <div class="sec-hd">
                    <h2><i class="bi bi-journal-bookmark-fill"></i> Classes</h2>
                    <button class="btn btn-sm btn-primary" @onclick="OpenCreateClass">+ New Class</button>
                </div>
                @if (!_classes.Any())
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-journal-bookmark-fill" style="font-size:2rem"></i></div>
                        <div class="empty-txt">No classes yet</div>
                    </div>
                }
                else
                {
                    <div class="tbl-wrap">
                        <table class="data-table">
                            <thead>
                                <tr><th>Name</th><th>Subject</th><th>Section</th><th>Teacher</th><th>Students</th><th>Actions</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var cl in _classes)
                                {
                                    <tr>
                                        <td style="font-weight:600">@cl.Name</td>
                                        <td>@cl.Subject</td>
                                        <td>@cl.Section</td>
                                        <td>@(cl.Teacher ?? "—")</td>
                                        <td>@cl.StudentCount</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline" @onclick="() => ManageClass(cl)"><i class="bi bi-gear-fill"></i> Manage</button>
                                            <button class="btn btn-sm btn-danger-o" style="margin-left:.3rem"
                                                    @onclick="() => DeleteClass(cl.Id)"><i class="bi bi-trash-fill"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (_manageClass != null)
                {
                    <div class="card" style="margin-top:1.25rem">
                        <div style="font-weight:800;font-size:.95rem;margin-bottom:.85rem">
                            Manage: @_manageClass.Name
                            <button class="btn btn-sm btn-ghost" style="margin-left:.5rem;font-size:.7rem"
                                    @onclick="() => _manageClass = null">✕ Close</button>
                        </div>
                        <div style="display:flex;gap:.65rem;margin-bottom:.65rem;flex-wrap:wrap">
                            <select class="form-input" style="flex:1;min-width:160px" @bind="_addStudentId">
                                <option value="0">Select student…</option>
                                @foreach (var u in _allUsers.Where(u => u.Role == "Child"))
                                {
                                    <option value="@u.Id">@u.DisplayName</option>
                                }
                            </select>
                            <button class="btn btn-sm btn-primary" @onclick="AddStudentToClass">+ Add Student</button>
                        </div>
                        @if (!string.IsNullOrEmpty(_classMsg))
                        {
                            <div class="alert-ok">@_classMsg</div>
                        }
                    </div>
                }
            }

            <!-- ── LINKS (Parent-Child) ── -->
            @if (_activeTab == "Links")
            {
                <div class="sec-hd">
                    <h2><i class="bi bi-link-45deg"></i> Parent-Child Links</h2>
                    <button class="btn btn-sm btn-primary" @onclick="() => _showLinkModal = true">+ New Link</button>
                </div>
                @if (!_parentLinks.Any())
                {
                    <div class="empty-block">
                        <div class="empty-ico"><i class="bi bi-link-45deg" style="font-size:2rem"></i></div>
                        <div class="empty-txt">No parent-child links</div>
                    </div>
                }
                else
                {
                    <div class="tbl-wrap">
                        <table class="data-table">
                            <thead><tr><th>Parent</th><th>Child</th><th>Linked</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var lk in _parentLinks)
                                {
                                    <tr>
                                        <td>@lk.ParentName<br/><span style="font-size:.68rem;color:var(--text-m)">@lk.ParentEmail</span></td>
                                        <td>@lk.ChildName<br/><span style="font-size:.68rem;color:var(--text-m)">@lk.ChildEmail</span></td>
                                        <td style="font-size:.72rem;color:var(--text-m)">@lk.LinkedAt.ToLocalTime().ToString("MMM dd")</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger-o"
                                                    @onclick="() => UnlinkParentChild(lk.ParentId, lk.ChildId)"><i class="bi bi-trash-fill"></i> Unlink</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }

            } <!-- end !_loading -->

            @if (!string.IsNullOrEmpty(_toast))
            {
                <div class="toast-bar">@_toast</div>
            }

        </div><!-- /page-content -->
    </div><!-- /main-area -->
</div><!-- /app-root -->

<!-- Mobile bottom nav -->
<nav class="mobile-nav" style="display:none">
    @foreach (var (tab, iconCls, label) in _tabs)
    {
        <button class="mnav-item @(_activeTab == tab ? "active" : "")"
                @onclick="() => SetTab(tab)">
            <i class="bi @iconCls"></i>
            <span>@label</span>
        </button>
    }
</nav>

<!-- ── Create class modal ── -->
@if (_showCreateClass)
{
    <div class="modal-overlay" @onclick="() => _showCreateClass = false">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-head">
                <div class="modal-title"><i class="bi bi-journal-bookmark-fill"></i> New Class</div>
                <button class="modal-close" @onclick="() => _showCreateClass = false">✕</button>
            </div>
            <div class="form-group">
                <label class="form-label">Class Name</label>
                <input class="form-input" @bind="_clsName" placeholder="e.g. Class 5A" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Section</label>
                    <input class="form-input" @bind="_clsSection" placeholder="A" />
                </div>
                <div class="form-group">
                    <label class="form-label">Subject</label>
                    <input class="form-input" @bind="_clsSubject" placeholder="Mathematics" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Assign Teacher</label>
                <select class="form-input" @bind="_clsTeacherId">
                    <option value="0">— No teacher —</option>
                    @foreach (var t in _allUsers.Where(u => u.Role == "Teacher"))
                    {
                        <option value="@t.Id">@t.DisplayName</option>
                    }
                </select>
            </div>
            @if (!string.IsNullOrEmpty(_clsMsg))
            {
                <div class="@(_clsOk ? "alert-ok" : "alert-err")" style="margin-bottom:.75rem">@_clsMsg</div>
            }
            <div style="display:flex;gap:.65rem">
                <button class="btn btn-outline" @onclick="() => _showCreateClass = false" style="flex:1">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateClass" disabled="@_clsBusy" style="flex:2">
                    @(_clsBusy ? "Creating…" : "Create Class")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Link parent-child modal ── -->
@if (_showLinkModal)
{
    <div class="modal-overlay" @onclick="() => _showLinkModal = false">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-head">
                <div class="modal-title"><i class="bi bi-link-45deg"></i> Link Parent ↔ Child</div>
                <button class="modal-close" @onclick="() => _showLinkModal = false">✕</button>
            </div>
            <div class="form-group">
                <label class="form-label">Parent</label>
                <select class="form-input" @bind="_linkParentId">
                    <option value="0">Select parent…</option>
                    @foreach (var p in _allUsers.Where(u => u.Role == "Parent"))
                    {
                        <option value="@p.Id">@p.DisplayName (@p.Email)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Child</label>
                <select class="form-input" @bind="_linkChildId">
                    <option value="0">Select child…</option>
                    @foreach (var c in _allUsers.Where(u => u.Role == "Child"))
                    {
                        <option value="@c.Id">@c.DisplayName (@c.Email)</option>
                    }
                </select>
            </div>
            @if (!string.IsNullOrEmpty(_linkMsg))
            {
                <div class="@(_linkOk ? "alert-ok" : "alert-err")" style="margin-bottom:.75rem">@_linkMsg</div>
            }
            <div style="display:flex;gap:.65rem">
                <button class="btn btn-outline" @onclick="() => _showLinkModal = false" style="flex:1">Cancel</button>
                <button class="btn btn-primary" @onclick="LinkParentChild" disabled="@_linkBusy" style="flex:2">
                    @(_linkBusy ? "Linking…" : "Link")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Create user modal (Parent / Teacher) ── -->
@if (_showCreate)
{
    <div class="modal-overlay" @onclick="CloseCreate">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-head">
                <div class="modal-title"><i class="bi bi-person-plus-fill"></i> Create Account</div>
                <button class="modal-close" @onclick="CloseCreate"><i class="bi bi-x-lg"></i></button>
            </div>

            @if (!string.IsNullOrEmpty(_createError))
            {
                <div class="auth-error" style="margin-bottom:.85rem"><i class="bi bi-exclamation-triangle-fill"></i> @_createError</div>
            }
            @if (_createDone)
            {
                <div class="auth-success" style="margin-bottom:.85rem"><i class="bi bi-check-circle-fill" style="color:var(--green)"></i> Account created!</div>
            }

            <div class="field">
                <label class="field-label">Account Type</label>
                <div class="role-pick">
                    @foreach (var (role, iconCls, lbl) in _roles)
                    {
                        <div class="role-tile @(_createRole == role ? "selected" : "")"
                             @onclick="() => _createRole = role">
                            <span class="rt-icon"><i class="bi @iconCls"></i></span>
                            <span class="rt-lbl">@lbl</span>
                        </div>
                    }
                </div>
            </div>
            <div class="field">
                <label class="field-label">Full Name</label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="bi bi-person-fill"></i></span>
                    <input class="field-input" @bind="_createName" placeholder="Full name" />
                </div>
            </div>
            <div class="field">
                <label class="field-label">Email</label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="bi bi-envelope-fill"></i></span>
                    <input class="field-input" @bind="_createEmail" placeholder="email@example.com" type="email" />
                </div>
            </div>
            <div class="field">
                <label class="field-label">Password</label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="bi bi-key-fill"></i></span>
                    <input class="field-input" @bind="_createPassword" placeholder="Min 6 characters" type="password" />
                </div>
            </div>
            <div style="display:flex;gap:.65rem;margin-top:.5rem">
                <button class="btn btn-outline" @onclick="CloseCreate" style="flex:1">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateUser" disabled="@_createBusy" style="flex:2">
                    @(_createBusy ? "Creating…" : "Create Account")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Create student modal (atomic: student + class + parent) ── -->
@if (_showCreateStudent)
{
    <div class="modal-overlay" @onclick="CloseCreateStudent">
        <div class="modal-box" style="max-width:540px;max-height:92vh;overflow-y:auto" @onclick:stopPropagation>
            <div class="modal-head">
                <div class="modal-title"><i class="bi bi-person-plus-fill"></i> Add New Student</div>
                <button class="modal-close" @onclick="CloseCreateStudent"><i class="bi bi-x-lg"></i></button>
            </div>

            @if (!string.IsNullOrEmpty(_stuError))
            {
                <div class="auth-error" style="margin-bottom:.85rem"><i class="bi bi-exclamation-triangle-fill"></i> @_stuError</div>
            }
            @if (_stuDone)
            {
                <div class="auth-success" style="margin-bottom:.85rem"><i class="bi bi-check-circle-fill" style="color:var(--green)"></i> Student created successfully!</div>
            }

            <!-- ── Student Info ── -->
            <div class="modal-section-hd"><i class="bi bi-person-fill"></i> Student Information</div>

            <div class="field">
                <label class="field-label">Full Name <span class="req-star">*</span></label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="bi bi-person-fill"></i></span>
                    <input class="field-input" @bind="_stuName" placeholder="e.g. Ahmed Raza" />
                </div>
            </div>
            <div class="field">
                <label class="field-label">Email <span class="req-star">*</span></label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="bi bi-envelope-fill"></i></span>
                    <input class="field-input" @bind="_stuEmail" type="email" placeholder="student@school.edu" />
                </div>
            </div>
            <div class="field">
                <label class="field-label">Password <span class="req-star">*</span></label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="bi bi-key-fill"></i></span>
                    <input class="field-input" @bind="_stuPassword" type="password" placeholder="Min 6 characters" />
                </div>
            </div>
            <div class="field">
                <label class="field-label">
                    Roll Number <span class="req-star">*</span>
                    <span style="color:var(--text-m);font-weight:400;margin-left:.35rem">(must be unique)</span>
                </label>
                <div class="field-wrap">
                    <span class="field-icon"><i class="bi bi-hash"></i></span>
                    <input class="field-input" @bind="_stuRoll" placeholder="e.g. 2024-CS-001" />
                </div>
            </div>

            <!-- ── Class Assignment ── -->
            <div class="modal-section-hd"><i class="bi bi-journal-bookmark-fill"></i> Class Assignment</div>

            <div class="field">
                <label class="field-label">Class <span class="req-star">*</span></label>
                <select class="form-input" @bind="_stuClassId">
                    <option value="0">— Select a class —</option>
                    @foreach (var cl in _classes)
                    {
                        <option value="@cl.Id">@cl.Name · Section @cl.Section @(cl.Teacher != null ? $"({cl.Teacher})" : "")</option>
                    }
                </select>
            </div>

            <!-- ── Parent Assignment ── -->
            <div class="modal-section-hd"><i class="bi bi-people-fill"></i> Parent Account <span class="req-star">*</span></div>

            <div class="field">
                <div class="parent-mode-pick">
                    <div class="pmode-tile @(_stuParentMode == "existing" ? "selected" : "")"
                         @onclick='() => { _stuParentMode = "existing"; StateHasChanged(); }'>
                        <i class="bi bi-person-check-fill"></i>
                        <span>Existing Parent</span>
                    </div>
                    <div class="pmode-tile @(_stuParentMode == "new" ? "selected" : "")"
                         @onclick='() => { _stuParentMode = "new"; StateHasChanged(); }'>
                        <i class="bi bi-person-plus-fill"></i>
                        <span>Create New Parent</span>
                    </div>
                </div>
            </div>

            @if (_stuParentMode == "existing")
            {
                <div class="field">
                    <label class="field-label">Select Parent <span class="req-star">*</span></label>
                    <select class="form-input" @bind="_stuExistingParentId">
                        <option value="0">— Choose parent account —</option>
                        @foreach (var p in _allUsers.Where(u => u.Role == "Parent"))
                        {
                            <option value="@p.Id">@p.DisplayName (@p.Email)</option>
                        }
                    </select>
                    @if (!_allUsers.Any(u => u.Role == "Parent"))
                    {
                        <div style="font-size:.75rem;color:var(--text-m);margin-top:.35rem">
                            <i class="bi bi-info-circle-fill"></i> No parent accounts yet — switch to "Create New Parent"
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="field">
                    <label class="field-label">Parent Full Name <span class="req-star">*</span></label>
                    <div class="field-wrap">
                        <span class="field-icon"><i class="bi bi-person-fill"></i></span>
                        <input class="field-input" @bind="_stuParentName" placeholder="Parent's full name" />
                    </div>
                </div>
                <div class="field">
                    <label class="field-label">Parent Email <span class="req-star">*</span></label>
                    <div class="field-wrap">
                        <span class="field-icon"><i class="bi bi-envelope-fill"></i></span>
                        <input class="field-input" @bind="_stuParentEmail" type="email" placeholder="parent@example.com" />
                    </div>
                </div>
                <div class="field">
                    <label class="field-label">Parent Password <span class="req-star">*</span></label>
                    <div class="field-wrap">
                        <span class="field-icon"><i class="bi bi-key-fill"></i></span>
                        <input class="field-input" @bind="_stuParentPassword" type="password" placeholder="Min 6 characters" />
                    </div>
                </div>
            }

            <div style="display:flex;gap:.65rem;margin-top:.85rem;padding-top:.65rem;border-top:1px solid var(--border)">
                <button class="btn btn-outline" @onclick="CloseCreateStudent" style="flex:1">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateStudent" disabled="@_stuBusy" style="flex:2">
                    @if (_stuBusy) { <text><i class="bi bi-hourglass-split"></i> Creating…</text> }
                    else { <text><i class="bi bi-check-circle-fill"></i> Create Student</text> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    record UserDto(int Id, string DisplayName, string Email, string Role, string Status);
    record ComplaintDto(int Id, string Description, string Status, DateTime Timestamp);
    record ClassDto(int Id, string Name, string Section, string Subject, string? Teacher, int TeacherId, int StudentCount);
    record ClassDetail(int Id, string Name);
    record ParentLinkDto(int ParentId, string ParentName, string ParentEmail,
                         int ChildId,  string ChildName,  string ChildEmail, DateTime LinkedAt);

    DashboardStats?          _stats;
    List<UserDto>            _allUsers        = new();
    List<UserDto>            _pendingUsers    = new();
    List<FlaggedMessageItem> _flaggedMessages = new();
    List<ComplaintDto>       _complaints      = new();
    List<ClassDto>           _classes         = new();
    List<ParentLinkDto>      _parentLinks     = new();
    bool   _loading = true;
    string _activeTab = "Pending";
    string _toast = "";

    static readonly (string tab, string icon, string label)[] _tabs = {
        ("Pending","bi-hourglass-split","Pending"),
        ("Students","bi-person-fill","Students"),
        ("Teachers","bi-mortarboard-fill","Teachers"),
        ("Parents","bi-people-fill","Parents"),
        ("Flagged","bi-exclamation-triangle-fill","Flagged"),
        ("Complaints","bi-clipboard2-fill","Complaints"),
        ("Classes","bi-journal-bookmark-fill","Classes"),
        ("Links","bi-link-45deg","Links")
    };

    // Create user modal (Parent / Teacher only)
    bool   _showCreate, _createBusy, _createDone;
    string _createRole = "Parent", _createName = "", _createEmail = "", _createPassword = "", _createError = "";

    static readonly (string role, string icon, string label)[] _roles = {
        ("Parent","bi-people-fill","Parent"), ("Teacher","bi-mortarboard-fill","Teacher")
    };

    // Student creation modal (atomic: student + class + parent)
    bool   _showCreateStudent, _stuBusy, _stuDone;
    string _stuName = "", _stuEmail = "", _stuPassword = "", _stuRoll = "", _stuError = "";
    string _stuParentMode = "existing";   // "existing" | "new"
    int    _stuClassId, _stuExistingParentId;
    string _stuParentName = "", _stuParentEmail = "", _stuParentPassword = "";

    // Create class modal
    bool   _showCreateClass, _clsBusy, _clsOk;
    string _clsName = "", _clsSection = "", _clsSubject = "", _clsMsg = "";
    int    _clsTeacherId;

    // Manage class
    ClassDto? _manageClass;
    int       _addStudentId;
    string    _classMsg = "";

    // Parent-child link modal
    bool   _showLinkModal, _linkBusy, _linkOk;
    int    _linkParentId, _linkChildId;
    string _linkMsg = "";

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitAsync();
        if (!AuthState.IsAuthenticated || !AuthState.IsAdmin) { Nav.NavigateTo("/login"); return; }
        await LoadData();
    }

    async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _stats           = await Api.GetDashboardStatsAsync();
        _allUsers        = await Api.GetAsync<List<UserDto>>("admin/users") ?? new();
        _pendingUsers    = await Api.GetAsync<List<UserDto>>("admin/users/pending") ?? new();
        _flaggedMessages = await Api.GetFlaggedMessagesAsync();
        _complaints      = await Api.GetAsync<List<ComplaintDto>>("reports/complaint") ?? new();
        _classes         = await Api.GetAsync<List<ClassDto>>("classes") ?? new();
        _parentLinks     = await Api.GetAsync<List<ParentLinkDto>>("admin/parent-links") ?? new();
        _loading = false; StateHasChanged();
    }

    async Task SetTab(string tab)
    {
        _activeTab = tab;
        if (_allUsers.Count == 0) await LoadData();
        else StateHasChanged();
    }

    // ── Class management ──────────────────────────────────────

    void OpenCreateClass() { _clsName = _clsSection = _clsSubject = _clsMsg = ""; _clsTeacherId = 0; _showCreateClass = true; }

    async Task CreateClass()
    {
        if (string.IsNullOrWhiteSpace(_clsName)) { _clsMsg = "Name required."; _clsOk = false; return; }
        _clsBusy = true; StateHasChanged();
        var ok = await Api.PostAsync("classes", new
        {
            Name      = _clsName,
            Section   = _clsSection,
            Subject   = _clsSubject,
            TeacherId = _clsTeacherId == 0 ? (int?)null : _clsTeacherId
        });
        _clsBusy = false;
        _clsOk   = ok;
        _clsMsg  = ok ? "Class created!" : "Failed to create class.";
        if (ok) { await LoadData(); await Task.Delay(1500); _showCreateClass = false; }
        StateHasChanged();
    }

    async Task DeleteClass(int id)
    {
        if (await Api.DeleteAsync($"classes/{id}")) { _toast = "Class deleted."; await LoadData(); ShowToast(); }
    }

    void ManageClass(ClassDto cl) { _manageClass = cl; _addStudentId = 0; _classMsg = ""; }

    async Task AddStudentToClass()
    {
        if (_manageClass == null || _addStudentId == 0) return;
        var ok = await Api.PostAsync($"classes/{_manageClass.Id}/students", new { StudentId = _addStudentId });
        _classMsg = ok ? "Student added!" : "Already enrolled or failed.";
        if (ok) await LoadData();
        StateHasChanged();
    }

    // ── Parent-child links ────────────────────────────────────

    async Task LinkParentChild()
    {
        if (_linkParentId == 0 || _linkChildId == 0) { _linkMsg = "Select both users."; _linkOk = false; return; }
        _linkBusy = true; StateHasChanged();
        var ok = await Api.PostAsync("admin/parent-links", new { ParentId = _linkParentId, ChildId = _linkChildId });
        _linkBusy = false;
        _linkOk   = ok;
        _linkMsg  = ok ? "Linked!" : "Already linked or invalid.";
        if (ok) { await LoadData(); await Task.Delay(1500); _showLinkModal = false; }
        StateHasChanged();
    }

    async Task UnlinkParentChild(int parentId, int childId)
    {
        if (await Api.DeleteAsync($"admin/parent-links/{parentId}/{childId}"))
        { _toast = "Link removed."; await LoadData(); ShowToast(); }
    }

    async Task Approve(int id)
    {
        if (await Api.PostAsync($"admin/users/{id}/approve", new { }))
        { _toast = "Account approved"; await LoadData(); }
        ShowToast();
    }

    async Task Disable(int id)
    {
        if (await Api.PostAsync($"admin/users/{id}/disable", new { }))
        { _toast = "Account disabled"; await LoadData(); }
        ShowToast();
    }

    async Task UpdateComplaint(int id, string status)
    {
        await Api.PatchAsync($"reports/complaint/{id}", new { Status = status });
        _toast = status == "resolved" ? "Resolved" : "Marked under review";
        await LoadData();
        ShowToast();
    }

    void OpenCreate(string role)  { _createRole = role; _createError = ""; _createDone = false; _showCreate = true; }
    void OpenCreateTeacher() => OpenCreate("Teacher");
    void OpenCreateParent()  => OpenCreate("Parent");
    void CloseCreate()       { _showCreate = false; _createName = _createEmail = _createPassword = ""; _createError = ""; _createDone = false; }

    void OpenCreateChild()
    {
        _stuName = _stuEmail = _stuPassword = _stuRoll = _stuError = "";
        _stuParentName = _stuParentEmail = _stuParentPassword = "";
        _stuParentMode = "existing";
        _stuClassId = _stuExistingParentId = 0;
        _stuDone = false;
        _showCreateStudent = true;
    }

    void CloseCreateStudent()
    {
        _showCreateStudent = false;
        _stuName = _stuEmail = _stuPassword = _stuRoll = _stuError = "";
        _stuParentName = _stuParentEmail = _stuParentPassword = "";
        _stuDone = false;
    }

    async Task CreateStudent()
    {
        if (string.IsNullOrWhiteSpace(_stuName))     { _stuError = "Student name is required."; return; }
        if (string.IsNullOrWhiteSpace(_stuEmail))    { _stuError = "Student email is required."; return; }
        if (string.IsNullOrWhiteSpace(_stuPassword)) { _stuError = "Password is required (min 6 chars)."; return; }
        if (string.IsNullOrWhiteSpace(_stuRoll))     { _stuError = "Roll number is required."; return; }
        if (_stuClassId == 0)                        { _stuError = "Please select a class."; return; }

        if (_stuParentMode == "existing" && _stuExistingParentId == 0)
            { _stuError = "Please select an existing parent account."; return; }
        if (_stuParentMode == "new")
        {
            if (string.IsNullOrWhiteSpace(_stuParentName))     { _stuError = "Parent name is required."; return; }
            if (string.IsNullOrWhiteSpace(_stuParentEmail))    { _stuError = "Parent email is required."; return; }
            if (string.IsNullOrWhiteSpace(_stuParentPassword)) { _stuError = "Parent password is required."; return; }
        }

        _stuBusy = true; _stuError = ""; StateHasChanged();

        var payload = new
        {
            Name               = _stuName.Trim(),
            Email              = _stuEmail.Trim(),
            Password           = _stuPassword,
            RollNumber         = _stuRoll.Trim(),
            ClassId            = _stuClassId,
            ExistingParentId   = _stuParentMode == "existing" ? _stuExistingParentId : (int?)null,
            ParentName         = _stuParentMode == "new" ? _stuParentName.Trim()     : (string?)null,
            ParentEmail        = _stuParentMode == "new" ? _stuParentEmail.Trim()    : (string?)null,
            ParentPassword     = _stuParentMode == "new" ? _stuParentPassword        : (string?)null,
        };

        var (ok, error) = await Api.PostWithErrorAsync("admin/students", payload);
        _stuBusy = false;

        if (!ok) { _stuError = string.IsNullOrEmpty(error) ? "Failed to create student." : error; StateHasChanged(); return; }

        _stuDone = true;
        await LoadData();
        await Task.Delay(2000);
        CloseCreateStudent();
    }

    Task MarkUnderReview(int id) => UpdateComplaint(id, "underReview");
    Task MarkResolved(int id)    => UpdateComplaint(id, "resolved");

    async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(_createEmail) || string.IsNullOrWhiteSpace(_createPassword) || string.IsNullOrWhiteSpace(_createName))
        { _createError = "All fields are required."; return; }

        _createBusy = true; _createError = "";
        var ok = await Api.PostAsync("admin/users", new
        {
            Email       = _createEmail.Trim(),
            Password    = _createPassword,
            DisplayName = _createName.Trim(),
            Role        = _createRole
        });
        _createBusy = false;

        if (!ok) { _createError = "Failed. Email may already be taken."; return; }

        _createDone = true;
        _createName = _createEmail = _createPassword = "";
        await LoadData();
        await Task.Delay(2000);
        CloseCreate();
    }

    void ShowToast() { StateHasChanged(); Task.Delay(3000).ContinueWith(_ => { _toast = ""; InvokeAsync(StateHasChanged); }); }

    static string RoleIconClass(string role) => role switch
    {
        "Child"   => "bi-person-fill",
        "Parent"  => "bi-people-fill",
        "Teacher" => "bi-mortarboard-fill",
        "Admin"   => "bi-shield-fill",
        _         => "bi-person-circle"
    };
    static string StatusBadge(string s)  => s switch { "resolved" => "badge-green", "underReview" => "badge-gold", _ => "badge-blue" };

    RenderFragment UserRow(UserDto u) => __builder =>
    {
        <div class="user-row">
            <div class="user-av" style="font-size:1.2rem;display:flex;align-items:center;justify-content:center"><i class="bi @RoleIconClass(u.Role)"></i></div>
            <div class="user-info">
                <div class="user-name">@u.DisplayName</div>
                <div class="user-email">@u.Email</div>
            </div>
            <div class="user-acts">
                <span class="badge @(u.Status == "active" ? "badge-green" : u.Status == "pending" ? "badge-gold" : "badge-red")">
                    @u.Status
                </span>
                @if (u.Status != "active")
                {
                    <button class="btn btn-sm btn-ghost" @onclick="() => Approve(u.Id)" title="Approve"><i class="bi bi-check-circle-fill"></i></button>
                }
                @if (u.Status != "disabled")
                {
                    <button class="btn btn-sm btn-danger-o" @onclick="() => Disable(u.Id)" title="Disable"><i class="bi bi-slash-circle-fill"></i></button>
                }
            </div>
        </div>;
    };

}
