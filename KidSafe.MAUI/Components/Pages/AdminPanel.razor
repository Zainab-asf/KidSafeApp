@page "/admin"
@inject ApiService Api
@inject AuthStateService AuthState
@inject NavigationManager Nav

<div class="app-shell">
    <div class="topbar">
        <div class="topbar-logo"><span>🛡️</span>KidSafe</div>
        <div class="topbar-spacer"></div>
        <span class="topbar-role">Admin</span>
        <button class="btn-icon-circle" @onclick="Logout">🚪</button>
    </div>

    <div class="page-scroll">

        <!-- Analytics cards -->
        @if (_stats != null)
        {
            <div class="stats-row" style="margin-top:.25rem">
                <div class="stat-card">
                    <div class="stat-emoji">👥</div>
                    <div class="stat-value">@_allUsers.Count</div>
                    <div class="stat-label">Total Users</div>
                </div>
                <div class="stat-card warning">
                    <div class="stat-emoji">⏳</div>
                    <div class="stat-value" style="color:var(--warning)">@_stats.PendingTeachers</div>
                    <div class="stat-label">Pending</div>
                </div>
                <div class="stat-card danger">
                    <div class="stat-emoji">🚫</div>
                    <div class="stat-value" style="color:var(--danger)">@_stats.TotalReview</div>
                    <div class="stat-label">Blocked</div>
                </div>
                <div class="stat-card info">
                    <div class="stat-emoji">📋</div>
                    <div class="stat-value" style="color:var(--info)">@_stats.TotalComplaints</div>
                    <div class="stat-label">Complaints</div>
                </div>
            </div>
        }

        <!-- Tabs -->
        <div class="admin-tabs">
            @foreach (var (tab, icon) in _tabs)
            {
                <button class="admin-tab @(_activeTab == tab ? "active" : "")"
                        @onclick="() => SetTab(tab)">
                    @icon @tab
                </button>
            }
        </div>

        <!-- ── PENDING ── -->
        @if (_activeTab == "Pending")
        {
            @if (_loading) { <div class="loading-overlay"><div class="spinner"></div></div> }
            else if (!_pendingUsers.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">✅</div>
                    <div class="empty-text">No pending approvals</div>
                </div>
            }
            else
            {
                @foreach (var u in _pendingUsers)
                {
                    <div class="user-row">
                        <div class="user-avatar">@RoleEmoji(u.Role)</div>
                        <div class="user-info">
                            <div class="user-name">@u.DisplayName</div>
                            <div class="user-meta">@u.Email · @u.Role</div>
                        </div>
                        <div class="user-actions">
                            <button class="btn btn-sm btn-ghost" @onclick="() => Approve(u.Id)">✅</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Disable(u.Id)">🚫</button>
                        </div>
                    </div>
                }
            }
        }

        <!-- ── STUDENTS ── -->
        @if (_activeTab == "Students")
        {
            <div class="section-header">
                <span class="section-title">👦 Students</span>
                <button class="section-action" @onclick="OpenCreateChild">+ Add</button>
            </div>
            @if (_loading) { <div class="loading-overlay"><div class="spinner"></div></div> }
            else { @foreach (var u in _allUsers.Where(u => u.Role == "Child")) { @UserRow(u) } }
        }

        <!-- ── TEACHERS ── -->
        @if (_activeTab == "Teachers")
        {
            <div class="section-header">
                <span class="section-title">👩‍🏫 Teachers</span>
                <button class="section-action" @onclick="OpenCreateTeacher">+ Add</button>
            </div>
            @if (_loading) { <div class="loading-overlay"><div class="spinner"></div></div> }
            else { @foreach (var u in _allUsers.Where(u => u.Role == "Teacher")) { @UserRow(u) } }
        }

        <!-- ── PARENTS ── -->
        @if (_activeTab == "Parents")
        {
            <div class="section-header">
                <span class="section-title">👨‍👩‍👦 Parents</span>
                <button class="section-action" @onclick="OpenCreateParent">+ Add</button>
            </div>
            @if (_loading) { <div class="loading-overlay"><div class="spinner"></div></div> }
            else { @foreach (var u in _allUsers.Where(u => u.Role == "Parent")) { @UserRow(u) } }
        }

        <!-- ── FLAGGED ── -->
        @if (_activeTab == "Flagged")
        {
            @if (_loading) { <div class="loading-overlay"><div class="spinner"></div></div> }
            else if (!_flaggedMessages.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">✅</div>
                    <div class="empty-text">No flagged messages</div>
                </div>
            }
            else
            {
                @foreach (var m in _flaggedMessages)
                {
                    var cls = m.Score >= .8 ? "high" : m.Score >= .5 ? "medium" : "low";
                    <div class="flagged-row @m.Label.ToLower()">
                        <div class="flagged-top">
                            <span class="flagged-sender">@m.SenderName</span>
                            <span class="badge @(m.Label == "Review" ? "badge-red" : "badge-yellow")">@m.Label</span>
                        </div>
                        <div class="flagged-msg">@m.MaskedMessage</div>
                        <div class="flagged-footer">
                            <span class="flagged-time">@m.Timestamp.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                            <div class="score-bar"><div class="score-fill @cls" style="width:@((int)(m.Score*100))%"></div></div>
                            <span class="score-pct">@m.Score.ToString("P0")</span>
                        </div>
                    </div>
                }
            }
        }

        <!-- ── COMPLAINTS ── -->
        @if (_activeTab == "Complaints")
        {
            @if (_loading) { <div class="loading-overlay"><div class="spinner"></div></div> }
            else if (!_complaints.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <div class="empty-text">No complaints</div>
                </div>
            }
            else
            {
                @foreach (var c in _complaints)
                {
                    <div class="card card-flat card-sm" style="margin-bottom:.5rem">
                        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem">
                            <span class="fw-bold" style="flex:1;font-size:.85rem">@c.Description</span>
                            <span class="badge @StatusBadge(c.Status)">@c.Status</span>
                        </div>
                        <div class="text-muted">@c.Timestamp.ToLocalTime().ToString("MMM dd, HH:mm")</div>
                        @if (c.Status == "submitted")
                        {
                            <div style="display:flex;gap:.4rem;margin-top:.6rem">
                                <button class="btn btn-sm btn-ghost" @onclick="() => MarkUnderReview(c.Id)">Under Review</button>
                                <button class="btn btn-sm btn-outline" @onclick="() => MarkResolved(c.Id)">Resolve</button>
                            </div>
                        }
                    </div>
                }
            }
        }

        @if (!string.IsNullOrEmpty(_toast))
        {
            <div class="toast safe" style="position:relative;bottom:auto;margin-top:1rem;animation:none">@_toast</div>
        }

    </div>

    <div class="bottom-nav">
        <button class="nav-item active">
            <span class="nav-icon">🛡️</span>Admin
            <div class="nav-dot"></div>
        </button>
        <button class="nav-item" @onclick="LoadData">
            <span class="nav-icon">🔄</span>Refresh
            <div class="nav-dot"></div>
        </button>
        <button class="nav-item" @onclick="Logout">
            <span class="nav-icon">🚪</span>Logout
            <div class="nav-dot"></div>
        </button>
    </div>
</div>

<!-- Create user modal -->
@if (_showCreate)
{
    <div class="modal-overlay" @onclick="CloseCreate">
        <div class="modal-sheet" @onclick:stopPropagation>
            <div class="modal-handle"></div>
            <div class="modal-title">➕ Create @_createRole Account</div>

            @if (!string.IsNullOrEmpty(_createError))
            {
                <div class="msg-error">⚠️ @_createError</div>
            }
            @if (_createDone)
            {
                <div class="msg-info">✅ Account created successfully!</div>
            }

            <div class="form-group">
                <label class="form-label">Role</label>
                <div class="role-grid">
                    @foreach (var (role, icon, label) in _roles)
                    {
                        <div class="role-card @(_createRole == role ? "selected" : "")"
                             @onclick="() => _createRole = role">
                            <span class="role-icon">@icon</span>
                            <span class="role-label">@label</span>
                        </div>
                    }
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Display Name</label>
                <input class="form-input" @bind="_createName" placeholder="Full name" />
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input class="form-input" @bind="_createEmail" placeholder="email@example.com" type="email" />
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input class="form-input" @bind="_createPassword" placeholder="Temporary password" type="password" />
            </div>
            <button class="btn btn-primary" @onclick="CreateUser" disabled="@_createBusy">
                @(_createBusy ? "Creating…" : "Create Account")
            </button>
        </div>
    </div>
}

@code {
    record UserDto(int Id, string DisplayName, string Email, string Role, string Status);
    record ComplaintDto(int Id, string Description, string Status, DateTime Timestamp);

    DashboardStats?          _stats;
    List<UserDto>            _allUsers        = new();
    List<UserDto>            _pendingUsers    = new();
    List<FlaggedMessageItem> _flaggedMessages = new();
    List<ComplaintDto>       _complaints      = new();
    bool   _loading = true;
    string _activeTab = "Pending";
    string _toast = "";

    static readonly (string tab, string icon)[] _tabs = {
        ("Pending","⏳"), ("Students","👦"), ("Teachers","👩‍🏫"),
        ("Parents","👨‍👩‍👦"), ("Flagged","⚠️"), ("Complaints","📋")
    };

    // Create user form
    bool   _showCreate, _createBusy, _createDone;
    string _createRole = "Child", _createName = "", _createEmail = "", _createPassword = "", _createError = "";

    static readonly (string role, string icon, string label)[] _roles = {
        ("Child","👦","Student"), ("Parent","👨‍👩‍👦","Parent"), ("Teacher","👩‍🏫","Teacher")
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitAsync();
        if (!AuthState.IsAuthenticated || !AuthState.IsAdmin) { Nav.NavigateTo("/login"); return; }
        await LoadData();
    }

    async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _stats           = await Api.GetDashboardStatsAsync();
        _allUsers        = await Api.GetAsync<List<UserDto>>("admin/users") ?? new();
        _pendingUsers    = await Api.GetAsync<List<UserDto>>("admin/users/pending") ?? new();
        _flaggedMessages = await Api.GetFlaggedMessagesAsync();
        _complaints      = await Api.GetAsync<List<ComplaintDto>>("reports/complaint") ?? new();
        _loading = false; StateHasChanged();
    }

    async Task SetTab(string tab) { _activeTab = tab; if (_allUsers.Count == 0) await LoadData(); }

    async Task Approve(int id)
    {
        if (await Api.PostAsync($"admin/users/{id}/approve", new { }))
        {
            _toast = "✅ Account approved";
            await LoadData();
        }
        ShowToast();
    }

    async Task Disable(int id)
    {
        if (await Api.PostAsync($"admin/users/{id}/disable", new { }))
        {
            _toast = "🚫 Account disabled";
            await LoadData();
        }
        ShowToast();
    }

    async Task UpdateComplaint(int id, string status)
    {
        await Api.PatchAsync($"reports/complaint/{id}", new { Status = status });
        _toast = status == "resolved" ? "✅ Resolved" : "📋 Marked under review";
        await LoadData();
        ShowToast();
    }

    void OpenCreate(string role)  { _createRole = role; _createError = ""; _createDone = false; _showCreate = true; }
    void OpenCreateChild()   => OpenCreate("Child");
    void OpenCreateTeacher() => OpenCreate("Teacher");
    void OpenCreateParent()  => OpenCreate("Parent");
    void CloseCreate()       { _showCreate = false; _createName = _createEmail = _createPassword = ""; _createError = ""; _createDone = false; }
    Task MarkUnderReview(int id) => UpdateComplaint(id, "underReview");
    Task MarkResolved(int id)    => UpdateComplaint(id, "resolved");

    async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(_createEmail) || string.IsNullOrWhiteSpace(_createPassword) || string.IsNullOrWhiteSpace(_createName))
        { _createError = "All fields are required."; return; }

        _createBusy = true; _createError = "";
        var r = await Api.RegisterAsync(new RegisterRequest(_createEmail, _createPassword, _createName, _createRole));
        _createBusy = false;

        if (r == null) { _createError = "Failed. Email may already be taken."; return; }

        _createDone = true;
        _createName = _createEmail = _createPassword = "";
        await LoadData();
        await Task.Delay(2000);
        CloseCreate();
    }

    void ShowToast() { StateHasChanged(); Task.Delay(3000).ContinueWith(_ => { _toast = ""; InvokeAsync(StateHasChanged); }); }

    static string RoleEmoji(string role) => role switch { "Child" => "👦", "Parent" => "👨‍👩‍👦", "Teacher" => "👩‍🏫", "Admin" => "🛡️", _ => "👤" };
    static string StatusBadge(string s)  => s switch { "resolved" => "badge-green", "underReview" => "badge-yellow", _ => "badge-blue" };

    RenderFragment UserRow(UserDto u) => __builder =>
    {
        <div class="user-row">
            <div class="user-avatar">@RoleEmoji(u.Role)</div>
            <div class="user-info">
                <div class="user-name">@u.DisplayName</div>
                <div class="user-meta">@u.Email</div>
            </div>
            <div class="user-actions">
                <span class="badge @(u.Status == "active" ? "badge-green" : u.Status == "pending" ? "badge-yellow" : "badge-red")">
                    @u.Status
                </span>
                @if (u.Status != "active")
                {
                    <button class="btn btn-sm btn-ghost" @onclick="() => Approve(u.Id)">✅</button>
                }
                @if (u.Status != "disabled")
                {
                    <button class="btn btn-sm btn-danger" @onclick="() => Disable(u.Id)">🚫</button>
                }
            </div>
        </div>;
    };

    async Task Logout() { await AuthState.LogoutAsync(); Nav.NavigateTo("/login"); }
}
