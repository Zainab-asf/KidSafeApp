@page "/chat"
@inject ApiService Api
@inject AuthStateService AuthState
@inject ChatHubService Hub
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="chat-root">

    <!-- Chat header -->
    <div class="chat-hd">
        <button class="chat-back-btn" @onclick='() => Nav.NavigateTo("/child-home")'>←</button>
        <div class="chat-hd-av">@(_selectedClassmate?.Avatar ?? (AuthState.CurrentUser?.AvatarEmoji ?? "😊"))</div>
        <div class="chat-hd-info">
            <div class="chat-hd-name">@(_selectedClassmate?.DisplayName ?? (_className.Length > 0 ? _className : "Class Chat"))</div>
            <div class="chat-hd-status">
                <span class="conn-dot @(_hubState == HubState.Connected ? "on" : "")"></span>
                Online · AI Protected
            </div>
        </div>
        <div class="chat-shield-pill">🛡️ AI Shield ON</div>
    </div>

    <!-- Classmates row -->
    @if (_loadingClassmates)
    {
        <div class="classmates-row">
            <div class="cm-loading">Loading classmates…</div>
        </div>
    }
    else if (_classmates.Any())
    {
        <div class="classmates-row">
            @foreach (var cm in _classmates)
            {
                <div class="cm-item @(_selectedClassmate?.Id == cm.Id ? "cm-selected" : "")"
                     @onclick="() => SelectClassmate(cm)">
                    <div class="cm-av">@cm.Avatar</div>
                    <div class="cm-name">@ShortName(cm.DisplayName)</div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="classmates-row">
            <div class="cm-loading">No classmates yet — ask admin to enroll you in a class</div>
        </div>
    }

    <!-- Toast -->
    @if (!string.IsNullOrEmpty(_toast))
    {
        <div class="chat-toast @_toastClass">@_toast</div>
    }

    <!-- Messages area -->
    <div class="chat-msgs" id="msg-list">
        @if (!_messages.Any())
        {
            <div class="chat-empty">
                <div class="chat-empty-ico">💬</div>
                <div class="chat-empty-txt">
                    @(_selectedClassmate != null
                        ? $"Say hi to {ShortName(_selectedClassmate.DisplayName)}!"
                        : "Say hello to your classmates!")
                </div>
                <div class="chat-empty-sub">Be kind, be safe 🌟</div>
            </div>
        }
        @foreach (var msg in _messages)
        {
            var mine = msg.SenderId == AuthState.CurrentUser?.UserId;
            <div class="msg-row @(mine ? "mine" : "")">
                @if (!mine)
                {
                    <div class="msg-av">@(_selectedClassmate?.Avatar ?? "😊")</div>
                }
                <div class="bbl-wrap">
                    @if (msg.Label == "Review")
                    {
                        <div class="bbl blocked-msg">★★★ This message was blocked for safety ★★★</div>
                    }
                    else
                    {
                        <div class="bbl @BubbleClass(msg)">@msg.Content</div>
                    }
                    <div class="bbl-meta">
                        <span class="bbl-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</span>
                        @if (msg.Label == "Safe" && mine)
                        {
                            <span class="bbl-safe">🛡️ Safe</span>
                        }
                        @if (msg.Label == "Review")
                        {
                            <span class="bbl-badge blocked">🚫 Blocked</span>
                        }
                        @if (msg.Label == "Watch")
                        {
                            <span class="bbl-badge watch">👁️ Watch</span>
                        }
                        @if (!mine)
                        {
                            <button class="report-btn" title="Report" @onclick="() => ReportMsg(msg)">🚩</button>
                        }
                    </div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(_typingUser))
        {
            <div class="typing-row">
                <div class="msg-av">😊</div>
                <span class="typing-lbl">@_typingUser is typing</span>
                <div class="typing-dots"><span></span><span></span><span></span></div>
            </div>
        }
    </div>

    <!-- Quick replies -->
    <div class="quick-row">
        @foreach (var r in _quickReplies)
        {
            <button class="quick-chip" @onclick="() => _input = r">@r</button>
        }
    </div>

    <!-- Input area -->
    <div class="chat-input">
        <div class="emoji-row">
            @foreach (var e in _emojis)
            {
                <button class="emoji-chip" @onclick="() => _input += e">@e</button>
            }
        </div>
        <div class="input-row">
            <input class="msg-field" @bind="_input" @bind:event="oninput"
                   @onkeyup="OnKey" placeholder="Type a kind message…" />
            <button class="send-btn @(_sending ? "busy" : "")" @onclick="Send" disabled="@_sending">
                @(_sending ? "⏳" : "➤")
            </button>
        </div>
    </div>

    <!-- Bottom nav -->
    <nav class="mobile-nav">
        <button class="mnav-item" @onclick='() => Nav.NavigateTo("/child-home")'><span>🏠</span><span>Home</span></button>
        <button class="mnav-item active"><span>💬</span><span>Chat</span></button>
        <button class="mnav-item" @onclick='() => Nav.NavigateTo("/notifications")'><span>🔔</span><span>Alerts</span></button>
        <button class="mnav-item" @onclick='() => Nav.NavigateTo("/profile")'><span>👤</span><span>Profile</span></button>
    </nav>
</div>

@code {
    record ClassmateDto(int Id, string DisplayName, string Avatar);
    record ClassmatesResponse(string? ClassName, string? Section, List<ClassmateDto>? Classmates);

    List<ChatMessage>  _messages          = new();
    List<ClassmateDto> _classmates        = new();
    ClassmateDto?      _selectedClassmate;
    string             _className         = "";
    string             _input = "", _toast = "", _toastClass = "", _typingUser = "";
    bool               _sending, _loadingClassmates = true;
    HubState           _hubState          = HubState.Disconnected;

    static readonly string[] _quickReplies = { "That's great! 😊", "Sure, let's do it! 👍", "I agree with you!", "Thanks for sharing!" };
    static readonly string[] _emojis       = { "😊","😂","❤️","👍","🎉","🌟","🦄","🎮","🍕","⚽","🌈","🦋" };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitAsync();
        if (!AuthState.IsAuthenticated || !AuthState.IsChild) { Nav.NavigateTo("/login"); return; }

        Hub.OnMessageReceived += OnMsg;
        Hub.OnUserTyping      += OnTyping;
        Hub.OnStateChanged    += OnHubState;
        await Hub.StartAsync(AuthState.CurrentUser!.Token);

        // Load classmates (same class/section only)
        var resp = await Api.GetAsync<ClassmatesResponse>("classes/classmates");
        _classmates = resp?.Classmates ?? new();
        _className  = resp?.ClassName ?? "";
        if (_classmates.Any()) _selectedClassmate = _classmates[0];
        _loadingClassmates = false;
        StateHasChanged();
    }

    void SelectClassmate(ClassmateDto cm)
    {
        _selectedClassmate = cm;
        _messages.Clear();
        StateHasChanged();
    }

    void OnMsg(ChatMessage m)
    {
        _messages.Add(m);
        InvokeAsync(StateHasChanged);
    }

    void OnHubState(HubState s) { _hubState = s; InvokeAsync(StateHasChanged); }

    void OnTyping(string name)
    {
        _typingUser = name;
        InvokeAsync(StateHasChanged);
        Task.Delay(3000).ContinueWith(_ => { _typingUser = ""; InvokeAsync(StateHasChanged); });
    }

    async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { await Send(); return; }
        await Hub.SendTypingAsync(0);
    }

    async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_input) || _sending) return;
        _sending = true;
        var text       = _input; _input = "";
        var receiverId = _selectedClassmate?.Id ?? 0;

        var local = new ChatMessage
        {
            SenderId   = AuthState.CurrentUser!.UserId,
            SenderName = "You",
            Content    = text,
            Label      = "pending",
            Timestamp  = DateTime.UtcNow
        };
        _messages.Add(local); StateHasChanged();

        var result = await Api.SendMessageAsync(new SendMessageRequest(receiverId, text));
        _messages.Remove(local);

        if (result != null)
        {
            local.Label   = result.Label;
            local.Content = result.Label == "Watch" ? result.MaskedMessage ?? text : text;
            _messages.Add(local);

            (_toast, _toastClass) = result.Label switch
            {
                "Safe"   => ("✅ Sent! +10 points", "t-safe"),
                "Watch"  => ("👁️ Message flagged and masked.", "t-warn"),
                "Review" => ("🚫 Message blocked — please be kind!", "t-block"),
                _        => ("", "")
            };
        }

        _sending = false; StateHasChanged();
        await Task.Delay(3500);
        _toast = ""; StateHasChanged();
    }

    string BubbleClass(ChatMessage m) => m.SenderId == AuthState.CurrentUser?.UserId
        ? m.Label switch { "Watch" => "flagged", "Review" => "blocked", "pending" => "pending", _ => "" }
        : "";

    async Task ReportMsg(ChatMessage msg)
    {
        var ok = await Api.ReportAbuseAsync($"Reported message from {msg.SenderName}");
        _toast = ok ? "🚩 Reported. Thank you!" : "Failed to report.";
        _toastClass = ok ? "t-safe" : "t-block";
        StateHasChanged();
        await Task.Delay(3000);
        _toast = ""; StateHasChanged();
    }

    static string ShortName(string name) => name.Split(' ').First();

    public async ValueTask DisposeAsync()
    {
        Hub.OnMessageReceived -= OnMsg;
        Hub.OnUserTyping      -= OnTyping;
        Hub.OnStateChanged    -= OnHubState;
        await Hub.DisposeAsync();
    }
}
