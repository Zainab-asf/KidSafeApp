@page "/dashboard"
@inject ApiService Api
@inject AuthStateService AuthState
@inject ChatHubService Hub
@inject FcmService Fcm
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="app-shell">
    <div class="topbar">
        <div class="topbar-logo"><span>🛡️</span>KidSafe</div>
        <div class="topbar-spacer"></div>
        <span class="topbar-role">Parent</span>
        <button class="btn-icon-circle" @onclick="Logout">🚪</button>
    </div>

    @if (!string.IsNullOrEmpty(_fcmToast))
    {
        <div class="toast info">🔔 @_fcmToast</div>
    }

    <div class="page-scroll">

        @if (_stats != null)
        {
            var riskLevel = _stats.TotalReview > 5 ? "red" : _stats.TotalWatch > 10 ? "amber" : "";
            <div class="hero-card @riskLevel">
                <div class="hero-icon">@(riskLevel == "red" ? "🚨" : riskLevel == "amber" ? "⚠️" : "✅")</div>
                <div>
                    <div class="hero-title">@(riskLevel == "red" ? "HIGH RISK" : riskLevel == "amber" ? "MEDIUM RISK" : "ALL CLEAR")</div>
                    <div class="hero-sub">Based on recent activity</div>
                </div>
            </div>

            <div class="stats-row cols-3">
                <div class="stat-card">
                    <div class="stat-emoji">✅</div>
                    <div class="stat-value" style="color:var(--primary)">@(_stats.TotalFlagged == 0 ? "All" : "—")</div>
                    <div class="stat-label">Safe</div>
                </div>
                <div class="stat-card warning">
                    <div class="stat-emoji">👁️</div>
                    <div class="stat-value" style="color:var(--warning)">@_stats.TotalWatch</div>
                    <div class="stat-label">Watch</div>
                </div>
                <div class="stat-card danger">
                    <div class="stat-emoji">🚫</div>
                    <div class="stat-value" style="color:var(--danger)">@_stats.TotalReview</div>
                    <div class="stat-label">Review</div>
                </div>
            </div>
        }

        <!-- Live alerts -->
        <div class="section-header">
            <span class="section-title"><span class="live-dot"></span>Live Alerts</span>
            <button class="section-action" @onclick="LoadData">🔄 Refresh</button>
        </div>
        @if (!_liveAlerts.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">✅</div>
                <div class="empty-text">No live alerts</div>
            </div>
        }
        @foreach (var a in _liveAlerts.AsEnumerable().Reverse().Take(5))
        {
            <div class="alert-item @a.Label.ToLower()-alert">
                <div class="alert-icon">@(a.Label == "Review" ? "🚨" : "👁️")</div>
                <div class="alert-body">
                    <div class="alert-sender">@a.SenderName</div>
                    <div class="alert-msg">@a.MaskedMessage</div>
                    <div class="alert-meta">
                        <span class="badge @(a.Label == "Review" ? "badge-red" : "badge-yellow")">@a.Label</span>
                        <span class="alert-time">@a.Time.ToLocalTime().ToString("HH:mm")</span>
                    </div>
                </div>
            </div>
        }

        <!-- Flagged messages -->
        <div class="section-header" style="margin-top:1.5rem">
            <span class="section-title">📋 Flagged Messages</span>
        </div>
        <div class="filter-tabs">
            @foreach (var f in new[] { "All", "Watch", "Review" })
            {
                <button class="filter-tab @(_filter == f ? "active" : "")" @onclick="() => _filter = f">@f</button>
            }
        </div>

        @if (_loading)
        {
            <div class="loading-overlay"><div class="spinner"></div></div>
        }
        else if (!FilteredMessages.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">✅</div>
                <div class="empty-text">No flagged messages</div>
                <div class="empty-sub">Everything looks good!</div>
            </div>
        }
        else
        {
            @foreach (var m in FilteredMessages)
            {
                var cls = m.Score >= .8 ? "high" : m.Score >= .5 ? "medium" : "low";
                <div class="flagged-row @m.Label.ToLower()">
                    <div class="flagged-top">
                        <span class="flagged-sender">@m.SenderName</span>
                        <span class="badge @(m.Label == "Review" ? "badge-red" : "badge-yellow")">@m.Label</span>
                    </div>
                    <div class="flagged-msg">@m.MaskedMessage</div>
                    <div class="flagged-footer">
                        <span class="flagged-time">@m.Timestamp.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                        <div class="score-bar"><div class="score-fill @cls" style="width:@((int)(m.Score*100))%"></div></div>
                        <span class="score-pct">@m.Score.ToString("P0")</span>
                    </div>
                </div>
            }
        }
    </div>

    <div class="bottom-nav">
        <button class="nav-item active">
            <span class="nav-icon">📊</span>Dashboard
            <div class="nav-dot"></div>
        </button>
        <button class="nav-item" @onclick="LoadData">
            <span class="nav-icon">🔄</span>Refresh
            <div class="nav-dot"></div>
        </button>
        <button class="nav-item" @onclick="Logout">
            <span class="nav-icon">🚪</span>Logout
            <div class="nav-dot"></div>
        </button>
    </div>
</div>

@code {
    DashboardStats? _stats;
    List<FlaggedMessageItem> _flaggedMessages = new();
    List<LiveAlert> _liveAlerts = new();
    string _filter = "All";
    bool _loading = true;
    string _fcmToast = "";

    record LiveAlert(string SenderName, string MaskedMessage, string Label, DateTime Time);

    IEnumerable<FlaggedMessageItem> FilteredMessages =>
        _filter == "All" ? _flaggedMessages : _flaggedMessages.Where(m => m.Label == _filter);

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitAsync();
        if (!AuthState.IsAuthenticated || !AuthState.IsParentOrTeacher) { Nav.NavigateTo("/login"); return; }
        Hub.OnFlaggedAlert += OnAlert;
        Fcm.OnForegroundMessage += OnFcmToast;
        await Hub.StartAsync(AuthState.CurrentUser!.Token);
        await Hub.JoinParentRoomAsync();
        await Fcm.InitAsync();
        await LoadData();
    }

    async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _stats           = await Api.GetDashboardStatsAsync();
        _flaggedMessages = await Api.GetFlaggedMessagesAsync();
        _loading = false; StateHasChanged();
    }

    void OnAlert(int _, string name, string masked, string label, double score)
    {
        _liveAlerts.Add(new(name, masked, label, DateTime.UtcNow));
        if (_liveAlerts.Count > 20) _liveAlerts.RemoveAt(0);
        if (_stats != null)
        {
            if (label == "Watch") _stats.TotalWatch++;
            else if (label == "Review") _stats.TotalReview++;
            _stats.TotalFlagged = _stats.TotalWatch + _stats.TotalReview;
        }
        InvokeAsync(StateHasChanged);
    }

    void OnFcmToast(string title, string body, string label)
    {
        _fcmToast = $"{title}: {body}";
        InvokeAsync(StateHasChanged);
        Task.Delay(5000).ContinueWith(_ => { _fcmToast = ""; InvokeAsync(StateHasChanged); });
    }

    async Task Logout() { await AuthState.LogoutAsync(); Nav.NavigateTo("/login"); }

    public async ValueTask DisposeAsync()
    {
        Hub.OnFlaggedAlert -= OnAlert;
        Fcm.OnForegroundMessage -= OnFcmToast;
        Fcm.Dispose();
        await Hub.DisposeAsync();
    }
}
