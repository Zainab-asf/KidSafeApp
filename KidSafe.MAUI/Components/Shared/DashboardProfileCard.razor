@* Hero profile card used on all role dashboards (Admin / Teacher / Parent / Child) *@

<div class="dash-profile-card mb-2">
    <div class="dpc-avatar">
        @if (!string.IsNullOrEmpty(AvatarEmoji))
        {
            <text>@AvatarEmoji</text>
        }
        else
        {
            <i class="bi @IconClass" style="color:var(--green)"></i>
        }
    </div>
    <div class="dpc-info">
        <div class="dpc-name">@Name</div>
        <div class="dpc-role">@Role</div>
        @if (!string.IsNullOrEmpty(Meta))
        {
            <div class="dpc-meta">@Meta</div>
        }
    </div>
    @if (Actions != null)
    {
        <div class="dpc-actions">@Actions</div>
    }
</div>

@code {
    [Parameter]                 public string?         AvatarEmoji { get; set; }
    [Parameter]                 public string          IconClass   { get; set; } = "bi-person-circle";
    [Parameter, EditorRequired] public string          Name        { get; set; } = "";
    [Parameter]                 public string          Role        { get; set; } = "";
    [Parameter]                 public string          Meta        { get; set; } = "";
    [Parameter]                 public RenderFragment? Actions     { get; set; }
}
