@* Reusable empty-state placeholder *@

<div class="empty-block">
    <div class="empty-ico">@Icon</div>
    <div class="empty-txt">@Title</div>
    @if (!string.IsNullOrEmpty(Subtitle))
    {
        <div class="empty-sub">@Subtitle</div>
    }
    @if (Action != null)
    {
        <div style="margin-top:1rem">@Action</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string          Icon     { get; set; } = "📭";
    [Parameter, EditorRequired] public string          Title    { get; set; } = "Nothing here";
    [Parameter]                 public string          Subtitle { get; set; } = "";
    [Parameter]                 public RenderFragment? Action   { get; set; }
}
