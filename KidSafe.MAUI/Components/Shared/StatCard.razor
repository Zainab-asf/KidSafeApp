@* Reusable stat card for all dashboards.
   Color: "green" | "gold" | "coral" | "purple" | "blue" *@

<div class="stat-card">
    <div class="stat-icon @Color">@Icon</div>
    <div class="stat-body">
        <div class="stat-val" style="@ValueStyle">@Value</div>
        <div class="stat-label">@Label</div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Icon  { get; set; } = "📊";
    [Parameter, EditorRequired] public string Value { get; set; } = "0";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter]                 public string Color { get; set; } = "green";

    string ValueStyle => Color switch
    {
        "coral"  => "color:var(--danger)",
        "gold"   => "color:var(--warning)",
        "purple" => "color:var(--purple)",
        "blue"   => "color:var(--blue)",
        _        => ""
    };
}
