@using System.ComponentModel
@implements IDisposable
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager
@inherits LayoutComponentBase
@inject KidSafeApp.States.RoleState RoleState
@inject KidSafeApp.States.AccountManager AccountManager
@inject KidSafeApp.States.AuthenticationState AuthState
@inject KidSafeApp.States.AdminSessionState AdminSession
@inject KidSafeApp.Services.ErrorService ErrorSvc

<CascadingValue Name="AuthenticationState" Value="AuthState">

    <div class="page">
        <ErrorAlert />
        <main>
            @if (!IsLandingPage() && !IsAuthRoute())
            {
                <div class="top-row">
                    <div class="navbar-brand">
                        @if (ShouldShowDrawer())
                        {
                            <button class="hamburger-menu" @onclick="ToggleSidebarMenu" aria-label="Toggle menu">
                                <span></span>
                                <span></span>
                                <span></span>
                            </button>
                        }
                        KidSafeApp
                    </div>
                </div>

                @if (ShouldShowDrawer())
                {
                    <Sidebar @ref="sidebarRef" />
                }
            }

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>

</CascadingValue>

@code {
    private Sidebar? sidebarRef;
    private bool _isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Safe initialization of AccountManager
            if (AccountManager != null)
            {
                await AccountManager.InitializeAsync();
            }
            _isInitialized = true;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"MainLayout initialization error: {ex.Message}");
            ErrorSvc?.ShowError("Application initialization failed. Please refresh the page.", "Startup Error");
        }
    }

    private bool IsLandingPage()
    {
        try
        {
            if (!_isInitialized || NavigationManager is null)
                return true;
                
            return NavigationManager.Uri.EndsWith("/") || NavigationManager.Uri.Contains("/index");
        }
        catch
        {
            return true;
        }
    }

    private bool ShouldShowDrawer()
    {
        try
        {
            if (RoleState is null || AuthState is null || AdminSession is null)
                return false;

            var isRoleDrawer = RoleState.CurrentRole != KidSafeApp.States.AppRole.None;
            var isAdminDrawer = AdminSession.IsAdmin && string.Equals(AuthState.User?.Role, "Admin", StringComparison.OrdinalIgnoreCase);
            return isRoleDrawer || isAdminDrawer;
        }
        catch
        {
            return false;
        }
    }

    private bool IsAdminRoute()
    {
        try
        {
            if (!_isInitialized || NavigationManager is null)
                return false;

            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            return relativePath.StartsWith("admin", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }

    private bool IsAuthRoute()
    {
        try
        {
            if (!_isInitialized || NavigationManager is null)
                return false;

            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');
            return relativePath.Equals("login", StringComparison.OrdinalIgnoreCase)
                || relativePath.StartsWith("login/", StringComparison.OrdinalIgnoreCase)
                || relativePath.Equals("register", StringComparison.OrdinalIgnoreCase)
                || relativePath.Equals("auth", StringComparison.OrdinalIgnoreCase)
                || relativePath.Equals("unauthorized", StringComparison.OrdinalIgnoreCase)
                || relativePath.Equals("admin-login", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }

    private void ToggleSidebarMenu()
    {
        sidebarRef?.ToggleSidebar();
    }

    void IDisposable.Dispose()
    {
        // Cleanup if needed
    }
}
