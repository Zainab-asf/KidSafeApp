@inject KidSafeApp.States.RoleState RoleState

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">KidSafeApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (RoleState.IsRoleLoaded)
        {
            @switch (RoleState.CurrentRole)
            {
                case KidSafeApp.States.AppRole.Child:
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="child/dashboard">
                            <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Child Dashboard
                        </NavLink>
                    </div>
                    break;
                case KidSafeApp.States.AppRole.Parent:
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="parent/dashboard">
                            <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Parent Dashboard
                        </NavLink>
                    </div>
                    break;
                case KidSafeApp.States.AppRole.Teacher:
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="teacher/dashboard">
                            <span class="bi bi-mortarboard-fill-nav-menu" aria-hidden="true"></span> Teacher Dashboard
                        </NavLink>
                    </div>
                    break;
            }
        }
    </nav>
</div>
