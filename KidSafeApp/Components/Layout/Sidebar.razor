<div class="sidebar-backdrop @(isOpen ? "visible" : "")" @onclick="ToggleSidebar"></div>

@code {
    private bool isOpen = false;

    public void ToggleSidebar()
    {
        try
        {
            isOpen = !isOpen;
            _ = InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling sidebar: {ex.Message}");
        }
    }

    public void CloseSidebar()
    {
        try
        {
            isOpen = false;
            _ = InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error closing sidebar: {ex.Message}");
        }
    }

    private void HandleNavClick()
    {
        try
        {
            CloseSidebar();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in nav click: {ex.Message}");
        }
    }

    private async Task HandleLogout()
    {
        try
        {
            AdminSession.SignOut();
            AuthState.UnLoadState();
            await JsRuntime.InvokeVoidAsync("window.removeFromStorage", KidSafeApp.StateManagement.AuthenticationState.AuthStoreKey);
            RoleState.Reset();
            CloseSidebar();
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during logout: {ex.Message}");
        }
    }

    private string GetUserName()
    {
        if (AuthState?.User is null) return "Guest";
        var name = AuthState.User.Name ?? "User";
        return name.Length > 18 ? name[..18] + "…" : name;
    }

    private string GetUserRole()
    {
        return AuthState?.User?.Role ?? RoleState?.CurrentRole.ToString() ?? "User";
    }

    private string GetUserInitial()
    {
        var name = AuthState?.User?.Name;
        return string.IsNullOrWhiteSpace(name) ? "U" : name[..1].ToUpper();
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await ValueTask.CompletedTask;
    }
}
