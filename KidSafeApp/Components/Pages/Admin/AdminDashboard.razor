    private List<AdminAlertItem> BuildAlerts()
    {
        var alerts = new List<AdminAlertItem>();

        alerts.AddRange(_users.Where(u => !u.IsApproved && u.IsActive).Take(5).Select(u => new AdminAlertItem
        {
            Title = u.Name,
            Description = "Pending approval request",
            Severity = "Warning"
        }));

        alerts.AddRange(_users.Where(u => !u.IsActive).Take(3).Select(u => new AdminAlertItem
        {
            Title = u.Name,
            Description = "User inactive / blocked",
            Severity = "Blocked"
        }));

        if (alerts.Count == 0)
        {
            alerts.Add(new AdminAlertItem { Title = "All clear", Description = "No active issues detected.", Severity = "Safe" });
        }

        return alerts;
    }

