@page "/admin"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JsRuntime
@inject KidSafeApp.States.AdminSessionState AdminSession
@inject KidSafeApp.States.AuthenticationState AuthState
@using System.Text.Json

<PageTitle>Admin Dashboard</PageTitle>

@if (!AuthState.IsAuthenticated || !string.Equals(AuthState.User?.Role, "Admin", StringComparison.OrdinalIgnoreCase) || !AdminSession.IsAdmin)
{
    <div class="container py-5" style="max-width: 720px;">
        <div class="alert alert-warning mb-3">
            Admin access required.
        </div>
        <button class="btn btn-primary" @onclick="GoToAdminLogin">Go to Admin Login</button>
    </div>
    return;
}

<div class="container-fluid py-3">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-0">Admin Dashboard</h1>
            <div class="text-muted">Create users, manage classes, and control access.</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="Reload">Refresh</button>
            <button class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h6 mb-3">1) Create User Account</h2>
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="_newUser.Name" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label">Username</label>
                    <input class="form-control" @bind="_newUser.Username" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label">Password</label>
                    <input class="form-control" @bind="_newUser.Password" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label">Role</label>
                    <select class="form-select" @bind="_newUser.Role">
                        <option value="Child">Child</option>
                        <option value="Parent">Parent</option>
                        <option value="Teacher">Teacher</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
                <div class="col-12 col-md-3 d-grid">
                    <button class="btn btn-primary" @onclick="CreateUser">Create User</button>
                </div>
            </div>

            <hr class="my-3" />

            <h2 class="h6 mb-3">2) Review Existing Users</h2>

            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label">Search</label>
                    <input class="form-control" placeholder="Search by name or username"
                           @bind="_search" @bind:event="oninput" />
                </div>
                <div class="col-12 col-md-5">
                    <label class="form-label">Filter</label>
                    <select class="form-select" @bind="_filter">
                        <option value="all">All users</option>
                        <option value="pending">Pending approvals</option>
                        <option value="approved">Approved</option>
                        <option value="disabled">Disabled</option>
                    </select>
                </div>
                <div class="col-12 col-md-2 d-grid">
                    <button class="btn btn-outline-primary" @onclick="ClearFilters">Clear</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h6">3) Classrooms</h2>
            <div class="small text-muted mb-2">Create classes, assign students, assign teachers, and assign published courses.</div>
            <div class="row g-2 align-items-end mb-3">
                <div class="col-12 col-md-4"><label class="form-label">Class Name</label><input class="form-control" @bind="_newClassRoom.Name" /></div>
                <div class="col-12 col-md-3"><label class="form-label">Grade</label><input class="form-control" @bind="_newClassRoom.Grade" /></div>
                <div class="col-12 col-md-3"><label class="form-label">Section</label><input class="form-control" @bind="_newClassRoom.Section" /></div>
                <div class="col-12 col-md-2 d-grid"><button class="btn btn-outline-primary" @onclick="CreateClassRoom">Create Class</button></div>
            </div>

            @if (_classRoomDetails.Count == 0)
            {
                <div class="text-muted">No classrooms yet.</div>
            }
            else
            {
                <div class="row g-2">
                    @foreach (var room in _classRoomDetails)
                    {
                        <div class="col-12 col-lg-6">
                            <div class="border rounded p-2">
                                <div class="fw-semibold">@room.Name (@room.Grade-@room.Section)</div>
                                <div class="small text-muted mb-2">Students: @room.Students.Count</div>
                                <div class="small mb-2">Teacher: @(string.IsNullOrWhiteSpace(room.TeacherName) ? "Not assigned" : room.TeacherName)</div>

                                @if (room.Students.Count > 0)
                                {
                                    <details class="mb-2">
                                        <summary class="small">View students</summary>
                                        <ul class="mb-2 mt-1">
                                            @foreach (var student in room.Students)
                                            {
                                                <li class="d-flex justify-content-between align-items-center gap-2">
                                                    <span>@student.Name (@student.Username)</span>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStudent(room.Id, student.Id)">Remove</button>
                                                </li>
                                            }
                                        </ul>
                                    </details>
                                }
                                <div class="d-flex gap-2">
                                    <select class="form-select form-select-sm" @bind="_selectedStudentByClass[room.Id]">
                                        <option value="0">Select student</option>
                                        @foreach (var s in _users.Where(u => u.Role == "Child"))
                                        {
                                            <option value="@s.Id">@s.Name (@s.Username)</option>
                                        }
                                    </select>
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => AssignStudent(room.Id)">Assign</button>
                                </div>

                                <div class="d-flex gap-2 mt-2">
                                    <select class="form-select form-select-sm" @bind="_selectedTeacherByClass[room.Id]">
                                        <option value="0">Select teacher</option>
                                        @foreach (var t in _teachers)
                                        {
                                            <option value="@t.Id">@t.Name (@t.Username)</option>
                                        }
                                    </select>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => AssignTeacher(room.Id)">Assign Teacher</button>
                                </div>

                                <div class="d-flex gap-2 mt-2">
                                    <select class="form-select form-select-sm" @bind="_selectedCourseByClass[room.Id]">
                                        <option value="0">Select published course</option>
                                        @foreach (var c in _courses.Where(c => c.IsPublished))
                                        {
                                            <option value="@c.Id">@c.Title</option>
                                        }
                                    </select>
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => AssignCourseToClass(room.Id)">Assign Course</button>
                                </div>

                                @if (room.Courses.Count > 0)
                                {
                                    <div class="small text-muted mt-2">Class courses:</div>
                                    <ul class="mb-0 small">
                                        @foreach (var course in room.Courses)
                                        {
                                            <li>@course.Title</li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h6">4) Students Overview</h2>
            <div class="small text-muted mb-2">All registered students and the classes they are currently assigned to.</div>

            @if (_students.Count == 0)
            {
                <div class="text-muted">No students found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Username</th>
                                <th>Assigned Classes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in _students)
                            {
                                <tr>
                                    <td>@student.Name</td>
                                    <td>@student.Username</td>
                                    <td>
                                        @if (student.ClassRooms.Count == 0)
                                        {
                                            <span class="text-muted">Not assigned</span>
                                        }
                                        else
                                        {
                                            @string.Join(", ", student.ClassRooms)
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="alert alert-success">@_success</div>
    }

    @if (_loading)
    {
        <div class="text-muted">Loading...</div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Name</th>
                                <th>Username</th>
                                <th>Role</th>
                                <th>Approved</th>
                                <th>Active</th>
                                <th>Added</th>
                                <th style="width: 160px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in FilteredUsers)
                            {
                                <tr>
                                    <td>@u.Id</td>
                                    <td>@u.Name</td>
                                    <td>@u.Username</td>
                                    <td>
                                        <select class="form-select form-select-sm" style="min-width:140px"
                                                @onchange="(e) => SetRole(u, e.Value?.ToString())">
                                            <option value="Child" selected="@(u.Role == "Child")">Child</option>
                                            <option value="Parent" selected="@(u.Role == "Parent")">Parent</option>
                                            <option value="Teacher" selected="@(u.Role == "Teacher")">Teacher</option>
                                            <option value="Admin" selected="@(u.Role == "Admin")">Admin</option>
                                        </select>
                                    </td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@u.IsApproved"
                                               @onchange="(e) => SetApproved(u, (bool)(e.Value ?? false))" />
                                    </td>
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@u.IsActive"
                                               @onchange="(e) => SetActive(u, (bool)(e.Value ?? false))" />
                                    </td>
                                    <td class="text-muted">@u.AddedOn.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" @onclick="() => Save(u)">Save</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private string? _success;
    private List<AdminUserDto> _users = new();
    private List<AdminStudentOverviewDto> _students = new();
    private List<AdminClassRoomDetailDto> _classRoomDetails = new();
    private List<AdminUserDto> _teachers = new();
    private List<AdminCourseLiteDto> _courses = new();
    private int _studentFilterClassId;
    private AdminStudentProfileDto? _selectedStudentProfile;
    private readonly Dictionary<int, int> _selectedStudentByClass = new();
    private readonly Dictionary<int, int> _selectedTeacherByClass = new();
    private readonly Dictionary<int, int> _selectedCourseByClass = new();
    private AdminCreateUserDto _newUser = new() { Role = "Child", IsApproved = true, IsActive = true };
    private AdminCreateClassRoomDto _newClassRoom = new();
    private string _search = string.Empty;
    private string _filter = "pending";

    private IEnumerable<AdminUserDto> FilteredUsers
    {
        get
        {
            IEnumerable<AdminUserDto> query = _users;

            query = _filter switch
            {
                "pending" => query.Where(u => !u.IsApproved && u.IsActive),
                "approved" => query.Where(u => u.IsApproved && u.IsActive),
                "disabled" => query.Where(u => !u.IsActive),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim();
                query = query.Where(u =>
                    u.Name.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    u.Username.Contains(s, StringComparison.OrdinalIgnoreCase));
            }

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private void ClearFilters()
    {
        _search = string.Empty;
        _filter = "pending";
    }

    private void GoToAdminLogin() => Nav.NavigateTo("/admin-login");

    private async Task HandleLogout()
    {
        AdminSession.SignOut();
        AuthState.UnLoadState();
        await JsRuntime.InvokeVoidAsync("window.removeFromStorage", AuthenticationState.AuthStoreKey);
        Nav.NavigateTo("/", replace: true);
    }

    private async Task Reload()
    {
        _loading = true;
        _error = null;
        _success = null;
        try
        {
            var users = await Http.GetFromJsonAsync<List<AdminUserDto>>("api/admin/users");
            _users = users ?? new();
            var studentsUrl = _studentFilterClassId > 0
                ? $"api/admin/students?classRoomId={_studentFilterClassId}"
                : "api/admin/students";
            _students = await Http.GetFromJsonAsync<List<AdminStudentOverviewDto>>(studentsUrl) ?? new();
            _classRoomDetails = await Http.GetFromJsonAsync<List<AdminClassRoomDetailDto>>("api/admin/classrooms/details") ?? new();
            _teachers = await Http.GetFromJsonAsync<List<AdminUserDto>>("api/admin/teachers") ?? new();
            _courses = await Http.GetFromJsonAsync<List<AdminCourseLiteDto>>("api/admin/courses") ?? new();

            foreach (var room in _classRoomDetails)
            {
                if (!_selectedStudentByClass.ContainsKey(room.Id)) _selectedStudentByClass[room.Id] = 0;
                if (!_selectedTeacherByClass.ContainsKey(room.Id)) _selectedTeacherByClass[room.Id] = 0;
                if (!_selectedCourseByClass.ContainsKey(room.Id)) _selectedCourseByClass[room.Id] = 0;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetRole(AdminUserDto user, string? role)
    {
        if (string.IsNullOrWhiteSpace(role)) return;
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { Role = role };
        }
    }

    private void SetApproved(AdminUserDto user, bool isApproved)
    {
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { IsApproved = isApproved };
        }
    }

    private void SetActive(AdminUserDto user, bool isActive)
    {
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { IsActive = isActive };
        }
    }

    private async Task Save(AdminUserDto user)
    {
        _error = null;
        _success = null;
        try
        {
            var dto = new AdminUpdateUserDto
            {
                Role = user.Role,
                IsApproved = user.IsApproved,
                IsActive = user.IsActive
            };

            var resp = await Http.PutAsJsonAsync($"api/admin/users/{user.Id}", dto);
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            _success = $"User '{user.Username}' updated successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CreateUser()
    {
        _error = null;
        _success = null;
        try
        {
            if (string.IsNullOrWhiteSpace(_newUser.Name) || string.IsNullOrWhiteSpace(_newUser.Username) || string.IsNullOrWhiteSpace(_newUser.Password))
            {
                _error = "Name, Username and Password are required.";
                return;
            }

            var resp = await Http.PostAsJsonAsync("api/admin/users", _newUser);
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            _newUser = new AdminCreateUserDto { Role = "Child", IsApproved = true, IsActive = true };
            await Reload();
            _success = "User created successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CreateClassRoom()
    {
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/admin/classrooms", _newClassRoom);
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            _newClassRoom = new AdminCreateClassRoomDto();
            await Reload();
            _success = "Class created successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task AssignStudent(int classRoomId)
    {
        _error = null;
        _success = null;
        try
        {
            var studentId = _selectedStudentByClass.GetValueOrDefault(classRoomId, 0);
            if (studentId <= 0)
            {
                _error = "Please select a student.";
                return;
            }

            var resp = await Http.PostAsJsonAsync($"api/admin/classrooms/{classRoomId}/students", new AdminAssignStudentDto { StudentId = studentId });
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            await Reload();
            _success = "Student assigned successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RemoveStudent(int classRoomId, int studentId)
    {
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/admin/classrooms/{classRoomId}/students/{studentId}");
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            await Reload();
            _success = "Student removed from class.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task AssignTeacher(int classRoomId)
    {
        _error = null;
        _success = null;
        try
        {
            var teacherId = _selectedTeacherByClass.GetValueOrDefault(classRoomId, 0);
            if (teacherId <= 0)
            {
                _error = "Please select a teacher.";
                return;
            }

            var resp = await Http.PutAsJsonAsync($"api/admin/classrooms/{classRoomId}/teacher", new AdminAssignTeacherDto { TeacherId = teacherId });
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            await Reload();
            _success = "Teacher assigned to class.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task AssignCourseToClass(int classRoomId)
    {
        _error = null;
        _success = null;
        try
        {
            var courseId = _selectedCourseByClass.GetValueOrDefault(classRoomId, 0);
            if (courseId <= 0)
            {
                _error = "Please select a published course.";
                return;
            }

            var resp = await Http.PostAsJsonAsync($"api/admin/classrooms/{classRoomId}/courses", new AdminAssignCourseToClassDto { CourseId = courseId });
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            await Reload();
            _success = "Course assigned to class.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadStudentProfile(int studentId)
    {
        _error = null;
        try
        {
            _selectedStudentProfile = await Http.GetFromJsonAsync<AdminStudentProfileDto>($"api/admin/students/{studentId}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static async Task<string> ExtractErrorMessageAsync(HttpResponseMessage response)
    {
        var raw = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(raw))
        {
            return $"Request failed ({(int)response.StatusCode}).";
        }

        try
        {
            using var doc = JsonDocument.Parse(raw);
            var root = doc.RootElement;

            if (root.TryGetProperty("errors", out var errors) && errors.ValueKind == JsonValueKind.Object)
            {
                foreach (var property in errors.EnumerateObject())
                {
                    if (property.Value.ValueKind == JsonValueKind.Array && property.Value.GetArrayLength() > 0)
                    {
                        var first = property.Value[0].GetString();
                        if (!string.IsNullOrWhiteSpace(first))
                        {
                            return first;
                        }
                    }
                }
            }

            if (root.TryGetProperty("title", out var title))
            {
                var value = title.GetString();
                if (!string.IsNullOrWhiteSpace(value))
                {
                    return value;
                }
            }

            if (root.TryGetProperty("message", out var message))
            {
                var value = message.GetString();
                if (!string.IsNullOrWhiteSpace(value))
                {
                    return value;
                }
            }
        }
        catch
        {
        }

        return raw;
    }
}
