    private string GetChildRiskLevel(int childId)
    {
        if (TryGetDemoChildProfile(childId, out var demoProfile))
        {
            return demoProfile.RiskLevel;
        }

        var seed = Math.Abs(childId.GetHashCode()) % 5;
        return seed switch
        {
            0 => "Blocked",
            1 or 2 => "Warning",
            _ => "Safe"
        };
    }

