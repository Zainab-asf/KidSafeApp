    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(AuthState.Token))
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", AuthState.Token);
        }

        InitializeActiveSectionFromRoute();
        Nav.LocationChanged += OnLocationChanged;
        await Reload();
        await LoadAdminSettingsAsync();
    }

    protected override void OnParametersSet()
    {
        InitializeActiveSectionFromRoute();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InitializeActiveSectionFromRoute();
        await InvokeAsync(StateHasChanged);
    }

    private void InitializeActiveSectionFromRoute()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Trim('/').ToLowerInvariant();
        var segment = path.StartsWith("admin/") ? path["admin/".Length..] : "dashboard";

        _activeSection = segment switch
        {
            "child-chat" => "child-chat",
            "parent-portal" => "parent-portal",
            "teacher-module" => "teacher-module",
            "add-user" => "add-user",
            "notifications" => "notifications",
            "settings" => "settings",
            "help" => "help",
            _ => "dashboard"
        };
    }

    private void InitializeSelectedItems()
    {
        if (_selectedStudentId == 0)
        {
            _selectedStudentId = ChildChatSource.FirstOrDefault()?.Id ?? 0;
        }

        if (_selectedParentId == 0)
        {
            _selectedParentId = ParentPortalRows.FirstOrDefault()?.Id ?? 0;
        }

        if (_selectedTeacherId == 0)
        {
            _selectedTeacherId = FilteredTeachers.FirstOrDefault()?.Id ?? 0;
        }
    }

    private bool MatchesSearch(AdminUserDto user)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var s = _search.Trim();
        return user.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || user.Username.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private async Task Reload()
    {
        _loading = true;
        _error = null;
        try
        {
            _users = await Http.GetFromJsonAsync<List<AdminUserDto>>("api/admin/users") ?? new();
            _students = await Http.GetFromJsonAsync<List<AdminStudentOverviewDto>>("api/admin/students") ?? new();
            _classRoomDetails = await Http.GetFromJsonAsync<List<AdminClassRoomDetailDto>>("api/admin/classrooms/details") ?? new();
            _courses = await Http.GetFromJsonAsync<List<AdminCourseLiteDto>>("api/admin/courses") ?? new();
            _teachers = await Http.GetFromJsonAsync<List<AdminUserDto>>("api/admin/teachers") ?? new();

            InitializeSelectedItems();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadAndNotify()
    {
        await Reload();
        if (string.IsNullOrWhiteSpace(_error))
        {
            _success = "Data refreshed.";
        }
    }

