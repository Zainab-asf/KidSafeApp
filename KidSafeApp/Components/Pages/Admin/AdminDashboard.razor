    private async Task SaveAdminSettingsAsync(string successMessage)
    {
        _error = null;
        _savingAdminSettings = true;

        try
        {
            if (_adminSettings.ScreenTimeLimit <= 0)
            {
                _adminSettings.ScreenTimeLimit = 180;
            }

            var response = await Http.PutAsJsonAsync("api/settings?role=Admin", _adminSettings);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            var updated = await response.Content.ReadFromJsonAsync<UserSettingsDto>();
            if (updated is not null)
            {
                ApplyAdminSettings(updated);
            }

            _success = successMessage;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingAdminSettings = false;
        }
    }

    private void ApplyAdminSettings(UserSettingsDto dto)
    {
        _adminSettings.IsProfilePublic = dto.IsProfilePublic;
        _adminSettings.AllowMessageRequests = dto.AllowMessageRequests;
        _adminSettings.EmailNotificationsEnabled = dto.EmailNotificationsEnabled;
        _adminSettings.PushNotificationsEnabled = dto.PushNotificationsEnabled;
        _adminSettings.AchievementNotifications = dto.AchievementNotifications;
        _adminSettings.MessageNotifications = dto.MessageNotifications;
        _adminSettings.CourseReminderNotifications = dto.CourseReminderNotifications;
        _adminSettings.ThemePreference = string.IsNullOrWhiteSpace(dto.ThemePreference) ? "light" : dto.ThemePreference;
        _adminSettings.LanguagePreference = string.IsNullOrWhiteSpace(dto.LanguagePreference) ? "en" : dto.LanguagePreference;
        _adminSettings.CompactMode = dto.CompactMode;
        _adminSettings.StrictContentFilter = dto.StrictContentFilter;
        _adminSettings.BlockAdultContent = dto.BlockAdultContent;
        _adminSettings.ParentEmail = dto.ParentEmail;
        _adminSettings.RequireParentApprovalForMessages = dto.RequireParentApprovalForMessages;
        _adminSettings.ScreenTimeLimit = dto.ScreenTimeLimit <= 0 ? 180 : dto.ScreenTimeLimit;
        _adminSettings.Bio = dto.Bio;
        _adminSettings.AvatarUrl = dto.AvatarUrl;
    }

