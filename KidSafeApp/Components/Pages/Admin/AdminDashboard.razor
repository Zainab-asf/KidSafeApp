@code {
    private bool _loading = true;
    private string? _error;
    private string? _success;
    private string _activeTab = "users";
    private bool _showCreateUserForm = false;
    private List<AdminUserDto> _users = new();
    private List<AdminStudentOverviewDto> _students = new();
    private List<AdminClassRoomDetailDto> _classRoomDetails = new();
    private List<AdminUserDto> _teachers = new();
    private readonly Dictionary<int, int> _selectedStudentByClass = new();
    private readonly Dictionary<int, int> _selectedTeacherByClass = new();
    private AdminCreateUserDto _newUser = new() { Role = "Child", IsApproved = true, IsActive = true };
    private AdminCreateClassRoomDto _newClassRoom = new();
    private string _search = string.Empty;
    private string _filter = "all";

    private int PendingApprovalsCount => _users.Count(u => !u.IsApproved && u.IsActive);

    private IEnumerable<AdminUserDto> FilteredUsers
    {
        get
        {
            IEnumerable<AdminUserDto> query = _users;

            query = _filter switch
            {
                "pending" => query.Where(u => !u.IsApproved && u.IsActive),
                "approved" => query.Where(u => u.IsApproved && u.IsActive),
                "disabled" => query.Where(u => !u.IsActive),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim();
                query = query.Where(u =>
                    u.Name.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    u.Username.Contains(s, StringComparison.OrdinalIgnoreCase));
            }

            return query;
        }
    }

    private async Task ConfirmDeleteUser(AdminUserDto user)
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", $"Delete user '{user.Username}'? This cannot be undone.");
        if (!confirmed)
        {
            return;
        }

        await DeleteUser(user);
    }

    private string GetRoleColor(string role) => role switch
    {
        "Child" => "#C0E1D2",
        "Parent" => "#E5EEE4",
        "Teacher" => "#C0E1D2",
        "Admin" => "#C0E1D2",
        _ => "#DC9B9B"
    };

    protected override async Task OnInitializedAsync()
    {
        InitializeActiveSectionFromRoute();
        Nav.LocationChanged += OnLocationChanged;
        await Reload();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InitializeActiveSectionFromRoute();
        await InvokeAsync(StateHasChanged);
    }

    protected override void OnParametersSet()
    {
        InitializeActiveSectionFromRoute();
    }

    private void SetActiveTab(string tab)
    {
        var route = tab switch
        {
            "users" => "/admin/users",
            "classes" => "/admin/classes",
            "approvals" => "/admin/approvals",
            _ => "/admin/dashboard"
        };

        Nav.NavigateTo(route);
    }

    private void InitializeActiveSectionFromRoute()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).Trim('/').ToLowerInvariant();
        var segment = relativePath.StartsWith("admin/")
            ? relativePath["admin/".Length..]
            : relativePath == "admin" ? "dashboard" : relativePath;

        if (string.IsNullOrWhiteSpace(segment))
        {
            segment = "dashboard";
        }

        _activeTab = segment switch
        {
            "classes" or "students" or "teachers" or "courses" => "classes",
            "approvals" or "activity" or "activity-logs" => "approvals",
            _ => "users"
        };
    }

    private void ClearFilters()
    {
        _search = string.Empty;
        _filter = "all";
    }

    private void GoToAdminLogin() => Nav.NavigateTo("/admin-login");

    private async Task HandleLogout()
    {
        AdminSession.SignOut();
        AuthState.UnLoadState();
        await JsRuntime.InvokeVoidAsync("window.removeFromStorage", AuthenticationState.AuthStoreKey);
        Nav.NavigateTo("/", replace: true);
    }

    private async Task Reload()
    {
        _loading = true;
        _error = null;
        _success = null;
        try
        {
            var users = await Http.GetFromJsonAsync<List<AdminUserDto>>("api/admin/users");
            _users = users ?? new();
            _students = await Http.GetFromJsonAsync<List<AdminStudentOverviewDto>>("api/admin/students") ?? new();
            _classRoomDetails = await Http.GetFromJsonAsync<List<AdminClassRoomDetailDto>>("api/admin/classrooms/details") ?? new();
            _teachers = await Http.GetFromJsonAsync<List<AdminUserDto>>("api/admin/teachers") ?? new();

            foreach (var room in _classRoomDetails)
            {
                if (!_selectedStudentByClass.ContainsKey(room.Id)) _selectedStudentByClass[room.Id] = 0;
                if (!_selectedTeacherByClass.ContainsKey(room.Id)) _selectedTeacherByClass[room.Id] = 0;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConfirmDeleteClassRoom(int classRoomId)
    {
        var room = _classRoomDetails.FirstOrDefault(x => x.Id == classRoomId);
        var roomName = room?.Name ?? $"ID {classRoomId}";
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", $"Delete class '{roomName}'? This cannot be undone.");
        if (!confirmed)
        {
            return;
        }

        await DeleteClassRoom(classRoomId);
    }

    private void SetRole(AdminUserDto user, string? role)
    {
        if (string.IsNullOrWhiteSpace(role)) return;
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { Role = role };
        }
    }

    private void SetApproved(AdminUserDto user, bool isApproved)
    {
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { IsApproved = isApproved };
        }
    }

    private void SetActive(AdminUserDto user, bool isActive)
    {
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { IsActive = isActive };
        }
    }

    private async Task ApproveUser(AdminUserDto user)
    {
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { IsApproved = true };
            await Save(_users[idx]);
        }
    }

    private async Task DenyUser(AdminUserDto user)
    {
        var idx = _users.FindIndex(x => x.Id == user.Id);
        if (idx >= 0)
        {
            _users[idx] = user with { IsActive = false };
            await Save(_users[idx]);
        }
    }

    private async Task Save(AdminUserDto user)
    {
        _error = null;
        _success = null;
        try
        {
            var dto = new AdminUpdateUserDto
            {
                Role = user.Role,
                IsApproved = user.IsApproved,
                IsActive = user.IsActive
            };

            var resp = await Http.PutAsJsonAsync($"api/admin/users/{user.Id}", dto);
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            _success = $"User '{user.Username}' updated successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task DeleteUser(AdminUserDto user)
    {
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/admin/users/{user.Id}");
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            await Reload();
            _success = $"User '{user.Username}' deleted successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CreateUser()
    {
        _error = null;
        _success = null;
        try
        {
            if (string.IsNullOrWhiteSpace(_newUser.Name) || string.IsNullOrWhiteSpace(_newUser.Username) || string.IsNullOrWhiteSpace(_newUser.Password))
            {
                _error = "Name, Username and Password are required.";
                return;
            }

            var resp = await Http.PostAsJsonAsync("api/admin/users", _newUser);
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            _newUser = new AdminCreateUserDto { Role = "Child", IsApproved = true, IsActive = true };
            _showCreateUserForm = false;
            await Reload();
            _success = "User created successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CreateClassRoom()
    {
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/admin/classrooms", _newClassRoom);
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
            }

            _newClassRoom = new AdminCreateClassRoomDto();
            await Reload();
            _success = "Class created successfully.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task DeleteClassRoom(int classRoomId)
    {
        _error = null;
        _success = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/admin/classrooms/{classRoomId}");
            if (!resp.IsSuccessStatusCode)
            {
                _error = await ExtractErrorMessageAsync(resp);
                return;
