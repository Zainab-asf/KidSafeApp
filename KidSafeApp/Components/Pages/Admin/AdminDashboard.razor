    private async Task AddChildAsync()
    {
        if (_creatingChild) return;

        if (string.IsNullOrWhiteSpace(_newChildName)
            || string.IsNullOrWhiteSpace(_newChildRegNo)
            || string.IsNullOrWhiteSpace(_newChildPassword)
            || _newChildClassRoomId <= 0)
        {
            _error = "Child name, registration no, password, and class are required.";
            return;
        }

        _creatingChild = true;
        _error = null;

        try
        {
            var dto = new AdminCreateUserDto
            {
                Name = _newChildName.Trim(),
                Username = _newChildRegNo.Trim(),
                Password = _newChildPassword,
                Role = "Child",
                IsApproved = true,
                IsActive = true,
                RegistrationNo = _newChildRegNo.Trim(),
                ClassRoomId = _newChildClassRoomId,
                CourseId = _newChildCourseId
            };

            var response = await Http.PostAsJsonAsync("api/admin/users", dto);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            _newChildName = string.Empty;
            _newChildRegNo = string.Empty;
            _newChildPassword = string.Empty;
            _newChildClassRoomId = 0;
            _newChildCourseId = 0;

            await Reload();
            _success = "Child account added successfully. Child can now log in with registration no and password.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _creatingChild = false;
        }
    }

