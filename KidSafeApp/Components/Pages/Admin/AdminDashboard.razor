    private async Task SubmitSupportTicketAsync()
    {
        if (_submittingSupport) return;

        if (string.IsNullOrWhiteSpace(_supportSubject) || string.IsNullOrWhiteSpace(_supportMessage))
        {
            _error = "Please provide both subject and description for the support ticket.";
            return;
        }

        _error = null;
        _submittingSupport = true;

        try
        {
            await Task.Delay(250);

            _adminSupportTickets.Insert(0, new AdminSupportTicket
            {
                Subject = _supportSubject.Trim(),
                Category = _supportCategory,
                Priority = _supportPriority,
                CreatedAtText = "Just now"
            });

            _supportSubject = string.Empty;
            _supportMessage = string.Empty;
            _supportCategory = "General";
            _supportPriority = "Medium";

            _success = "Support ticket submitted successfully.";
        }
        finally
        {
            _submittingSupport = false;
        }
    }

