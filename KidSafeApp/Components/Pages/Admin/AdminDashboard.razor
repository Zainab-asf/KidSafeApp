    private string GetInitials(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "NA";
        var words = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (words.Length == 1) return words[0][..Math.Min(2, words[0].Length)].ToUpperInvariant();
        return string.Concat(words[0][0], words[^1][0]).ToUpperInvariant();
    }

    private List<DemoChatLine> GetDemoChat(int studentId)
