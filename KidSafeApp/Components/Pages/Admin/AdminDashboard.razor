    private async Task LoadAdminSettingsAsync()
    {
        try
        {
            var dto = await Http.GetFromJsonAsync<UserSettingsDto>("api/settings?role=Admin");
            if (dto is not null)
            {
                ApplyAdminSettings(dto);
            }

            _settingsLanguage = GetLanguageName(_adminSettings.LanguagePreference);

            var localJson = await JsRuntime.InvokeAsync<string?>("getFromStorage", AdminGeneralSettingsStoreKey);
            if (!string.IsNullOrWhiteSpace(localJson))
            {
                var localState = JsonSerializer.Deserialize<AdminGeneralLocalState>(localJson);
                if (localState is not null)
                {
                    _settingsInstitutionName = localState.InstitutionName;
                    _settingsAdminEmail = localState.AdminEmail;
                    _settingsTimezone = localState.Timezone;
                    _settingsInstitutionAddress = localState.InstitutionAddress;
                }
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SaveAdminGeneralSettingsAsync()
    {
        _adminSettings.LanguagePreference = GetLanguageCode(_settingsLanguage);

        await SaveAdminSettingsAsync("General settings saved.");

        if (string.IsNullOrWhiteSpace(_error))
        {
            var localState = new AdminGeneralLocalState
            {
                InstitutionName = _settingsInstitutionName,
                AdminEmail = _settingsAdminEmail,
                Timezone = _settingsTimezone,
                InstitutionAddress = _settingsInstitutionAddress
            };

            await JsRuntime.InvokeVoidAsync("setToStorage", AdminGeneralSettingsStoreKey, JsonSerializer.Serialize(localState));
        }
    }

