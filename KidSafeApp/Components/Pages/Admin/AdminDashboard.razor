        return cls is null ? "Grade -" : $"Grade {cls.Grade}";
    }

    private string GetLinkedChildForParent(int parentId)
    {
        var children = GetLinkedChildrenForParent();

        if (children.Count == 0) return "-";
        var idx = Math.Abs(parentId.GetHashCode()) % children.Count;
        return children[idx].Name;
    }

    private string GetLinkedChildGradeLabel(int parentId)
    {
        var childName = GetLinkedChildForParent(parentId);
        var classRoom = _classRoomDetails.FirstOrDefault(c => c.Students.Any(s => s.Name == childName));
        return classRoom is null ? "Grade -" : $"Grade {classRoom.Grade}";
