    private List<string> GetTeacherClassLabels(int teacherId)
    {
        var labels = _classRoomDetails
            .Where(c => c.TeacherId == teacherId)
            .Select(c => $"Grade {c.Grade}{c.Section}")
            .ToList();

        if (labels.Count == 0)
        {
            labels.Add($"Grade {(Math.Abs(teacherId) % 6) + 5}A");
            labels.Add($"Grade {(Math.Abs(teacherId) % 6) + 6}B");
        }

        return labels;
    }

    private int GetTeacherStudentCount(int teacherId)
    {
        var fromAssignedClasses = _classRoomDetails
            .Where(c => c.TeacherId == teacherId)
            .Sum(c => c.Students.Count);

        return fromAssignedClasses > 0 ? fromAssignedClasses : 55 + Math.Abs((teacherId * 7) % 60);
    }

