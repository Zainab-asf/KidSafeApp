    private string GetChatTimeText(DemoChatLine line)
    {
        var text = line.Text;
        if (text.Contains("Hey man", StringComparison.OrdinalIgnoreCase)) return "10:02 AM";
        if (text.Contains("Nothing much", StringComparison.OrdinalIgnoreCase)) return "10:03 AM";
        if (text.Contains("loser", StringComparison.OrdinalIgnoreCase)) return "10:05 AM";
        if (text.Contains("not cool", StringComparison.OrdinalIgnoreCase)) return "10:06 AM";
        if (text.Contains("pathetic", StringComparison.OrdinalIgnoreCase)) return "10:07 AM";
        return "10:08 AM";
    }

    private string GetTeacherSubject(int teacherId)
