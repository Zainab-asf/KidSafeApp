@page "/admin-login"
@inject NavigationManager Nav
@inject HttpClient HttpClient
@inject IJSRuntime JsRuntime
@inject KidSafeApp.StateManagement.AdminSessionState AdminSession
@inject KidSafeApp.StateManagement.RoleState RoleState

<PageTitle>Admin Login</PageTitle>

<AuthCardShell>
    <HeaderContent>
        <h1 class="h5 mb-0">Admin Login 🔐</h1>
    </HeaderContent>
    <BodyContent>
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        <div class="mb-3">
            <label class="form-label">Username</label>
            <input class="form-control" @bind="_username" />
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" @bind="_password" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="SignIn" disabled="@_isBusy">
                @if (_isBusy)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                Sign in
            </button>
            <button class="btn btn-outline-secondary" @onclick="GoBack" disabled="@_isBusy">Back</button>
        </div>
    </BodyContent>
    <FooterContent>
        Sign in with an Admin account created from the admin user list.
    </FooterContent>
</AuthCardShell>

@code {
    protected override void OnInitialized()
    {
        _error = null;
        _isBusy = true;
        try
        {
            if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
            {
                _error = "Username and password are required.";
                return;
            }

            var loginDto = new LoginDto
            {
                Username = _username,
                Password = _password
            };

            var response = await HttpClient.PostAsJsonAsync("api/account/login", loginDto);
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            var content = await response.Content.ReadAsStringAsync();
            var authResult = JsonHelper.Deserialize<AuthResponseDto>(content);
            if (authResult is null)
            {
                _error = "Unable to parse login response.";
                return;
            }

            if (!string.Equals(authResult.User.Role, "Admin", StringComparison.OrdinalIgnoreCase))
            {
                _error = "This account is not an admin account.";
                return;
            }

            if (AuthenticationState is null)
            {
                _error = "Authentication state is not available.";
                return;
            }

            var serialized = JsonHelper.Serialize(authResult);
            await JsRuntime.InvokeVoidAsync("window.setToStorage", AuthenticationState.AuthStoreKey, serialized);
            AuthenticationState.LoadState(authResult);

            AdminSession.SignInAdmin();
            RoleState.Reset();
            Nav.NavigateTo("/admin", replace: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }
}


