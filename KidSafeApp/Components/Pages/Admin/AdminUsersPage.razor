@page "/admin/users"
@using KidSafeApp.Services
@using KidSafeApp.Shared.DTOs.Admin
@using KidSafeApp.StateManagement
@inject AdminUsersApiClient AdminUsersApi
@inject NavigationManager Nav

<PageTitle>Admin Users</PageTitle>

<div class="container py-4">
    <h3>User Management</h3>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="alert alert-success">@_success</div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <input class="form-control" placeholder="Search name or username" @bind="_query.Search" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="_query.Role">
                        <option value="">All roles</option>
                        <option>Admin</option><option>Parent</option><option>Teacher</option><option>Child</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="_activeFilter">
                        <option value="">All status</option>
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="_approvedFilter">
                        <option value="">All approvals</option>
                        <option value="true">Approved</option>
                        <option value="false">Pending</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button class="btn btn-primary w-100" @onclick="LoadUsersAsync">Go</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Create User</div>
        <div class="card-body">
            <AdminUserForm Model="_newUser"
                           IsSubmitting="_creating"
                           OnSubmit="CreateUserAsync"
                           ClassRooms="_classRooms"
                           Courses="_courses" />
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between">
            <span>Users</span>
            <span class="text-muted">Total: @_totalCount</span>
        </div>
        <div class="card-body">
            <AdminUserTable Users="_users" />
            <div class="d-flex justify-content-between align-items-center mt-3">
                <button class="btn btn-outline-secondary" disabled="@(_query.PageNumber <= 1)" @onclick="PrevPageAsync">Previous</button>
                <span>Page @_query.PageNumber of @_totalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(_query.PageNumber >= _totalPages)" @onclick="NextPageAsync">Next</button>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "AuthenticationState")]
    public AuthenticationState? AuthenticationState { get; set; }

    private readonly AdminUsersQueryDto _query = new() { PageNumber = 1, PageSize = 10 };
    private AdminCreateUserDto _newUser = new() { Role = "Parent", IsActive = true, IsApproved = true };
    private List<AdminUserDto> _users = new();
    private IReadOnlyList<AdminClassRoomDto> _classRooms = Array.Empty<AdminClassRoomDto>();
    private IReadOnlyList<AdminCourseLiteDto> _courses = Array.Empty<AdminCourseLiteDto>();
    private string? _error;
    private string? _success;
    private string? _activeFilter;
    private string? _approvedFilter;
#pragma warning disable CS0649
    private bool _creating;
#pragma warning restore CS0649
    private int _totalCount;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        if (!string.Equals(AuthenticationState?.User?.Role, "Admin", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/admin-login", replace: true);
            return;
        }

        await LoadUsersAsync();
        await LoadReferenceDataAsync();
    }

    private async Task LoadReferenceDataAsync()
    {
        try
        {
            _classRooms = await AdminUsersApi.GetClassRoomsAsync();
            _courses = await AdminUsersApi.GetCoursesAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            _error = null;
            ApplyFiltersToQuery();
            var page = await AdminUsersApi.GetUsersAsync(_query);
            _users = page.Items.ToList();
            _totalCount = page.TotalCount;
            _totalPages = Math.Max(1, page.TotalPages);
            _query.PageNumber = Math.Min(_query.PageNumber, _totalPages);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void ApplyFiltersToQuery()
    {
        _query.IsActive = TryParseNullableBool(_activeFilter);
        _query.IsApproved = TryParseNullableBool(_approvedFilter);
    }

    private static bool? TryParseNullableBool(string? value)
        => bool.TryParse(value, out var parsed) ? parsed : null;

    private void ResetNewUser()
    {
        _newUser = new AdminCreateUserDto { Role = "Parent", IsActive = true, IsApproved = true };
    }

    private async Task CreateUserAsync()
    {
        try
        {
            _creating = true;
            _error = null;
            _success = null;
            await AdminUsersApi.CreateUserAsync(_newUser);
            _success = "User created successfully.";
            ResetNewUser();
            _query.PageNumber = 1;
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _creating = false;
        }
    }

    private async Task PrevPageAsync()
    {
        if (_query.PageNumber <= 1) return;
        _query.PageNumber--;
        await LoadUsersAsync();
    }

    private async Task NextPageAsync()
    {
        if (_query.PageNumber >= _totalPages) return;
        _query.PageNumber++;
        await LoadUsersAsync();
    }
}


