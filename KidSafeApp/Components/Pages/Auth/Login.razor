@page "/login"
@using KidSafeApp.Helpers
@using KidSafeApp.StateManagement
@inject HttpClient HttpClient
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager
@inject RoleState RoleState
@inject AdminSessionState AdminSession

<PageTitle>Login - KidSafeApp</PageTitle>

<div class="auth-page-wrapper">
    <div class="auth-container">
        <div class="auth-card-wrapper">
            <EditForm Model="LoginModel" OnValidSubmit="LoginAsync">
                <div class="auth-card">
                    <div class="auth-header">
                        <div class="auth-logo">
                            <span class="logo-icon">🛡️</span>
                            <h1 class="auth-title">Welcome Back</h1>
                        </div>
                        <p class="auth-subtitle">Sign in to continue to KidSafe</p>
                    </div>

                    <div class="auth-body">
                        <DataAnnotationsValidator />
                        
                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="error-message">
                                <span class="error-icon">⚠️</span>
                                <span>@errorMessage</span>
                            </div>
                        }

                        <div class="form-group">
                            <label class="form-label" for="username">
                                <span class="label-icon">👤</span>
                                Username
                            </label>
                            <div class="input-wrapper">
                                <InputText id="username" @bind-Value="LoginModel.Username" 
                                    class="form-control" placeholder="Enter your username" />
                            </div>
                            <ValidationMessage For="() => LoginModel.Username" class="validation-message" />
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="password">
                                <span class="label-icon">🔒</span>
                                Password
                            </label>
                            <div class="input-wrapper">
                                <InputText id="password" type="password" @bind-Value="LoginModel.Password" 
                                    class="form-control" placeholder="Enter your password" />
                            </div>
                            <ValidationMessage For="() => LoginModel.Password" class="validation-message" />
                        </div>
                    </div>

                    <div class="auth-footer">
                        <NavLink href="/" class="btn btn-secondary">
                            <span class="btn-icon">←</span>
                            Back
                        </NavLink>

                        @if (_isBusy)
                        {
                            <button class="btn btn-primary btn-loading" type="button" disabled>
                                <span class="spinner"></span>
                                Signing in...
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary">
                                Sign In
                                <span class="btn-icon">→</span>
                            </button>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "AuthenticationState")]
    public AuthenticationState? AuthenticationState { get; set; }

    private LoginDto LoginModel { get; set; } = new();
    private bool _isBusy = false;
    private string? errorMessage = null;

    private async Task LoginAsync()
    {
        try
        {
            _isBusy = true;
            errorMessage = null;

            var response = await HttpClient.PostAsJsonAsync<LoginDto>("api/account/login", LoginModel);
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                var authResult = JsonHelper.Deserialize<AuthResponseDto>(content);
                if (authResult is null)
                {
                    _isBusy = false;
                    errorMessage = "Invalid login response.";
                    return;
                }

                if (AuthenticationState is null)
                {
                    _isBusy = false;
                    errorMessage = "Authentication state is not available.";
                    return;
                }

                var serialized = JsonHelper.Serialize(authResult);
                await JsRuntime.InvokeVoidAsync("window.setToStorage", AuthenticationState.AuthStoreKey, serialized);

                AuthenticationState.LoadState(authResult);
                var destination = authResult.User.Role switch
                {
                    "Child" => "/child/dashboard",
                    "Parent" => "/parent/dashboard",
                    "Teacher" => "/teacher/dashboard",
                    "Admin" => "/admin/dashboard",
                    _ => "/login"
                };

                var selectedRole = authResult.User.Role switch
                {
                    "Child" => AppRole.Child,
                    "Parent" => AppRole.Parent,
                    "Teacher" => AppRole.Teacher,
                    "Admin" => AppRole.Admin,
                    _ => AppRole.None
                };

                if (string.Equals(authResult.User.Role, "Admin", StringComparison.OrdinalIgnoreCase))
                {
                    AdminSession.SignInAdmin();
                }
                else
                {
                    AdminSession.SignOut();
                }

                if (selectedRole != AppRole.None)
                {
                    RoleState.SelectRole(selectedRole);
                    await RoleState.InitializeAsync(selectedRole);
                }

                NavigationManager.NavigateTo(destination, replace: true);
            }
            else
            {
                string? errorContent = null;
                try
                {
                    errorContent = await response.Content.ReadAsStringAsync();
                }
                catch
                {
                }

                if (string.IsNullOrWhiteSpace(errorContent))
                {
                    errorContent = $"Error {response.StatusCode} - {response.ReasonPhrase}";
                }

                _isBusy = false;
                errorMessage = errorContent;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            _isBusy = false;
        }
    }
}


