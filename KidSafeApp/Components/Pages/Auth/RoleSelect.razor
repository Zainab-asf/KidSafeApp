@page "/auth"
@using KidSafeApp.StateManagement

@inject NavigationManager Navigation
@inject RoleState RoleState

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Choose Your Role 😊</h1>
    <p class="auth-subtitle">Pick how you want to use KidSafe today.</p>

    <div class="auth-options">
      <button class="auth-option auth-child" @onclick="GoToChild">
        <div class="auth-option-title">I am a Child 🧒</div>
        <div class="auth-option-text">Use KidSafe to learn and chat safely.</div>
      </button>

      <button class="auth-option auth-parent" @onclick="GoToParent">
        <div class="auth-option-title">I am a Parent 👨‍👩‍👧</div>
        <div class="auth-option-text">Monitor messages, progress, and achievements.</div>
      </button>

      <button class="auth-option auth-teacher" @onclick="GoToTeacher">
        <div class="auth-option-title">I am a Teacher 👩‍🏫</div>
        <div class="auth-option-text">Manage classes, assign lessons, and review activity.</div>
      </button>

      <button class="auth-option auth-admin" @onclick="GoToAdmin">
        <div class="auth-option-title">I am an Admin 🛡️</div>
        <div class="auth-option-text">Manage users, monitor system, and configure settings.</div>
      </button>
    </div>

    <p class="auth-hint">You can switch dashboards later from the left navigation.</p>
  </div>
</div>

@code {
  private async Task GoToChild()
  {
    RoleState.SelectRole(AppRole.Child);
    await RoleState.InitializeAsync(AppRole.Child);
    Navigation.NavigateTo("/child/dashboard", replace: true);
  }

  private async Task GoToParent()
  {
    RoleState.SelectRole(AppRole.Parent);
    await RoleState.InitializeAsync(AppRole.Parent);
    Navigation.NavigateTo("/parent/dashboard", replace: true);
  }

  private async Task GoToTeacher()
  {
    RoleState.SelectRole(AppRole.Teacher);
    await RoleState.InitializeAsync(AppRole.Teacher);
    Navigation.NavigateTo("/teacher/dashboard", replace: true);
  }

  private async Task GoToAdmin()
  {
    RoleState.SelectRole(AppRole.Admin);
    await RoleState.InitializeAsync(AppRole.Admin);
    Navigation.NavigateTo("/admin/dashboard", replace: true);
  }
}
