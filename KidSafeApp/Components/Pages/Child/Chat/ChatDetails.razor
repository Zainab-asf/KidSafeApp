@namespace KidSafeApp.Components.Pages.Child.Chat
@using System.Net.Http.Headers
@using KidSafeApp.Shared.DTOs.Chat
@using KidSafeApp.Helpers
@using KidSafeApp.Services
@inject HttpClient Client
@inject IJSRuntime JsRuntime
@inject KidSafeApp.StateManagement.AuthenticationState AuthState
@inject ChatService ChatService
@inject ErrorService ErrorService

@if (SelectedUser is null)
{
    <div class="p-3 w-100">
        <div class="alert alert-info mb-0">
            Select a user to start a conversation.
        </div>
    </div>
}
else
{
    <div class="flex-grow-1 d-flex flex-column">
        <div class="header">
            <div class="d-flex align-items-center gap-2">
                <div class="avatar-circle">
                    @if (!string.IsNullOrWhiteSpace(SelectedUser.AvatarUrl))
                    {
                        <img src="@SelectedUser.AvatarUrl" alt="avatar" class="avatar-img" />
                    }
                    else
                    {
                        <span class="avatar-initials">@GetInitials(SelectedUser.Name)</span>
                    }
                </div>
                <div class="fw-semibold">@SelectedUser.Name</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="HandleCancelClick">Close</button>
        </div>

        <div class="messages-list" @ref="_messagesListDiv">
            @if (_loadingInitial)
            {
                <div class="d-flex justify-content-center align-items-center p-5" style="min-height: 200px;">
                    <div class="text-center">
                        <div class="spinner-border spinner-border-sm text-primary mb-2" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mb-0 small text-muted">Loading messages...</p>
                    </div>
                </div>
            }
            else if (Messages.Count == 0)
            {
                <div class="d-flex align-items-center justify-content-center" style="min-height: 200px; flex-direction: column;">
                    <p class="text-muted small text-center">
                        No messages yet.<br/>
                        <span class="text-primary">Start the conversation!</span>
                    </p>
                </div>
            }
            else
            {
                @foreach (var message in Messages)
                {
                    <div class="message-item @(message.FromUserId == AuthenticationState?.User?.Id ? "sent" : "received")">
                        <div class="avatar-circle message-avatar">
                            @if (message.FromUserAvatarUrl != null)
                            {
                                <img src="@message.FromUserAvatarUrl" alt="avatar" class="avatar-img" />
                            }
                            else
                            {
                                <span class="avatar-initials">@GetInitials(message.FromUserName)</span>
                            }
                        </div>
                        <div class="message-content">
                            <div class="message-text">@message.Message</div>
                            <div class="message-time">@message.SentAt.ToString("MMM d, h:mm tt")</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="message-input">
            <input class="form-control" 
                placeholder="Type your message..." 
                @bind="NewMessage" 
                @bind:event="oninput"
                @onkeydown="OnKeyDown"
                disabled="_sendingMessage"
                autocomplete="off"
                aria-label="Message input" />
            <button class="btn btn-primary" 
                @onclick="SendMessageAsync"
                disabled="@(_sendingMessage || string.IsNullOrWhiteSpace(NewMessage))"
                type="button"
                aria-label="Send message">
                @if (_sendingMessage)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Sending...</span>
                }
                else
                {
                    <span>Send</span>
                }
            </button>
        </div>
    </div>
}

@code {
    [CascadingParameter(Name = "AuthenticationState")]
    public AuthenticationState? AuthenticationState { get; set; }

    [Parameter]
    public UserDto? SelectedUser { get; set; }

    [Parameter]
    public MessageDto? NewIncomingMessage { get; set; }

    [Parameter]
    public EventCallback OnIncomingMessageRecieved { get; set; }

    [Parameter]
    public EventCallback<bool> OnCancel { get; set; }

    private bool _loadingInitial = false;
    private bool _sendingMessage = false;
    private readonly List<MessageDto> Messages = new();
    private string NewMessage = string.Empty;
    private ElementReference _messagesListDiv;

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (SelectedUser is null)
        {
            Messages.Clear();
            return;
        }

        // Load message history when user is selected
        await LoadMessagesAsync();

        if (NewIncomingMessage is not null)
        {
            Messages.Add(NewIncomingMessage);
            await OnIncomingMessageRecieved.InvokeAsync();
        }
        await ScrollToBottomAsync();
    }

    private async Task LoadMessagesAsync()
    {
        if (SelectedUser is null || AuthenticationState is null)
            return;

        try
        {
            _loadingInitial = true;
            var messages = await ChatService.GetMessagesAsync(SelectedUser.Id);
            if (messages is not null)
            {
                Messages.Clear();
                Messages.AddRange(messages);
            }
        }
        catch
        {
            // Error already shown by ErrorService
        }
        finally
        {
            _loadingInitial = false;
        }
    }

    private async Task SendMessageAsync()
    {
        if (SelectedUser is null || AuthenticationState is null)
            return;

        if (string.IsNullOrWhiteSpace(NewMessage))
            return;

        _sendingMessage = true;
        var messageContent = NewMessage;
        NewMessage = string.Empty;

        try
        {
            var sentMessage = await ChatService.SendAsync(SelectedUser.Id, messageContent);
            if (sentMessage is not null)
            {
                Messages.Add(sentMessage);
                ErrorService.ShowSuccess("Message sent!");
                await ScrollToBottomAsync();
            }
        }
        catch
        {
            // Error already shown by ErrorService
            NewMessage = messageContent; // Restore message for retry
        }
        finally
        {
            _sendingMessage = false;
        }
    }

    private async Task HandleCancelClick()
    {
        await OnCancel.InvokeAsync(true);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_sendingMessage && !string.IsNullOrWhiteSpace(NewMessage))
        {
            await SendMessageAsync();
        }
    }

    private async Task ScrollToBottomAsync()
    {
        await Task.Delay(50); // Wait for render
        if (_messagesListDiv.Context is not null)
        {
            await JsRuntime.InvokeVoidAsync("scrollToBottom", _messagesListDiv);
        }
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return string.Concat(parts[0][0], parts[^1][0]).ToUpper();
    }
}


