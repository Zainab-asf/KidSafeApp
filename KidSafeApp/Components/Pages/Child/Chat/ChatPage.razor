@namespace KidSafeApp.Components.Pages.Child.Chat
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Headers
@using KidSafeApp.Helpers
@using KidSafeApp.Constants
@inject HttpClient Client
@inject KidSafeApp.StateManagement.RoleState RoleState
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime
@inject KidSafeApp.StateManagement.AuthenticationState AuthState
@inject KidSafeApp.StateManagement.AdminSessionState AdminSession
@inject KidSafeApp.Services.HubConnectionService HubService
@inject KidSafeApp.Services.AuthenticationService AuthService

@implements IAsyncDisposable

<div class="container-fluid">
    <div class="card br-0 mt-1">
        <div class="card-header bg-light br-0">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <h2 class="mb-0">Chat</h2>
                    <div class="small text-muted">@AuthenticationState?.User?.Name</div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <button type="button" class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
                    <button type="button" class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
                </div>
            </div>
        </div>
        <div class="card-body messages-window bg-light d-flex">
            <div class="row ks-chat-layout" style="flex: 1">
                <div class="col-12 col-lg-3 ks-chat-pane">
                    <ChatsList Loading="_loadingUsers" Chats="Chats" OnUserSelected="OnUserSelected" />
                </div>
                <div class="col-12 col-lg-6 d-flex px-0 ks-chat-pane">
                    <ChatDetails SelectedUser="_selectedUser" 
                        NewIncomingMessage="@_newIncomingMessage"
                        OnIncomingMessageRecieved = "()=> _newIncomingMessage = null"
                        OnCancel="HandleChatDetailsCancel" />
                </div>
                <div class="col-12 col-lg-3 ks-chat-pane">
                    <UsersList Loading="_loadingUsers" Users="Users" OnUserSelected="OnUserSelected" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "AuthenticationState")]
    public AuthenticationState? AuthenticationState { get; set; }

    private bool _loadingUsers = false;
    public ICollection<UserDto> Users { get; set; } = new HashSet<UserDto>();
    public IList<UserDto> Chats { get; set; } = new List<UserDto>();

    private UserDto? _selectedUser = null;
    private MessageDto? _newIncomingMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (!AuthService.IsAuthenticated || !await AuthService.IsTokenValidAsync())
        {
            return;
        }

        try
        {
            _loadingUsers = true;

            // Load users and chats in parallel
            var userListTask = GetClient().GetFromJsonAsync<ICollection<UserDto>>(
                ChatPageConstants.GetUsersEndpoint, JsonHelper.DefaultOptions);
            var chatListTask = GetClient().GetFromJsonAsync<IList<UserDto>>(
                ChatPageConstants.GetChatsEndpoint, JsonHelper.DefaultOptions);

            // Connect to hub and await data loading
            await HubService.ConnectAsync();
            RegisterHubEventHandlers();

            var usersList = await userListTask;
            if (usersList is not null)
            {
                Users = usersList;
            }

            var chatsList = await chatListTask;
            if (chatsList is not null)
            {
                Chats = chatsList;
            }

            // Mark user as online
            if (AuthenticationState?.User is not null)
            {
                await HubService.SetUserOnlineAsync(AuthenticationState.User);
            }
        }
        catch (HttpRequestException)
        {
            // HTTP request failed - connection issue
        }
        catch (TaskCanceledException)
        {
            // Request timeout
        }
        catch (InvalidOperationException)
        {
            // Configuration error
        }
        catch
        {
            // Unexpected error
        }
        finally
        {
            _loadingUsers = false;
        }
    }

    private void RegisterHubEventHandlers()
    {
        HubService.OnUserConnected += async user =>
        {
            await InvokeAsync(() =>
            {
                Users.Add(user);
                StateHasChanged();
            });
        };

        HubService.OnOnlineUsersList += async users =>
        {
            await InvokeAsync(() =>
            {
                var onlineIds = users.Select(u => u.Id).ToHashSet();
                foreach (var user in Users)
                {
                    user.IsOnline = onlineIds.Contains(user.Id);
                }
                StateHasChanged();
            });
        };

        HubService.OnUserIsOnline += async userId =>
        {
            await InvokeAsync(() =>
            {
                var user = Users.FirstOrDefault(u => u.Id == userId);
                if (user is not null)
                {
                    user.IsOnline = true;
                    StateHasChanged();
                }
            });
        };

        HubService.OnMessageReceived += async messageDto =>
        {
            await InvokeAsync(() =>
            {
                var fromUser = Users.FirstOrDefault(u => u.Id == messageDto.FromUserId);
                if (fromUser is null)
                {
                    return;
                }

                if (!Chats.Any(c => c.Id == messageDto.FromUserId))
                {
                    Chats.Insert(0, fromUser);
                }
                else if (_selectedUser?.Id == messageDto.FromUserId)
                {
                    _newIncomingMessage = messageDto;
                }

                StateHasChanged();
            });
        };

        HubService.OnRosterUpdated += async _ =>
        {
            await RefreshParticipantsAsync();
        };
    }

    private HttpClient GetClient()
    {
        if (!string.IsNullOrWhiteSpace(AuthService.CurrentToken))
        {
            Client.DefaultRequestHeaders.Authorization = 
                new AuthenticationHeaderValue("Bearer", AuthService.CurrentToken);
        }
        return Client;
    }

    private async Task RefreshParticipantsAsync()
    {
        try
        {
            var refreshedUsers = await GetClient().GetFromJsonAsync<ICollection<UserDto>>(
                ChatPageConstants.GetUsersEndpoint, JsonHelper.DefaultOptions);
            var refreshedChats = await GetClient().GetFromJsonAsync<IList<UserDto>>(
                ChatPageConstants.GetChatsEndpoint, JsonHelper.DefaultOptions);

            await InvokeAsync(() =>
            {
                Users = refreshedUsers ?? new List<UserDto>();
                Chats = refreshedChats ?? new List<UserDto>();
                StateHasChanged();
            });
        }
        catch
        {
            // Ignore transient sync failures; next reconnect/event will retry.
        }
    }

    private async Task OnUserSelected(UserDto user)
    {
        _selectedUser = user;

        var selectedChatUser = Chats.FirstOrDefault(c => c.IsSelected);
        if (selectedChatUser is not null)
        {
            selectedChatUser.IsSelected = false;
        }

        var chatUser = Chats.FirstOrDefault(c => c.Id == user.Id);
        if (chatUser is null)
        {
            user.IsSelected = true;
            Chats.Add(user);
        }
        else
        {
            chatUser.IsSelected = true;
        }
    }

    private async Task HandleChatDetailsCancel(bool shouldRemoveFromChatsList)
    {
        if (shouldRemoveFromChatsList && _selectedUser is not null)
        {
            Chats.Remove(_selectedUser);
        }
        _selectedUser = null;
    }

    private async Task HandleLogout()
    {
        await HubService.DisconnectAsync();
        try
        {
            await JsRuntime.InvokeVoidAsync("window.removeFromStorage", AuthenticationState.AuthStoreKey);
        }
        catch
        {
            // Ignore JavaScript errors
        }
        await AuthService.LogoutAsync();
    }

    private void HandleBack()
    {
        NavigationManager.NavigateTo(RoleState.CurrentRole switch
        {
            AppRole.Child => "/child/dashboard",
            AppRole.Parent => "/parent/dashboard",
            AppRole.Teacher => "/teacher/dashboard",
            _ => "/"
        });
    }

    public async ValueTask DisposeAsync()
    {
        await HubService.DisposeAsync();
    }
}


