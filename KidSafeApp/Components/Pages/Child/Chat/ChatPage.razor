@namespace KidSafeApp.Components.Pages.Child.Chat
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Headers
@using System.IdentityModel.Tokens.Jwt;
@using System.Net.Sockets
@using KidSafeApp.Helpers
@inject HttpClient Client
@inject KidSafeApp.States.RoleState RoleState

@implements IAsyncDisposable

@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime
@inject KidSafeApp.States.AuthenticationState AuthState
@inject KidSafeApp.States.AdminSessionState AdminSession

<div class="container-fluid">
    <div class="card br-0 mt-1">
        <div class="card-header bg-light br-0">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <h2 class="mb-0">Chat</h2>
                    <div class="small text-muted">@AuthenticationState?.User?.Name</div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <button type="button" class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
                    <button type="button" class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
                </div>
            </div>
        </div>
        <div class="card-body messages-window bg-light d-flex">
            <div class="row ks-chat-layout" style="flex: 1">
                <div class="col-12 col-lg-3 ks-chat-pane">
                    <ChatsList Loading="_loadingUsers" Chats="Chats" OnUserSelected="OnUserSelected" />
                </div>
                <div class="col-12 col-lg-6 d-flex px-0 ks-chat-pane">
                    <ChatDetails SelectedUser="_selectedUser" 
                        NewIncomingMessage="@_newIncomingMessage"
                        OnIncomingMessageRecieved = "()=> _newIncomingMessage = null"
                        OnCancel="HandleChatDetailsCancel" />
                </div>
                <div class="col-12 col-lg-3 ks-chat-pane">
                    <UsersList Loading="_loadingUsers" Users="Users" OnUserSelected="OnUserSelected" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "AuthenticationState")]
    public AuthenticationState? AuthenticationState { get; set; }

    private HubConnection? _hubConnection;

    private bool _loadingUsers = false;
    public ICollection<UserDto> Users { get; set; } = new HashSet<UserDto>();
    public IList<UserDto> Chats { get; set; } = new List<UserDto>();

    private UserDto? _selectedUser = null;
    private MessageDto? _newIncomingMessage = null;

    private async Task<bool> IsTokenExpiredAsync()
    {
        if (AuthenticationState is null || string.IsNullOrWhiteSpace(AuthenticationState.Token))
        {
            return true;
        }

        var jwt = new JwtSecurityToken(AuthenticationState.Token);
        if (jwt.ValidTo <= DateTime.Now)
        {
            await HandleLogout();
            return true;
        }
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (AuthenticationState is null || !AuthenticationState.IsAuthenticated)
        {
            _loadingUsers = false;
            return;
        }

        try
        {
            if (!await IsTokenExpiredAsync())
            {
                _hubConnection = ConfigureHubConnection();

                _loadingUsers = true;
                var userListTask = GetClient().GetFromJsonAsync<ICollection<UserDto>>("api/users", JsonConverter.JsonSerializerOptions);
                var chatListTask = GetClient().GetFromJsonAsync<IList<UserDto>>("api/users/chats", JsonConverter.JsonSerializerOptions);

                await _hubConnection.StartAsync();
                await JsRuntime.InvokeVoidAsync("console.log", "Hub connected successfully");

                var usersList = await userListTask;
                if (usersList is not null)
                {
                    Users = usersList;
                    await JsRuntime.InvokeVoidAsync("console.log", $"Loaded {usersList.Count} users");
                }
                else
                {
                    await JsRuntime.InvokeVoidAsync("console.log", "Users list is null");
                }

                var chatsList = await chatListTask;
                if (chatsList is not null)
                {
                    Chats = chatsList;
                    await JsRuntime.InvokeVoidAsync("console.log", $"Loaded {chatsList.Count} chats");
                }
                else
                {
                    await JsRuntime.InvokeVoidAsync("console.log", "Chats list is null");
                }

                await _hubConnection.SendAsync(nameof(IChatHubServer.SetUserOnline), AuthenticationState.User);
                await JsRuntime.InvokeVoidAsync("console.log", "User marked online");
            }
        }
        catch (Exception ex) when (ex is InvalidOperationException or TaskCanceledException)
        {
            await JsRuntime.InvokeVoidAsync("console.log", $"TaskCanceled/InvalidOp error: {ex.Message}");
        }
        catch (HttpRequestException ex)
        {
            await JsRuntime.InvokeVoidAsync("console.log", $"HTTP error: {ex.Message}");
        }
        catch (SocketException ex)
        {
            await JsRuntime.InvokeVoidAsync("console.log", $"Socket error: {ex.Message}");
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("console.log", $"Unexpected error: {ex.GetType().Name} - {ex.Message}");
        }
        finally
        {
            _loadingUsers = false;
        }
    }

    private HttpClient GetClient()
    {
        if (AuthenticationState is not null && !string.IsNullOrWhiteSpace(AuthenticationState.Token))
        {
            Client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", AuthenticationState.Token);
        }
        return Client;
    }

    private async Task OnUserSelected(UserDto user)
    {
        _selectedUser = user;

        var selectedChatUser = Chats.FirstOrDefault(c => c.IsSelected);
        if(selectedChatUser is not null)
        {
            selectedChatUser.IsSelected = false;
        }

        var chatUser = Chats.FirstOrDefault(c => c.Id == user.Id);
        if(chatUser is null)
        {
            user.IsSelected = true;
            Chats.Add(user);
        }
        else
        {
            chatUser.IsSelected = true;
        }

    }

    private async Task HandleChatDetailsCancel(bool shouldRemoveFromChatsList)
    {
        if (shouldRemoveFromChatsList)
        {
            if (_selectedUser is not null)
            {
                Chats.Remove(_selectedUser);
            }
        }
        _selectedUser = null;
    }

    private async Task HandleLogout()
    {
        AdminSession.SignOut();
        AuthState.UnLoadState();
        await JsRuntime.InvokeVoidAsync("window.removeFromStorage", AuthenticationState.AuthStoreKey);
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }

    private void HandleBack()
    {
        if (RoleState.CurrentRole == KidSafeApp.States.AppRole.Child)
        {
            NavigationManager.NavigateTo("/child/dashboard");
            return;
        }

        if (RoleState.CurrentRole == KidSafeApp.States.AppRole.Parent)
        {
            NavigationManager.NavigateTo("/parent/dashboard");
            return;
        }

        if (RoleState.CurrentRole == KidSafeApp.States.AppRole.Teacher)
        {
            NavigationManager.NavigateTo("/teacher/dashboard");
            return;
        }

        NavigationManager.NavigateTo("/");
    }

    private HubConnection ConfigureHubConnection()
    {
        if (Client.BaseAddress is null)
        {
            throw new InvalidOperationException("HttpClient.BaseAddress is not configured.");
        }

        var hubUrl = new Uri(Client.BaseAddress, "hubs/kidsafeapp");
        var hubConnection = new HubConnectionBuilder()
                            .WithUrl(hubUrl,
                               options => options.AccessTokenProvider = () => Task.FromResult(AuthenticationState.Token))
                            .Build();

        hubConnection.On<UserDto>(nameof(IChatHubClient.UserConnected), (newUser) =>
        {
            Users.Add(newUser);
            StateHasChanged();
        });

        hubConnection.On<ICollection<UserDto>>(nameof(IChatHubClient.OnlineUsersList), (onlineUsers) =>
        {
            foreach (var user in Users)
            {
                if (onlineUsers.Any(u => u.Id == user.Id))
                {
                    user.IsOnline = true;
                }
            }
            StateHasChanged();
        });

        hubConnection.On<int>(nameof(IChatHubClient.UserIsOnline), (userId) =>
        {
            var user = Users.FirstOrDefault(u => u.Id == userId);
            if (user is not null)
            {
                user.IsOnline = true;
                StateHasChanged();
            }
        });

        hubConnection.On<MessageDto>(nameof(IChatHubClient.MessageRecieved), (messageDto) =>
        {
            var fromUser = Users.FirstOrDefault(u => u.Id == messageDto.FromUserId);

            if (!Chats.Any(c => c.Id == messageDto.FromUserId))
            {
                Chats.Insert(0, fromUser!);
            }
            else
            {
                if (_selectedUser?.Id == messageDto.FromUserId)
                {
                    _newIncomingMessage = messageDto;
                }
            }
            StateHasChanged();
        });

        return hubConnection;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
