@namespace KidSafeApp.Components.Pages.Child.Chat

<div class="d-flex align-items-center justify-content-between">
    <h3 class="mb-2">Chats</h3>
    @if (!Loading && Chats.Any())
    {
        <small class="text-muted badge bg-light text-dark">@Chats.Count()</small>
    }
</div>

<input class="form-control form-control-sm mb-2" placeholder="Search chats..." @bind="_query" @bind:event="oninput" />
<ul class="list-group list-group-flush">
    @if (Loading)
    {
        <li class="list-group-item">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            Loading...
        </li>
    }
    else
    {
        if (!FilteredChats.Any())
        {
            <li class="list-group-item text-muted text-center py-3">
                <small>No chats yet. Select a classmate to start!</small>
            </li>
        }
        else
        {
            @foreach (var chat in FilteredChats)
            {
                <li class="list-group-item d-flex align-items-center gap-2 @(chat.IsSelected ? "bg-success text-white" : "")"
                    @onclick="() => HandleUserClick(chat)"
                    style="cursor: pointer;">
                    <div style="position: relative; width: 36px; height: 36px; flex-shrink: 0;">
                        <div class="avatar-circle" style="width:36px;height:36px;">
                            @if (!string.IsNullOrWhiteSpace(chat.AvatarUrl))
                            {
                                <img src="@chat.AvatarUrl" alt="avatar" class="avatar-img" />
                            }
                            else
                            {
                                <span class="avatar-initials">@GetInitials(chat.Name)</span>
                            }
                        </div>
                        @if (chat.IsOnline)
                        {
                            <span style="position:absolute; bottom:0; right:0; width:10px; height:10px;
                                         background:#28a745; border-radius:50%; border:2px solid white;"></span>
                        }
                    </div>
                    <span class="flex-grow-1 text-truncate" style="max-width:120px;">@chat.Name</span>
                    @if (chat.UnreadCount > 0)
                    {
                        <span class="badge bg-danger rounded-pill">@chat.UnreadCount</span>
                    }
                </li>
            }
        }
    }
</ul>

@code {
    [Parameter]
    public IEnumerable<UserDto> Chats { get; set; } = Enumerable.Empty<UserDto>();

    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public EventCallback<UserDto> OnUserSelected { get; set; }

    private string _query = string.Empty;

    private IEnumerable<UserDto> FilteredChats => string.IsNullOrWhiteSpace(_query)
        ? Chats
        : Chats.Where(c => (c.Name ?? string.Empty).Contains(_query, StringComparison.OrdinalIgnoreCase));

    private async Task HandleUserClick(UserDto chat)
    {
        await OnUserSelected.InvokeAsync(chat);
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return string.Concat(parts[0][0], parts[^1][0]).ToUpper();
    }
}
