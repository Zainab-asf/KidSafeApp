@namespace KidSafeApp.Components.Pages.Child
@page "/child/learn/course/{CourseId:int}"

@inject HttpClient Client
@inject NavigationManager NavigationManager

<ChildPageShell>
    <div class="container py-3">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h1 class="h4 mb-1">Course Lessons</h1>
          <div class="text-secondary">Open lessons and update your progress</div>
        </div>
        <button class="btn btn-outline-secondary" @onclick="GoBackToLearn">Back to Learn</button>
      </div>

      @if (!string.IsNullOrWhiteSpace(_error))
      {
        <div class="alert alert-danger">@_error</div>
      }
      else if (_loading)
      {
        <div class="text-secondary">Loading lessons...</div>
      }
      else if (_lessons.Count == 0)
      {
        <div class="alert alert-info">No lessons are published for this course yet.</div>
      }
      else
      {
        <div class="row g-3">
          @foreach (var lesson in _lessons.OrderBy(l => l.SortOrder))
          {
            var progress = _progressByCourseLesson.GetValueOrDefault(lesson.CourseLessonId);
            <div class="col-12 col-lg-6">
              <div class="card h-100">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <h2 class="h6 mb-0">@lesson.SortOrder. @lesson.LessonTitle</h2>
                    <span class="badge text-bg-light">@lesson.Subject</span>
                  </div>

                  <div class="small text-secondary mb-2">Difficulty @lesson.DifficultyLevel</div>

                  <div class="progress mb-2" style="height: 8px;">
                    <div class="progress-bar" role="progressbar" style="width: @(progress?.PercentageComplete ?? 0)%"></div>
                  </div>

                  <div class="small text-secondary mb-3">
                    @(progress?.PercentageComplete ?? 0)% complete • @(progress?.IsCompleted == true ? "Completed" : "In progress")
                  </div>

                  @if (!string.IsNullOrWhiteSpace(lesson.PdfUrl))
                  {
                    <div class="mb-3">
                      <a class="btn btn-sm btn-outline-secondary" href="@lesson.PdfUrl" target="_blank">Open PDF Content</a>
                    </div>
                  }

                  <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => UpdateProgressAsync(lesson.CourseLessonId, 10, false)">Start / Continue</button>
                    <button class="btn btn-sm btn-primary" @onclick="() => UpdateProgressAsync(lesson.CourseLessonId, 100, true)">Mark Complete</button>
                  </div>
                </div>
              </div>
            </div>
          }
        </div>
      }
    </div>
</ChildPageShell>

@code {
  [Parameter] public int CourseId { get; set; }

  private bool _loading = true;
  private string? _error;
  private List<CourseLessonDto> _lessons = new();
  private Dictionary<int, LessonProgressDto> _progressByCourseLesson = new();

  protected override async Task OnParametersSetAsync()
  {
    await LoadAsync();
  }

  private async Task LoadAsync()
  {
    _loading = true;
    _error = null;
    try
    {
      _lessons = await Client.GetFromJsonAsync<List<CourseLessonDto>>($"api/child/learning/courses/{CourseId}/lessons") ?? new();
      var progress = await Client.GetFromJsonAsync<List<LessonProgressDto>>($"api/learning/progress/course/{CourseId}") ?? new();
      _progressByCourseLesson = progress.ToDictionary(p => p.CourseLessonId, p => p);
    }
    catch (Exception ex)
    {
      _error = ex.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private void GoBackToLearn() => NavigationManager.NavigateTo("/child/learn");

  private async Task UpdateProgressAsync(int courseLessonId, int percentageComplete, bool isCompleted)
  {
    _error = null;
    try
    {
      var dto = new UpdateLessonProgressDto
      {
        CourseLessonId = courseLessonId,
        PercentageComplete = percentageComplete,
        IsCompleted = isCompleted,
        TimeSpentSeconds = isCompleted ? 300 : 60
      };

      var response = await Client.PutAsJsonAsync("api/learning/progress", dto);
      if (!response.IsSuccessStatusCode)
      {
        _error = await response.Content.ReadAsStringAsync();
        return;
      }

      var updated = await response.Content.ReadFromJsonAsync<LessonProgressDto>();
      if (updated is not null)
      {
        _progressByCourseLesson[updated.CourseLessonId] = updated;
      }
    }
    catch (Exception ex)
    {
      _error = ex.Message;
    }
  }
}
