@namespace KidSafeApp.Components.Pages.Child
@page "/child/dashboard"
@page "/child-dashboard"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject KidSafeApp.States.AuthenticationState AuthState

<PageTitle>Child Home Portal</PageTitle>

@if (!AuthState.IsAuthenticated)
{
  <NavigateTo href="/login/child" replace="true" />
}
else if (!string.Equals(AuthState.User?.Role, "Child", StringComparison.OrdinalIgnoreCase))
{
  <NavigateTo href="/unauthorized" replace="true" />
}

@if (!RoleState.IsRoleLoaded)
{
  <RoleLoading />
}
else
{
  <ChildPageShell>
    <div class="ks-child-dashboard">
      <div class="ks-child-dashboard-body">
        <section class="ks-child-hero-card">
          <div class="ks-child-hero-avatar">👦🏻</div>
          <div class="flex-grow-1">
            <small>Good evening! 🌟</small>
            <h2>Hi, Ali!</h2>
            <div class="ks-child-hero-meta">Grade 5 &nbsp;•&nbsp; 🔥 5-day safe streak</div>
          </div>
          <div class="ks-child-hero-shield">
            <i class="bi bi-shield-check"></i>
          </div>
        </section>

        <section class="ks-child-stat-grid">
          <article class="ks-child-stat-card">
            <span class="ks-child-stat-icon"><i class="bi bi-chat"></i></span>
            <h3>158</h3>
            <small>Total Chats</small>
          </article>
          <article class="ks-child-stat-card">
            <span class="ks-child-stat-icon icon-blue"><i class="bi bi-shield-check"></i></span>
            <h3>90%</h3>
            <small>Safe Messages</small>
          </article>
          <article class="ks-child-stat-card">
            <span class="ks-child-stat-icon icon-gold"><i class="bi bi-lightbulb"></i></span>
            <h3>7</h3>
            <small>Badges Earned</small>
          </article>
        </section>

        <section class="ks-child-progress-card">
          <div class="d-flex justify-content-between align-items-center mb-2 gap-2">
            <strong>⭐ Stars Progress</strong>
            <strong class="text-success">320 / 500</strong>
          </div>
          <div class="progress ks-child-stars-progress" role="progressbar" aria-label="Stars progress" aria-valuenow="64" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-bar" style="width:64%"></div>
          </div>
          <small>180 more stars to unlock Super Communicator badge!</small>
        </section>

        <a href="/child/chat" class="ks-child-chat-cta">
          <span class="ks-child-chat-cta-icon"><i class="bi bi-chat"></i></span>
          <span>
            <strong>Start Chatting!</strong>
            <small>Safe & fun with AI protection 🛡️</small>
          </span>
          <i class="bi bi-arrow-right"></i>
        </a>

        <section class="ks-child-badges-card">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <strong>My Badges</strong>
            <a href="/child/achievements">View All</a>
          </div>
          <div class="ks-child-badges-row">
            <div class="ks-child-mini-badge"><span>💗</span><small>Kind Communicator</small></div>
            <div class="ks-child-mini-badge"><span>🛡️</span><small>Safe Chatter</small></div>
            <div class="ks-child-mini-badge"><span>⭐</span><small>Star Student</small></div>
            <div class="ks-child-mini-badge"><span>🙂</span><small>Emoji Master</small></div>
          </div>
        </section>

        <section class="ks-child-tip-card">
          <div class="d-flex gap-2 align-items-start">
            <span class="ks-child-tip-bulb">💡</span>
            <div>
              <strong>Tip of the Day</strong>
              <p>Kind words are like sunshine — they make everyone feel warm and happy. Try giving someone a compliment today!</p>
            </div>
          </div>
        </section>

        <section class="ks-child-support-grid">
          <article class="ks-child-support-card">
            <h3 class="ks-child-support-title">Daily Check-in</h3>
            <p class="ks-child-support-text">How are you feeling today? Share with your parent safely.</p>
            <a href="/child/settings" class="ks-child-support-link">Open Profile</a>
          </article>

          <article class="ks-child-support-card">
            <h3 class="ks-child-support-title">Need Help?</h3>
            <p class="ks-child-support-text">If something feels wrong, quickly open support resources.</p>
            <a href="/child/support" class="ks-child-support-link">Open Support</a>
          </article>
        </section>
      </div>
    </div>
  </ChildPageShell>
}

@code {
}
