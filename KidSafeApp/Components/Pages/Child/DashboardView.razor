@namespace KidSafeApp.Components.Pages.Child

<div class="ks-dashboard">
    <div class="container py-4 py-md-5">
        <div class="row justify-content-center">
            <div class="col-12 col-xxl-11">

                <!-- HEADER -->
                <div class="ks-shell shadow-sm">
                    <div class="d-flex align-items-start align-items-md-center justify-content-between flex-wrap gap-3">
                        <div>
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span class="ks-pill">KidSafe</span>
                                <span class="text-secondary small">Child Dashboard</span>
                            </div>

                            <h1 class="ks-h1 mt-2 mb-1">Good morning, <span class="ks-accent">Zainab</span></h1>
                            <div class="text-secondary ks-muted">
                                Learn • Chat • Grow — keep going today.
                            </div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap align-items-center">
                            <div class="ks-search">
                                <input class="form-control" placeholder="Search lessons, messages..." />
                            </div>
                            <a href="/child/learn" class="btn btn-primary">📚 Start Lesson</a>
                        </div>
                    </div>

                    <!-- STATS GRID -->
                    <div class="row g-3 g-md-4 mt-4">
                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-card">
                                <div class="ks-card-top">
                                    <div class="ks-icon">💬</div>
                                    <div>
                                        <div class="ks-card-title">Messages Sent</div>
                                        <div class="ks-card-sub">This week</div>
                                    </div>
                                </div>
                                <div class="ks-stat">0</div>
                                <div class="ks-trend ks-trend-up">+12.5% from last week</div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-card">
                                <div class="ks-card-top">
                                    <div class="ks-icon">📘</div>
                                    <div>
                                        <div class="ks-card-title">Courses Completed</div>
                                        <div class="ks-card-sub">All time</div>
                                    </div>
                                </div>
                                <div class="ks-stat">0</div>
                                <div class="ks-trend">Start your first lesson today</div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-card">
                                <div class="ks-card-top">
                                    <div class="ks-icon">🏅</div>
                                    <div>
                                        <div class="ks-card-title">Achievements</div>
                                        <div class="ks-card-sub">Badges earned</div>
                                    </div>
                                </div>
                                <div class="ks-stat">0</div>
                                <div class="ks-trend">Earn badges by staying active</div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-card">
                                <div class="ks-card-top">
                                    <div class="ks-icon">🔥</div>
                                    <div>
                                        <div class="ks-card-title">Days in a Row</div>
                                        <div class="ks-card-sub">Streak</div>
                                    </div>
                                </div>
                                <div class="ks-stat">0</div>
                                <div class="ks-trend">You are doing great</div>
                            </div>
                        </div>

                        <!-- TODAY'S TASKS -->
                        <div class="col-12 col-lg-7">
                            <div class="ks-card ks-card-lg">
                                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                    <div>
                                        <div class="ks-card-title">Today's Tasks</div>
                                        <div class="ks-card-sub">Suggested next steps</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary" type="button">View all</button>
                                </div>

                                <div class="ks-list mt-3">
                                    <div class="ks-list-item">
                                        <span class="ks-dot ks-dot-success"></span>
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">Finish one short lesson</div>
                                            <div class="text-secondary small">Build a daily learning habit</div>
                                        </div>
                                        <span class="text-secondary small">10 min</span>
                                    </div>

                                    <div class="ks-list-item">
                                        <span class="ks-dot ks-dot-info"></span>
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">Send a kind message</div>
                                            <div class="text-secondary small">Practice communication</div>
                                        </div>
                                        <span class="text-secondary small">2 min</span>
                                    </div>

                                    <div class="ks-list-item">
                                        <span class="ks-dot ks-dot-warning"></span>
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">Try a challenge</div>
                                            <div class="text-secondary small">Earn your first badge</div>
                                        </div>
                                        <span class="text-secondary small">5 min</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- PROFILE CARD -->
                        <div class="col-12 col-lg-5">
                            <div class="ks-card ks-card-lg">
                                <div class="ks-card-title">Profile</div>
                                <div class="ks-card-sub">Your details</div>

                                <div class="ks-profile mt-3">
                                    <div class="ks-avatar">Z</div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold">Zainab</div>
                                        <div class="text-secondary small">zainab@kidsafeapp.com</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary" type="button">Edit</button>
                                </div>

                                <div class="ks-note mt-3">
                                    <div class="fw-semibold">🌟 You are awesome!</div>
                                    <div class="text-secondary small">You finished 0 courses. Keep learning!</div>
                                </div>

                                <div class="d-flex justify-content-end mt-3">
                                    <a class="btn btn-sm btn-light" href="#">View Profile</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- LEARNING MODULE -->
                    <div class="row g-3 g-md-4 mt-4">
                        <div class="col-12">
                            <div class="ks-card ks-card-lg">
                                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                    <div>
                                        <div class="ks-card-title">📚 Recommended Courses</div>
                                        <div class="ks-card-sub">Learn at your own pace</div>
                                    </div>
                                    <a href="/child/learn" class="btn btn-sm btn-primary">See all courses</a>
                                </div>

                                <div class="ks-course-grid mt-3">
                                    <div class="ks-course-card">
                                        <div class="ks-course-badge">Beginner</div>
                                        <div class="ks-course-header">Digital Safety 101</div>
                                        <div class="text-secondary small">Learn how to stay safe online</div>
                                        <div class="ks-course-meta mt-2">
                                            <span class="ks-course-duration">📺 12 min</span>
                                            <span class="ks-course-progress">5/5 lessons</span>
                                        </div>
                                        <div class="ks-progress-bar mt-2">
                                            <div class="ks-progress" style="width: 100%;"></div>
                                        </div>
                                        <button class="btn btn-sm btn-outline-primary w-100 mt-2">✅ Completed</button>
                                    </div>

                                    <div class="ks-course-card">
                                        <div class="ks-course-badge ks-badge-warning">Intermediate</div>
                                        <div class="ks-course-header">Cyberbullying Awareness</div>
                                        <div class="text-secondary small">Recognize and handle bullying</div>
                                        <div class="ks-course-meta mt-2">
                                            <span class="ks-course-duration">📺 18 min</span>
                                            <span class="ks-course-progress">2/6 lessons</span>
                                        </div>
                                        <div class="ks-progress-bar mt-2">
                                            <div class="ks-progress" style="width: 33%;"></div>
                                        </div>
                                        <button class="btn btn-sm btn-primary w-100 mt-2">Continue →</button>
                                    </div>

                                    <div class="ks-course-card">
                                        <div class="ks-course-badge ks-badge-secondary">Intermediate</div>
                                        <div class="ks-course-header">Social Media Etiquette</div>
                                        <div class="text-secondary small">Be respectful online</div>
                                        <div class="ks-course-meta mt-2">
                                            <span class="ks-course-duration">📺 15 min</span>
                                            <span class="ks-course-progress">0/4 lessons</span>
                                        </div>
                                        <div class="ks-progress-bar mt-2">
                                            <div class="ks-progress" style="width: 0%;"></div>
                                        </div>
                                        <button class="btn btn-sm btn-primary w-100 mt-2">Start Course</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CHAT MODULE -->
                    <div class="row g-3 g-md-4 mt-4">
                        <div class="col-12 col-lg-6">
                            <div class="ks-card ks-card-lg">
                                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                    <div>
                                        <div class="ks-card-title">💬 Recent Chats</div>
                                        <div class="ks-card-sub">Your conversations</div>
                                    </div>
                                    <a href="/child/chat" class="btn btn-sm btn-primary">Open Chat</a>
                                </div>

                                <div class="ks-chat-list mt-3">
                                    <div class="ks-chat-item">
                                        <div class="ks-chat-avatar">P</div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="fw-semibold">Parent</div>
                                            <div class="text-secondary small text-truncate">Thanks for finishing your homework! 👍</div>
                                            <div class="text-muted x-small">2 min ago</div>
                                        </div>
                                        <span class="ks-badge-unread">2</span>
                                    </div>

                                    <div class="ks-chat-item">
                                        <div class="ks-chat-avatar">T</div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="fw-semibold">Teacher</div>
                                            <div class="text-secondary small text-truncate">Great work on the assignment</div>
                                            <div class="text-muted x-small">1 hour ago</div>
                                        </div>
                                    </div>

                                    <div class="ks-chat-item">
                                        <div class="ks-chat-avatar">F</div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="fw-semibold">Friend</div>
                                            <div class="text-secondary small text-truncate">Want to play after school?</div>
                                            <div class="text-muted x-small">3 hours ago</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SAFETY TIPS MODULE -->
                        <div class="col-12 col-lg-6">
                            <div class="ks-card ks-card-lg">
                                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                    <div>
                                        <div class="ks-card-title">💡 Safety Tips</div>
                                        <div class="ks-card-sub">Stay safe online</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary">More tips</button>
                                </div>

                                <div class="ks-tips mt-3">
                                    <div class="ks-tip-item">
                                        <div class="ks-tip-icon">🔐</div>
                                        <div>
                                            <div class="fw-semibold">Strong Passwords</div>
                                            <div class="text-secondary small">Use uppercase, numbers & symbols</div>
                                        </div>
                                    </div>

                                    <div class="ks-tip-item">
                                        <div class="ks-tip-icon">👤</div>
                                        <div>
                                            <div class="fw-semibold">Privacy First</div>
                                            <div class="text-secondary small">Don't share personal info online</div>
                                        </div>
                                    </div>

                                    <div class="ks-tip-item">
                                        <div class="ks-tip-icon">🛑</div>
                                        <div>
                                            <div class="fw-semibold">Report Bullying</div>
                                            <div class="text-secondary small">Talk to a trusted adult</div>
                                        </div>
                                    </div>

                                    <div class="ks-tip-item">
                                        <div class="ks-tip-icon">⏰</div>
                                        <div>
                                            <div class="fw-semibold">Screen Time</div>
                                            <div class="text-secondary small">Take breaks every hour</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ACHIEVEMENTS MODULE -->
                    <div class="row g-3 g-md-4 mt-4">
                        <div class="col-12">
                            <div class="ks-card ks-card-lg">
                                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                    <div>
                                        <div class="ks-card-title">🏆 Achievements & Badges</div>
                                        <div class="ks-card-sub">Your milestones</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary">View all</button>
                                </div>

                                <div class="ks-badges-grid mt-3">
                                    <div class="ks-badge-item ks-badge-earned">
                                        <div class="ks-badge-icon">🏅</div>
                                        <div class="ks-badge-label">First Lesson</div>
                                    </div>

                                    <div class="ks-badge-item ks-badge-earned">
                                        <div class="ks-badge-icon">⭐</div>
                                        <div class="ks-badge-label">7-Day Streak</div>
                                    </div>

                                    <div class="ks-badge-item ks-badge-locked">
                                        <div class="ks-badge-icon">🔒 🎓</div>
                                        <div class="ks-badge-label">Course Master</div>
                                    </div>

                                    <div class="ks-badge-item ks-badge-locked">
                                        <div class="ks-badge-icon">🔒 💬</div>
                                        <div class="ks-badge-label">Chat Pro</div>
                                    </div>

                                    <div class="ks-badge-item ks-badge-locked">
                                        <div class="ks-badge-icon">🔒 🛡️</div>
                                        <div class="ks-badge-label">Safety Expert</div>
                                    </div>

                                    <div class="ks-badge-item ks-badge-locked">
                                        <div class="ks-badge-icon">🔒 🌟</div>
                                        <div class="ks-badge-label">Super User</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>
</div>
