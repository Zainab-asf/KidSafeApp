@namespace KidSafeApp.Components.Pages.Child

<div class="ks-home">
    <div class="ks-home-body">
        <section class="ks-hero-card">
            <div class="ks-hero-avatar">👦🏻</div>
            <div class="flex-grow-1">
                <small>Good evening! 🌟</small>
                <h2>Hi, Ali!</h2>
                <div class="ks-hero-meta">Grade 5 &nbsp;•&nbsp; 🔥 5-day safe streak</div>
            </div>
            <div class="ks-hero-shield">
                <i class="bi bi-shield-check"></i>
            </div>
        </section>

        <section class="ks-stat-grid">
            <article class="ks-stat-card">
                <span class="ks-stat-icon"><i class="bi bi-chat"></i></span>
                <h3>158</h3>
                <small>Total Chats</small>
            </article>
            <article class="ks-stat-card">
                <span class="ks-stat-icon icon-blue"><i class="bi bi-shield-check"></i></span>
                <h3>90%</h3>
                <small>Safe Messages</small>
            </article>
            <article class="ks-stat-card">
                <span class="ks-stat-icon icon-gold"><i class="bi bi-lightbulb"></i></span>
                <h3>7</h3>
                <small>Badges Earned</small>
            </article>
        </section>

        <section class="ks-progress-card">
            <div class="d-flex justify-content-between align-items-center mb-2 gap-2">
                <strong>⭐ Stars Progress</strong>
                <strong class="text-success">320 / 500</strong>
            </div>
            <div class="progress ks-stars-progress" role="progressbar" aria-label="Stars progress" aria-valuenow="64" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width:64%"></div>
            </div>
            <small>180 more stars to unlock Super Communicator badge!</small>
        </section>

        <a href="/child/chat" class="ks-chat-cta">
            <span class="ks-chat-cta-icon"><i class="bi bi-chat"></i></span>
            <span>
                <strong>Start Chatting!</strong>
                <small>Safe & fun with AI protection 🛡️</small>
            </span>
            <i class="bi bi-arrow-right"></i>
        </a>

        <section class="ks-badges-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <strong>My Badges</strong>
                <a href="/child/achievements">View All</a>
            </div>
            <div class="ks-badges-row">
                <div class="ks-mini-badge"><span>💗</span><small>Kind Communicator</small></div>
                <div class="ks-mini-badge"><span>🛡️</span><small>Safe Chatter</small></div>
                <div class="ks-mini-badge"><span>⭐</span><small>Star Student</small></div>
                <div class="ks-mini-badge"><span>🙂</span><small>Emoji Master</small></div>
            </div>
        </section>

        <section class="ks-tip-card">
            <div class="d-flex gap-2 align-items-start">
                <span class="ks-tip-bulb">💡</span>
                <div>
                    <strong>Tip of the Day</strong>
                    <p>Kind words are like sunshine — they make everyone feel warm and happy. Try giving someone a compliment today!</p>
                </div>
            </div>
        </section>
    </div>

    <nav class="ks-bottom-nav" aria-label="Child navigation">
        <a class="active" href="/child/dashboard"><i class="bi bi-house"></i><span>Home</span></a>
        <a href="/child/chat"><i class="bi bi-chat"></i><span>Chat</span></a>
        <a href="/child/notifications"><i class="bi bi-bell"></i><span>Alerts</span><em>2</em></a>
        <a href="/child/settings"><i class="bi bi-person"></i><span>Profile</span></a>
    </nav>
</div>
