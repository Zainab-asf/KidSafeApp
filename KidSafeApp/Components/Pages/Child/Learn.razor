@namespace KidSafeApp.Components.Pages.Child
@page "/child/learn"
@using KidSafeApp.Shared.DTOs
@inject HttpClient Client
@inject NavigationManager NavigationManager

<ChildLayout>
  <section class="ks-content">
    <div class="ks-learn-container">
      <div class="ks-learn-header">
        <div>
          <h1 class="ks-learn-title">📚 Learning Center</h1>
          <p class="ks-learn-subtitle">Explore courses and lessons to grow your knowledge</p>
        </div>
        <div class="ks-learn-stats">
          <div class="ks-stat-box">
            <span class="ks-stat-value">@FilteredCourses.Count</span>
            <span class="ks-stat-label">Courses</span>
          </div>
          <div class="ks-stat-box">
            <span class="ks-stat-value">@FilteredCourses.Sum(c => c.LessonCount)</span>
            <span class="ks-stat-label">Lessons</span>
          </div>
        </div>
      </div>

      <!-- COURSE CATEGORIES -->
      <div class="ks-category-tabs">
        <button class="ks-tab @(FilterCategory == string.Empty ? "active" : string.Empty)" @onclick="() => SelectCategory(string.Empty)">All Courses</button>
        <button class="ks-tab @(IsSafetySelected ? "active" : string.Empty)" @onclick="SelectSafety">🛡️ Safety</button>
        <button class="ks-tab @(IsSocialSelected ? "active" : string.Empty)" @onclick="SelectSocial">👥 Social Skills</button>
        <button class="ks-tab @(IsTechnologySelected ? "active" : string.Empty)" @onclick="SelectTechnology">💻 Technology</button>
      </div>

      <!-- FEATURED COURSE -->
      @if (FilteredCourses.Count > 0)
      {
        var featured = FilteredCourses[0];
        <div class="ks-featured-course">
          <div class="ks-featured-badge">Featured</div>
          <div class="ks-featured-content">
            <h2>🌟 @featured.Title</h2>
            <p>@featured.Description</p>
            <div class="ks-featured-meta">
              <span>🎓 Difficulty @featured.DifficultyLevel</span>
              <span>📺 @featured.LessonCount lessons</span>
              <span>📈 @featured.PercentageComplete% complete</span>
            </div>
            <button class="btn btn-primary mt-3" @onclick="() => OpenCourse(featured.Id)">Open Course →</button>
          </div>
        </div>
      }

      <!-- COURSES GRID -->
      <div class="ks-learn-grid">
        @if (!string.IsNullOrWhiteSpace(_error))
        {
          <div class="alert alert-danger">@_error</div>
        }
        else if (_loading)
        {
          <div class="text-secondary">Loading courses...</div>
        }
        else if (FilteredCourses.Count == 0)
        {
          <div class="alert alert-info">No published courses available right now.</div>
        }
        else
        {
          @foreach (var course in FilteredCourses)
          {
            <div class="ks-learn-card">
              <div class="ks-card-flag">Level @course.DifficultyLevel</div>
              <div class="ks-card-content">
                <div class="ks-learn-icon">📘</div>
                <h3>@course.Title</h3>
                <p>@course.Description</p>

                <div class="ks-card-stats">
                  <span>📺 @course.LessonCount lessons</span>
                  <span>✅ @course.CompletedLessons completed</span>
                </div>

                <div class="ks-progress-container">
                  <div class="ks-progress-bar">
                    <div class="ks-progress" style="width: @course.PercentageComplete%;"></div>
                  </div>
                  <span class="ks-progress-text">@course.PercentageComplete% Complete</span>
                </div>

                <button class="btn btn-sm @(course.PercentageComplete > 0 ? "btn-primary" : "btn-outline-primary") w-100 mt-2"
                        @onclick="() => OpenCourse(course.Id)">
                  @(course.PercentageComplete > 0 ? "Continue" : "Start Course")
                </button>
              </div>
            </div>
          }
        }
      </div>
    </div>
  </section>
</ChildLayout>

@code {
  private bool _loading = true;
  private string? _error;
  private List<ChildCourseDto> _courses = new();
  private string FilterCategory { get; set; } = string.Empty;
  private bool IsSafetySelected => string.Equals(FilterCategory, "Safety", StringComparison.OrdinalIgnoreCase);
  private bool IsSocialSelected => string.Equals(FilterCategory, "Social", StringComparison.OrdinalIgnoreCase);
  private bool IsTechnologySelected => string.Equals(FilterCategory, "Technology", StringComparison.OrdinalIgnoreCase);

  private List<ChildCourseDto> FilteredCourses =>
    string.IsNullOrWhiteSpace(FilterCategory)
      ? _courses
      : _courses.Where(c => string.Equals(c.Subject, FilterCategory, StringComparison.OrdinalIgnoreCase)).ToList();

  protected override async Task OnInitializedAsync()
  {
    await LoadCoursesAsync();
  }

  private async Task LoadCoursesAsync()
  {
    _loading = true;
    _error = null;
    try
    {
      _courses = await Client.GetFromJsonAsync<List<ChildCourseDto>>("api/child/learning/courses") ?? new();
    }
    catch (Exception ex)
    {
      _error = ex.Message;
    }
    finally
    {
      _loading = false;
    }
  }

  private void SelectCategory(string category)
  {
    FilterCategory = category;
  }

  private void SelectSafety() => SelectCategory("Safety");
  private void SelectSocial() => SelectCategory("Social");
  private void SelectTechnology() => SelectCategory("Technology");

  private void OpenCourse(int courseId) => NavigationManager.NavigateTo($"/child/learn/course/{courseId}");
}
