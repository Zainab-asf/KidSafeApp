@namespace KidSafeApp.Components.Pages.Child
@page "/child/progress"
@inject HttpClient Client
@inject NavigationManager NavigationManager

<ChildLayout>
  <section class="ks-content">
    <div class="ks-progress-container">
      <!-- HEADER -->
      <div class="ks-card mb-4">
        <div class="d-flex align-items-start align-items-md-center justify-content-between flex-wrap gap-3">
          <div>
            <h1 class="ks-h1 mb-1">📈 Your Progress</h1>
            <p class="text-secondary">Track your learning journey and achievements</p>
          </div>
        </div>
      </div>

      <!-- STATS CARDS -->
      @if (Summary != null)
      {
        <div class="row g-3 g-md-4 mb-4">
          <div class="col-12 col-md-6 col-xl-3">
            <div class="ks-stat-card">
              <div class="ks-stat-icon" style="background: linear-gradient(135deg, #E5EEE4, #C0E1D2);">
                <span>📚</span>
              </div>
              <div class="ks-stat-content">
                <div class="ks-stat-label">Total Courses</div>
                <div class="ks-stat-number">@Summary.TotalCourses</div>
                <div class="ks-stat-subtext">@Summary.InProgressCourses in progress</div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6 col-xl-3">
            <div class="ks-stat-card">
              <div class="ks-stat-icon" style="background: linear-gradient(135deg, #C0E1D2, #C0E1D2);">
                <span>✅</span>
              </div>
              <div class="ks-stat-content">
                <div class="ks-stat-label">Completed</div>
                <div class="ks-stat-number">@Summary.CompletedCourses</div>
                <div class="ks-stat-subtext">Well done! Keep it up</div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6 col-xl-3">
            <div class="ks-stat-card">
              <div class="ks-stat-icon" style="background: linear-gradient(135deg, #DC9B9B, #DC9B9B);">
                <span>🔥</span>
              </div>
              <div class="ks-stat-content">
                <div class="ks-stat-label">Longest Streak</div>
                <div class="ks-stat-number">@Summary.LongestStreak</div>
                <div class="ks-stat-subtext">days in a row</div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6 col-xl-3">
            <div class="ks-stat-card">
              <div class="ks-stat-icon" style="background: linear-gradient(135deg, #DC9B9B, #7c3aed);">
                <span>⭐</span>
              </div>
              <div class="ks-stat-content">
                <div class="ks-stat-label">Total Points</div>
                <div class="ks-stat-number">@Summary.TotalPoints</div>
                <div class="ks-stat-subtext">@Summary.TotalLessonsCompleted lessons</div>
              </div>
            </div>
          </div>
        </div>
      }

      <!-- COURSE PROGRESS LIST -->
      <div class="ks-card">
        <header class="ks-card-header">
          <h2>Course Progress</h2>
        </header>

        @if (IsLoading)
        {
          <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--ks-green);" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
          </div>
        }
        else if (ProgressList == null || ProgressList.Count == 0)
        {
          <div class="alert alert-info">
            <strong>No courses yet!</strong> Start learning to see your progress here.
          </div>
        }
        else
        {
          <div class="row g-3 g-md-4">
            @foreach (var progress in ProgressList)
            {
              <div class="col-12 col-lg-6">
                <div class="ks-progress-card">
                  <div class="ks-progress-header">
                    <h3 class="ks-progress-title">@progress.CourseTitle</h3>
                    <span class="ks-badge" style="background-color: @GetStatusColor(progress.Status); color: white;">
                      @progress.Status
                    </span>
                  </div>

                  <div class="ks-progress-body">
                    <div class="ks-progress-info">
                      <span class="ks-progress-lessons">
                        @progress.LessonsCompleted / @progress.TotalLessons lessons
                      </span>
                    </div>

                    <div class="progress ks-progress-bar" style="height: 8px;">
                      <div class="progress-bar ks-progress-fill"
                           role="progressbar"
                           style="width: @progress.PercentageComplete%; background: linear-gradient(90deg, #E5EEE4, #C0E1D2);"
                           aria-valuenow="@progress.PercentageComplete"
                           aria-valuemin="0"
                           aria-valuemax="100">
                      </div>
                    </div>

                    <div class="ks-progress-stats">
                      <div class="stat">
                        <span class="label">Progress</span>
                        <span class="value">@progress.PercentageComplete%</span>
                      </div>
                      <div class="stat">
                        <span class="label">Points</span>
                        <span class="value">@progress.TotalPoints</span>
                      </div>
                      <div class="stat">
                        <span class="label">Streak</span>
                        <span class="value">@progress.Streak 🔥</span>
                      </div>
                    </div>

                    <div class="ks-progress-dates">
                      <small class="text-secondary">
                        Started @progress.StartDate.ToString("MMM d, yyyy")
                        @if (progress.CompletionDate.HasValue)
                        {
                          <span>• Completed @progress.CompletionDate.Value.ToString("MMM d, yyyy")</span>
                        }
                      </small>
                    </div>
                  </div>

                  <div class="ks-progress-actions">
                    <a href="/child/learn" class="btn btn-sm btn-primary">Continue Learning</a>
                  </div>
                </div>
              </div>
            }
          </div>
        }
      </div>
    </div>
  </section>
</ChildLayout>

@code {
    private List<UserProgressDto> ProgressList = new();
    private ProgressSummaryDto Summary = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProgress();
    }

    private async Task LoadProgress()
    {
        try
        {
            IsLoading = true;

            var courseResponse = await Client.GetFromJsonAsync<List<ChildCourseDto>>("api/child/learning/courses");
            var courses = courseResponse ?? new List<ChildCourseDto>();

            ProgressList = courses.Select(c => new UserProgressDto
            {
                Id = c.Id,
                CourseTitle = c.Title,
                LessonsCompleted = c.CompletedLessons,
                TotalLessons = c.LessonCount,
                PercentageComplete = c.PercentageComplete,
                StartDate = DateTime.UtcNow,
                CompletionDate = c.PercentageComplete >= 100 ? DateTime.UtcNow : null,
                Status = c.PercentageComplete >= 100 ? "Completed" : (c.PercentageComplete > 0 ? "In Progress" : "Not Started"),
                Streak = 0,
                TotalPoints = c.CompletedLessons * 10,
                LastAccessedDate = DateTime.UtcNow
            }).ToList();

            Summary = new ProgressSummaryDto
            {
                TotalCourses = ProgressList.Count,
                CompletedCourses = ProgressList.Count(p => p.Status == "Completed"),
                InProgressCourses = ProgressList.Count(p => p.Status == "In Progress"),
                TotalPoints = ProgressList.Sum(p => p.TotalPoints),
                AverageStreak = ProgressList.Count > 0 ? ProgressList.Average(p => p.Streak) : 0,
                LongestStreak = ProgressList.Count > 0 ? ProgressList.Max(p => p.Streak) : 0,
                TotalLessonsCompleted = ProgressList.Sum(p => p.LessonsCompleted)
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading progress: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string GetStatusColor(string status) => status switch
    {
        "Completed" => "#C0E1D2",
        "In Progress" => "#C0E1D2",
        _ => "#DC9B9B"
    };

    public class ProgressSummaryDto
    {
        public int TotalCourses { get; set; }
        public int CompletedCourses { get; set; }
        public int InProgressCourses { get; set; }
        public int TotalPoints { get; set; }
        public double AverageStreak { get; set; }
        public int LongestStreak { get; set; }
        public int TotalLessonsCompleted { get; set; }
    }
}
