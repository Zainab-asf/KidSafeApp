@inject NavigationManager Navigation
@inject KidSafeApp.StateManagement.RoleState RoleState

<PageTitle>KidSafe - Welcome</PageTitle>

<div class="splash-container">
    <div class="splash-content">
        <!-- Logo/Brand Section -->
        <div class="splash-logo">
            <div class="logo-icon">
                <svg viewBox="0 0 100 100" class="logo-svg">
                    <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" stroke-width="3" />
                    <path d="M30 50 L45 65 L70 35" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <h1 class="brand-name">KidSafe</h1>
            <p class="brand-tagline">English Learning Portal</p>
        </div>

        <!-- Animated Tagline -->
        <div class="splash-features">
            <div class="feature-item">
                <span class="feature-icon">🛡️</span>
                <span>Safe Learning Environment</span>
            </div>
            <div class="feature-item">
                <span class="feature-icon">📚</span>
                <span>Interactive Lessons</span>
            </div>
            <div class="feature-item">
                <span class="feature-icon">💬</span>
                <span>Protected Chat</span>
            </div>
        </div>

        <!-- Loading Indicator -->
        <div class="splash-loader">
            <div class="loader-dots">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <p class="loader-text">Loading your experience...</p>
        </div>

        <!-- Skip Button -->
        <button class="skip-btn" @onclick="SkipSplash">
            Continue to Get Started →
        </button>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Auto-navigate to role selection after 5 seconds
        await Task.Delay(5000);
        Navigation.NavigateTo("/auth", replace: true);
    }

    private void SkipSplash()
    {
        Navigation.NavigateTo("/auth", replace: true);
    }
}


