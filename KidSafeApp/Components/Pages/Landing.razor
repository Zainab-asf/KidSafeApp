@inject NavigationManager NavigationManager
@inject KidSafeApp.States.RoleState RoleState

<PageTitle>KidSafe</PageTitle>

<div class="ks-hero">
    <div class="container py-4 py-md-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10 col-xl-9">
                <div class="ks-surface shadow-sm">
                    <div class="d-flex align-items-start align-items-md-center justify-content-between gap-3 flex-wrap">
                        <div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="ks-badge">KidSafe</span>
                                <span class="text-secondary small">School mode</span>
                            </div>
                            <h1 class="mt-2 mb-2 ks-title">Choose your portal</h1>
                            <p class="mb-0 text-secondary ks-subtitle"></p>
                        </div>
                    </div>

                    <div class="row g-3 g-md-4 mt-4">
                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile">
                                <div class="ks-tile-header">
                                    <div class="ks-icon">🧒</div>
                                    <div>
                                        <div class="ks-tile-title">Child</div>
                                        <div class="ks-tile-sub">Learning, chat, progress</div>
                                    </div>
                                </div>
                                <div class="ks-tile-body">
                                    <div class="text-secondary small">Open the child portal.</div>
                                </div>
                                <div class="ks-tile-footer">
                                    <button class="btn btn-sm btn-primary" type="button" @onclick="GoToChild">Enter</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile">
                                <div class="ks-tile-header">
                                    <div class="ks-icon">👨‍👩‍👧</div>
                                    <div>
                                        <div class="ks-tile-title">Parent</div>
                                        <div class="ks-tile-sub">Monitoring & reports</div>
                                    </div>
                                </div>
                                <div class="ks-tile-body">
                                    <div class="text-secondary small">Open the parent portal.</div>
                                </div>
                                <div class="ks-tile-footer">
                                    <button class="btn btn-sm btn-primary" type="button" @onclick="GoToParent">Enter</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile">
                                <div class="ks-tile-header">
                                    <div class="ks-icon">👩‍🏫</div>
                                    <div>
                                        <div class="ks-tile-title">Teacher</div>
                                        <div class="ks-tile-sub">Lessons & activity</div>
                                    </div>
                                </div>
                                <div class="ks-tile-body">
                                    <div class="text-secondary small">Open the teacher portal.</div>
                                </div>
                                <div class="ks-tile-footer">
                                    <button class="btn btn-sm btn-primary" type="button" @onclick="GoToTeacher">Enter</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile">
                                <div class="ks-tile-header">
                                    <div class="ks-icon">🛠️</div>
                                    <div>
                                        <div class="ks-tile-title">Admin</div>
                                        <div class="ks-tile-sub">Approve users & set roles</div>
                                    </div>
                                </div>
                                <div class="ks-tile-body">
                                    <div class="text-secondary small">Requires admin login.</div>
                                </div>
                                <div class="ks-tile-footer">
                                    <button class="btn btn-sm btn-outline-primary" type="button" @onclick="GoToAdmin">Admin Login</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center justify-content-end flex-wrap gap-2 mt-4 pt-3 ks-divider">
                        <button class="btn btn-sm btn-outline-light" type="button" @onclick="GoToAdmin">Admin Login</button>
                    </div>
                </div>

                <div class="text-center text-secondary small mt-3">
                    KidSafe UI • Responsive layout • Theme-ready
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private async Task GoToChild()
    {
        RoleState.SelectRole(KidSafeApp.States.AppRole.Child);
        await RoleState.InitializeAsync(KidSafeApp.States.AppRole.Child);
        NavigationManager.NavigateTo("/child/dashboard", replace: true);
    }

    private async Task GoToParent()
    {
        RoleState.SelectRole(KidSafeApp.States.AppRole.Parent);
        await RoleState.InitializeAsync(KidSafeApp.States.AppRole.Parent);
        NavigationManager.NavigateTo("/parent/dashboard", replace: true);
    }

    private async Task GoToTeacher()
    {
        RoleState.SelectRole(KidSafeApp.States.AppRole.Teacher);
        await RoleState.InitializeAsync(KidSafeApp.States.AppRole.Teacher);
        NavigationManager.NavigateTo("/teacher/dashboard", replace: true);
    }
    private void GoToAdmin() => NavigationManager.NavigateTo("/admin-login");
}
