@inject NavigationManager NavigationManager
@inject KidSafeApp.States.RoleState RoleState

<PageTitle>KidSafe</PageTitle>

<div class="ks-hero">
    <div class="container py-4 py-md-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10 col-xl-9">
                <div class="ks-surface">
                    <div class="ks-top">
                        <div class="ks-brand">KidSafe English</div>
                        <div class="ks-brand-sub">Learning portal</div>
                    </div>

                    <div class="ks-cards row g-3 g-md-4 mt-2">
                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile ks-tile-yellow">
                                <div class="ks-tile-head">Child 🧒</div>
                                <div class="ks-tile-main">Learn & Chat</div>
                                <div class="ks-tile-stage">Safe learning space</div>
                                <button class="btn btn-sm ks-tile-btn" type="button" @onclick="GoToChild">Enter</button>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile ks-tile-green">
                                <div class="ks-tile-head">Parent 👨‍👩‍👧</div>
                                <div class="ks-tile-main">Track Child Progress</div>
                                <div class="ks-tile-stage">Reports & updates</div>
                                <button class="btn btn-sm ks-tile-btn ks-tile-btn-light" type="button" @onclick="GoToParent">Enter</button>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile ks-tile-yellow">
                                <div class="ks-tile-head">Teacher 👩‍🏫</div>
                                <div class="ks-tile-main">Manage Class & Lessons</div>
                                <div class="ks-tile-stage">Students & assignments</div>
                                <button class="btn btn-sm ks-tile-btn" type="button" @onclick="GoToTeacher">Enter</button>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="ks-tile ks-tile-green">
                                <div class="ks-tile-head">Admin 🛡️</div>
                                <div class="ks-tile-main">Manage Users & Roles</div>
                                <div class="ks-tile-stage">System administration</div>
                                <button class="btn btn-sm ks-tile-btn ks-tile-btn-outline" type="button" @onclick="GoToAdmin">Admin Login</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Task GoToChild()
    {
        NavigationManager.NavigateTo("/login/child", replace: true);
        return Task.CompletedTask;
    }

    private Task GoToParent()
    {
        NavigationManager.NavigateTo("/login/parent", replace: true);
        return Task.CompletedTask;
    }

    private Task GoToTeacher()
    {
        NavigationManager.NavigateTo("/login/teacher", replace: true);
        return Task.CompletedTask;
    }
    private void GoToAdmin() => NavigationManager.NavigateTo("/login", replace: true);
}
