@page "/messages"

<div class="ks-chat-layout">
  <div class="ks-chat-header">
    <h1>Messages</h1>
    <p class="ks-chat-subtitle">Chat safely with your friends in KidSafe.</p>
  </div>

  <div class="ks-chat-card">
    <div class="ks-chat-messages">
      @if (messages.Count == 0)
      {
        <div class="ks-chat-empty">
          <p>No messages yet. Say hi to start the conversation.</p>
        </div>
      }
      else
      {
        @foreach (var message in messages)
        {
          <div class="ks-chat-message @(message.IsMine ? "ks-chat-message-mine" : "ks-chat-message-other")">
            <div class="ks-chat-meta">
              <span class="ks-chat-author">@message.Author</span>
              <span class="ks-chat-time">@message.Timestamp.ToShortTimeString()</span>
            </div>
            <div class="ks-chat-text">@message.Text</div>
          </div>
        }
      }
    </div>

    <div class="ks-chat-input-row">
      <input @bind="messageInput" @bind:event="oninput" class="ks-chat-input" placeholder="Type a message..." />
      <button class="ks-chat-send" @onclick="SendMessage">Send</button>
    </div>
  </div>
</div>

@code {
  private readonly List<ChatMessage> messages = new();
  private string messageInput = string.Empty;

  protected override void OnInitialized()
  {
    // Seed with a few demo messages so the page feels alive.
    messages.Add(new ChatMessage("Zainab", "Hi there! Welcome to KidSafe.", false));
    messages.Add(new ChatMessage("You", "Thanks! I am ready to learn.", true));
  }

  private void SendMessage()
  {
    if (string.IsNullOrWhiteSpace(messageInput))
    {
      return;
    }

    messages.Add(new ChatMessage("You", messageInput, true));
    messageInput = string.Empty;
  }

  private sealed class ChatMessage
  {
    public ChatMessage(string author, string text, bool isMine)
    {
      Author = author;
      Text = text;
      IsMine = isMine;
      Timestamp = DateTime.Now;
    }

    public string Author { get; }
    public string Text { get; }
    public bool IsMine { get; }
    public DateTime Timestamp { get; }
  }
}
