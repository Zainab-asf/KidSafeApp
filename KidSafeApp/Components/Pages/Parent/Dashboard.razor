@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/dashboard"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject ParentDashboardApiClient ParentApiClient
@inject KidSafeApp.States.AuthenticationState AuthState

@if (!AuthState.IsAuthenticated)
{
    <NavigateTo href="/login/parent" replace="true" />
}
else if (!string.Equals(AuthState.User?.Role, "Parent", StringComparison.OrdinalIgnoreCase))
{
    <NavigateTo href="/unauthorized" replace="true" />
}

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<div class="parent-shell">
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    <section class="hero-card">
        <div class="hero-avatar">👧</div>
        <div class="hero-copy">
            <div class="hero-greeting">Hello, @(_parentName) 👋</div>
            <div class="hero-title">Monitoring @_childName</div>
            <div class="hero-subtitle">Grade @_childGrade • @_safeStreak-day safe streak</div>
        </div>
        <div class="hero-score">
            <div class="hero-score-value">@_safeRate%</div>
            <small>Safe Rate</small>
        </div>
    </section>

    <section class="stats-grid">
        <article class="stat-card stat-red">
            <div class="stat-icon">🚩</div>
            <div class="stat-value">@_flaggedCount</div>
            <div class="stat-label">Flagged</div>
        </article>
        <article class="stat-card stat-yellow">
            <div class="stat-icon">🔔</div>
            <div class="stat-value">@_unreadAlerts</div>
            <div class="stat-label">Unread Alerts</div>
        </article>
        <article class="stat-card stat-green">
            <div class="stat-icon">🏅</div>
            <div class="stat-value">@_badgesEarned</div>
            <div class="stat-label">Badges Earned</div>
        </article>
    </section>

    <section class="panel-card">
        <h3>Child's Progress This Week</h3>
        <div class="progress-line">
            <div class="progress-row">
                <span>Safe Messages</span>
                <strong>@_safeMessages</strong>
            </div>
            <div class="progress-track"><div class="progress-fill green" style="width:@_safeBar%"></div></div>
        </div>
        <div class="progress-line">
            <div class="progress-row">
                <span>Flagged Events</span>
                <strong>@_flaggedCount</strong>
            </div>
            <div class="progress-track"><div class="progress-fill yellow" style="width:@_flaggedBar%"></div></div>
        </div>
        <div class="progress-line">
            <div class="progress-row">
                <span>Badges Earned</span>
                <strong>@_badgesEarned</strong>
            </div>
            <div class="progress-track"><div class="progress-fill blue" style="width:@_badgeBar%"></div></div>
        </div>
    </section>

    <section class="panel-card">
        <h3>Weekly Activity</h3>
        <div class="weekly-chart">
            @foreach (var day in _weekly)
            {
                <div class="week-col">
                    <div class="bar-stack">
                        <div class="bar-block safe" style="height:@day.SafeHeight%"></div>
                        <div class="bar-block flagged" style="height:@day.FlaggedHeight%"></div>
                        <div class="bar-block blocked" style="height:@day.BlockedHeight%"></div>
                    </div>
                    <small>@day.Day</small>
                </div>
            }
        </div>
        <div class="chart-legend">
            <span><i class="dot safe"></i> Safe</span>
            <span><i class="dot flagged"></i> Flagged</span>
            <span><i class="dot blocked"></i> Blocked</span>
        </div>
    </section>

    <section class="quick-grid">
        <button class="quick-card quick-primary" @onclick="GoToProgress">
            <div>
                <div class="quick-title">View Reports</div>
                <small>@_newFlags new flags</small>
            </div>
        </button>
        <button class="quick-card" @onclick="GoToFlagged">
            <div>
                <div class="quick-title">Flagged Messages</div>
                <small>Review high-risk activity</small>
            </div>
        </button>
        <button class="quick-card" @onclick="GoToNotifications">
            <div>
                <div class="quick-title">View Alerts</div>
                <small>@_unreadAlerts unread alerts</small>
            </div>
        </button>
        <button class="quick-card" @onclick="GoToSettings">
            <div>
                <div class="quick-title">Manage Filters</div>
                <small>Custom keywords</small>
            </div>
        </button>
    </section>
</div>
}

@code {
    private string? _error;
    private IReadOnlyList<NotificationDto> _notifications = Array.Empty<NotificationDto>();
    private string _parentName = "Fatima";
    private string _childName = "Ali Hassan";
    private string _childGrade = "Grade 5A";
    private int _safeRate = 91;
    private int _flaggedCount;
    private int _unreadAlerts;
    private int _badgesEarned;
    private int _safeMessages;
    private int _safeBar;
    private int _flaggedBar;
    private int _badgeBar;
    private int _safeStreak = 5;
    private int _newFlags = 2;

    private readonly List<WeeklyPoint> _weekly = new()
    {
        new("Mon", 70, 8, 1),
        new("Tue", 88, 5, 1),
        new("Wed", 62, 10, 1),
        new("Thu", 95, 3, 1),
        new("Fri", 66, 7, 1),
        new("Sat", 45, 4, 1),
        new("Sun", 30, 2, 1)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _notifications = await ParentApiClient.GetNotificationsAsync();

            _flaggedCount = Math.Max(0, _notifications.Count(ParentDashboardApiClient.IsFlaggedSignal));
            _unreadAlerts = _notifications.Count(n => !n.IsRead);
            _badgesEarned = Math.Max(0, _notifications.Count(n => (n.Title ?? string.Empty).Contains("badge", StringComparison.OrdinalIgnoreCase)));
            _safeMessages = 163;
            _safeBar = 100;
            _flaggedBar = 40;
            _badgeBar = 70;
            _safeRate = 91;
            _newFlags = Math.Max(0, _notifications.Count(n => !n.IsRead && ParentDashboardApiClient.IsFlaggedSignal(n)));
            _safeStreak = 5;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void GoToNotifications() => NavigationManager.NavigateTo("/parent/notifications");
    private void GoToFlagged() => NavigationManager.NavigateTo("/parent/flagged");
    private void GoToProgress() => NavigationManager.NavigateTo("/parent/progress");
    private void GoToSettings() => NavigationManager.NavigateTo("/parent/settings");

    private sealed record WeeklyPoint(string Day, int SafeHeight, int FlaggedHeight, int BlockedHeight);
}
