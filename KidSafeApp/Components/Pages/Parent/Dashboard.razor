@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/dashboard"
@using KidSafeApp.Services

<PageTitle>Parent Safety Dashboard</PageTitle>

@inject KidSafeApp.StateManagement.RoleState RoleState
@inject NavigationManager NavigationManager
@inject ParentDashboardApiClient ParentApiClient
@inject KidSafeApp.StateManagement.AuthenticationState AuthState

@if (!AuthState.IsAuthenticated)
{
    <NavigateTo href="/login/parent" replace="true" />
}
else if (!string.Equals(AuthState.User?.Role, "Parent", StringComparison.OrdinalIgnoreCase))
{
    <NavigateTo href="/login/parent" replace="true" />
}

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<ParentPageShell>
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--ks-green);" role="status"></div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }
    else
    {

    <section class="hero-card">
        <div class="hero-avatar">👧</div>
        <div class="hero-copy">
            <div class="hero-greeting">Hello, @(_dashboard?.ParentName ?? string.Empty) 👋</div>
            <div class="hero-title">
                @if (_dashboard?.HasLinkedChild == true)
                {
                    <span>Monitoring @_dashboard.ChildName</span>
                }
                else
                {
                    <span>No linked child</span>
                }
            </div>
            <div class="hero-subtitle">@HeroSubtitle</div>
        </div>
        <div class="hero-score">
            <div class="hero-score-value">@(_dashboard?.SafeRate ?? 0)%</div>
            <small>Safe Rate</small>
        </div>
    </section>

    <section class="stats-grid">
        <article class="stat-card stat-red">
            <div class="stat-icon">🚩</div>
            <div class="stat-value">@(_dashboard?.FlaggedCount ?? 0)</div>
            <div class="stat-label">Flagged</div>
        </article>
        <article class="stat-card stat-yellow">
            <div class="stat-icon">🔔</div>
            <div class="stat-value">@(_dashboard?.UnreadAlerts ?? 0)</div>
            <div class="stat-label">Unread Alerts</div>
        </article>
        <article class="stat-card stat-green">
            <div class="stat-icon">🏅</div>
            <div class="stat-value">@(_dashboard?.BadgesEarned ?? 0)</div>
            <div class="stat-label">Badges Earned</div>
        </article>
    </section>

    <section class="panel-card">
        <h3>Child's Progress This Week</h3>
        <div class="progress-line">
            <div class="progress-row">
                <span>Safe Messages</span>
                <strong>@(_dashboard?.SafeMessages ?? 0)</strong>
            </div>
            <div class="progress-track"><div class="progress-fill green" style="width:@(_dashboard?.SafeBar ?? 0)%"></div></div>
        </div>
        <div class="progress-line">
            <div class="progress-row">
                <span>Flagged Events</span>
                <strong>@(_dashboard?.FlaggedCount ?? 0)</strong>
            </div>
            <div class="progress-track"><div class="progress-fill yellow" style="width:@(_dashboard?.FlaggedBar ?? 0)%"></div></div>
        </div>
        <div class="progress-line">
            <div class="progress-row">
                <span>Badges Earned</span>
                <strong>@(_dashboard?.BadgesEarned ?? 0)</strong>
            </div>
            <div class="progress-track"><div class="progress-fill blue" style="width:@(_dashboard?.BadgeBar ?? 0)%"></div></div>
        </div>
    </section>

    <section class="panel-card">
        <h3>Weekly Activity</h3>
        <div class="weekly-chart">
            @foreach (var day in _dashboard?.Weekly ?? new List<WeeklyPointDto>())
            {
                <div class="week-col">
                    <div class="bar-stack">
                        <div class="bar-block safe" style="height:@day.Safe%"></div>
                        <div class="bar-block flagged" style="height:@day.Flagged%"></div>
                        <div class="bar-block blocked" style="height:@day.Blocked%"></div>
                    </div>
                    <small>@day.Day</small>
                </div>
            }
        </div>
        <div class="chart-legend">
            <span><i class="dot safe"></i> Safe</span>
            <span><i class="dot flagged"></i> Flagged</span>
            <span><i class="dot blocked"></i> Blocked</span>
        </div>
    </section>

    <section class="quick-grid">
        <button class="quick-card quick-primary" @onclick="GoToProgress">
            <div>
                <div class="quick-title">View Reports</div>
                <small>@(_dashboard?.NewFlags ?? 0) new flags</small>
            </div>
        </button>
        <button class="quick-card" @onclick="GoToFlagged">
            <div>
                <div class="quick-title">Flagged Messages</div>
                <small>Review high-risk activity</small>
            </div>
        </button>
        <button class="quick-card" @onclick="GoToNotifications">
            <div>
                <div class="quick-title">View Alerts</div>
                <small>@(_dashboard?.UnreadAlerts ?? 0) unread alerts</small>
            </div>
        </button>
        <button class="quick-card" @onclick="GoToSettings">
            <div>
                <div class="quick-title">Manage Filters</div>
                <small>Custom keywords</small>
            </div>
        </button>
    </section>

    <section class="parent-enhanced-grid">
        <article class="panel-card parent-insights-card">
            <h3>Safety Overview</h3>
            <div class="parent-insight-row">
                <span>Safe Rate</span>
                <strong>@(_dashboard?.SafeRate ?? 0)%</strong>
            </div>
            <div class="parent-insight-row">
                <span>Unread Alerts</span>
                <strong>@(_dashboard?.UnreadAlerts ?? 0)</strong>
            </div>
            <div class="parent-insight-row">
                <span>Flagged Signals</span>
                <strong>@(_dashboard?.FlaggedCount ?? 0)</strong>
            </div>
            <div class="parent-insight-row">
                <span>Safe Streak</span>
                <strong>@(_dashboard?.SafeStreak ?? 0) days</strong>
            </div>
            <a class="parent-link-btn" href="/parent/progress">See detailed report</a>
        </article>

        <article class="panel-card parent-recent-card">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                <h3 class="m-0">Recent Alerts</h3>
                <a class="parent-link-inline" href="/parent/notifications">View all</a>
            </div>

            @if (_dashboard is null || _dashboard.RecentAlerts.Count == 0)
            {
                <div class="parent-empty-state">No recent alerts.</div>
            }
            else
            {
                <div class="parent-recent-list">
                    @foreach (var alert in _dashboard.RecentAlerts)
                    {
                        <div class="parent-recent-item">
                            <div class="parent-recent-meta">
                                <strong>@alert.Title</strong>
                                <small>@alert.CreatedAt.ToLocalTime().ToString("g")</small>
                            </div>
                            <span class="parent-alert-badge @GetAlertBadgeClass(alert)">@GetAlertBadgeText(alert)</span>
                        </div>
                    }
                </div>
            }
        </article>
    </section>
    }
</ParentPageShell>
}

@code {
    private string? _error;
    private ParentDashboardDto? _dashboard;
    private bool _loading = true;

    private string HeroSubtitle
        => _dashboard?.HasLinkedChild == true
            ? $"{_dashboard.ChildGrade} • {_dashboard.SafeStreak}-day safe streak"
            : "Link a child to see progress";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _dashboard = await ParentApiClient.GetDashboardAsync();
            if (_dashboard is null)
            {
                _dashboard = new ParentDashboardDto();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToNotifications() => NavigationManager.NavigateTo("/parent/notifications");
    private void GoToFlagged() => NavigationManager.NavigateTo("/parent/flagged");
    private void GoToProgress() => NavigationManager.NavigateTo("/parent/progress");
    private void GoToSettings() => NavigationManager.NavigateTo("/parent/settings");

    private static string GetAlertBadgeText(NotificationDto alert)
    {
        var title = alert.Title ?? string.Empty;
        if (ParentDashboardApiClient.IsFlaggedSignal(alert)) return "Flagged";
        if (title.Contains("badge", StringComparison.OrdinalIgnoreCase)) return "Achievement";
        return "Info";
    }

    private static string GetAlertBadgeClass(NotificationDto alert)
    {
        var title = alert.Title ?? string.Empty;
        if (ParentDashboardApiClient.IsFlaggedSignal(alert)) return "badge-flagged";
        if (title.Contains("badge", StringComparison.OrdinalIgnoreCase)) return "badge-achievement";
        return "badge-info";
    }

    private sealed record WeeklyPoint(string Day, int SafeHeight, int FlaggedHeight, int BlockedHeight);
}