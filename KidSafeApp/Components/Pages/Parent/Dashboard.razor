@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/dashboard"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject HttpClient Client
@inject KidSafeApp.States.AuthenticationState AuthState

@if (!AuthState.IsAuthenticated)
{
    <NavigateTo href="/login/parent" replace="true" />
}
else if (!string.Equals(AuthState.User?.Role, "Parent", StringComparison.OrdinalIgnoreCase))
{
    <NavigateTo href="/unauthorized" replace="true" />
}

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<div class="portal">
    <header class="portal-header">
        <div>
            <h1 class="portal-title">Parent Portal 👨‍👩‍👧</h1>
            <div class="portal-subtitle">Simple updates to support your child every day.</div>
        </div>

        <div class="portal-actions">
            <button class="btn btn-outline-secondary" type="button" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" type="button" @onclick="HandleLogout">Logout</button>
        </div>
    </header>

    <section class="portal-grid">
        <div class="portal-card">
            <div class="portal-card-title">Today’s Screen Time ⏱️</div>
            <div class="portal-stat">@_screenTimeToday</div>
            <div class="portal-muted">Based on tracked learning activity</div>
        </div>

        <div class="portal-card">
            <div class="portal-card-title">Safety Alerts 🚨</div>
            <div class="portal-stat">@_safetyAlerts</div>
            <div class="portal-muted">Derived from unread parent alerts</div>
        </div>

        <div class="portal-card">
            <div class="portal-card-title">Learning Progress 📘</div>
            <div class="portal-stat">@_avgProgress%</div>
            <div class="portal-muted">Average across published courses</div>
        </div>

        <div class="portal-card">
            <div class="portal-card-title">Recent Activity 📌</div>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="small text-danger">@_error</div>
            }
            else if (_loading)
            {
                <div class="small text-secondary">Loading...</div>
            }
            else if (_courses.Count == 0)
            {
                <div class="small text-secondary">No activity yet.</div>
            }
            else
            {
                <ul class="portal-list">
                    @foreach (var c in _courses.OrderByDescending(x => x.PercentageComplete).Take(3))
                    {
                        <li>@c.Title: @c.PercentageComplete% complete</li>
                    }
                </ul>
            }
        </div>
    </section>

    <section class="portal-wide">
        <div class="portal-card portal-card-wide">
            <div class="portal-card-title">Quick Controls ⚙️</div>
            <div class="portal-controls">
                <button class="btn btn-primary" type="button" @onclick="GoToSettings">Set Screen Time Limit</button>
                <button class="btn btn-outline-primary" type="button" @onclick="GoToProgress">View Progress</button>
                <button class="btn btn-outline-primary" type="button" @onclick="GoToNotifications">View Alerts</button>
            </div>
        </div>
    </section>
</div>
}

@code {
    [Parameter] public int? ChildId { get; set; }

    private bool _loading;
    private string? _error;
    private List<ChildCourseDto> _courses = new();
    private List<NotificationDto> _notifications = new();
    private int _avgProgress;
    private int _safetyAlerts;
    private string _screenTimeToday = "0m";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var courseUrl = ChildId.HasValue
                ? $"api/child/learning/courses?childId={ChildId.Value}"
                : "api/child/learning/courses";
            _courses = await Client.GetFromJsonAsync<List<ChildCourseDto>>(courseUrl) ?? new();
            _notifications = await Client.GetFromJsonAsync<List<NotificationDto>>("api/notifications?unreadOnly=true&role=Parent") ?? new();

            _avgProgress = _courses.Count == 0 ? 0 : (int)Math.Round(_courses.Average(c => c.PercentageComplete));
            _safetyAlerts = _notifications.Count;

            var estimatedMinutes = _courses.Sum(c => c.CompletedLessons * 10);
            _screenTimeToday = estimatedMinutes >= 60
                ? $"{estimatedMinutes / 60}h {estimatedMinutes % 60}m"
                : $"{estimatedMinutes}m";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleBack()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }

    private void GoToNotifications() => NavigationManager.NavigateTo("/parent/notifications");

    private void GoToProgress() => NavigationManager.NavigateTo("/parent/progress");

    private void GoToSettings() => NavigationManager.NavigateTo("/parent/settings");
}
