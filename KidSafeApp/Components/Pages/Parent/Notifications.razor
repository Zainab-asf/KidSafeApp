@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/notifications"
@using KidSafeApp.Services

@inject KidSafeApp.StateManagement.RoleState RoleState
@inject NavigationManager NavigationManager
@inject ParentDashboardApiClient ParentApiClient

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<ParentPageShell Title="Notifications">

    <div class="filters-row">
        <button class='filter-pill @(string.Equals(_activeFilter, "all", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)'
                @onclick='() => SetFilter("all")'>
            All (@_alerts.Count)
        </button>
        <button class='filter-pill @(string.Equals(_activeFilter, "unread", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)'
                @onclick='() => SetFilter("unread")'>
            Unread (@_alerts.Count(a => !a.IsRead))
        </button>
        <button class="mark-read-link" @onclick="MarkAllAsRead">Mark all read</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="notification-list">
        @if (_loading)
        {
            <div class="panel-card">Loading alerts...</div>
        }
        else if (!FilteredAlerts.Any())
        {
            <div class="panel-card">No alerts right now. You're all caught up! 🎉</div>
        }
        else
        {
            @foreach (var alert in FilteredAlerts)
            {
                <div class="notif-card @GetNotifClass(alert)" @onclick="() => MarkAsRead(alert)">
                    <div class="notif-icon">@GetNotifIcon(alert)</div>
                    <div class="notif-copy">
                        <div class="notif-title">@alert.Title</div>
                        <div class="notif-message">@alert.Message</div>
                        <div class="notif-meta">@alert.CreatedAt.ToLocalTime().ToString("g")</div>
                    </div>
                    <div class="notif-dot @(alert.IsRead ? "read" : "")"></div>
                </div>
            }
        }
    </div>

</ParentPageShell>
}

@code {
    private bool _loading;
    private string? _error;
    private readonly List<NotificationDto> _alerts = new();
    private string _activeFilter = "unread";

    private IEnumerable<NotificationDto> FilteredAlerts => _activeFilter switch
    {
        "all" => _alerts,
        _     => _alerts.Where(a => !a.IsRead)
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        _alerts.Clear();
        try
        {
            var notifications = await ParentApiClient.GetNotificationsAsync();
            _alerts.AddRange(notifications.OrderByDescending(x => x.CreatedAt));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetFilter(string filter) => _activeFilter = filter;

    private async Task MarkAllAsRead()
    {
        try
        {
            await ParentApiClient.MarkAllNotificationsAsReadAsync();
            foreach (var alert in _alerts) alert.IsRead = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task MarkAsRead(NotificationDto alert)
    {
        if (alert.IsRead) return;
        try
        {
            await ParentApiClient.MarkNotificationAsReadAsync(alert.Id);
            alert.IsRead = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private string GetNotifClass(NotificationDto alert)
    {
        var title = alert.Title ?? string.Empty;
        if (title.Contains("Block", StringComparison.OrdinalIgnoreCase)) return "blocked";
        if (title.Contains("Flag",  StringComparison.OrdinalIgnoreCase)) return "flagged";
        if (title.Contains("Badge", StringComparison.OrdinalIgnoreCase)) return "badge";
        return string.Empty;
    }

    private string GetNotifIcon(NotificationDto alert)
    {
        var title = alert.Title ?? string.Empty;
        if (title.Contains("Block", StringComparison.OrdinalIgnoreCase)) return "⛔";
        if (title.Contains("Flag",  StringComparison.OrdinalIgnoreCase)) return "🚩";
        if (title.Contains("Badge", StringComparison.OrdinalIgnoreCase)) return "🏅";
        return "🔔";
    }
}


