@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/notifications"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject HttpClient Client

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<div class="container py-3 parent-module">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h4 mb-1">Parent Notifications</h1>
            <div class="text-secondary">Recent alerts and system updates</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h6">Unread Alerts</h2>
            @if (_loading)
            {
                <div class="text-secondary">Loading alerts...</div>
            }
            else if (_alerts.Count == 0)
            {
                <div class="text-secondary">No alerts right now.</div>
            }
            else
            {
                <ul class="mb-0">
                    @foreach (var alert in _alerts)
                    {
                        <li>
                            <strong>@alert.Title</strong>: @alert.Message
                            <span class="small text-secondary">(@alert.CreatedAt.ToLocalTime().ToString("g"))</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h6">Actions</h2>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" @onclick="MarkAllAsRead">Mark all as read</button>
                <button class="btn btn-outline-primary" @onclick="HandleGoToSettings">Notification preferences</button>
            </div>
        </div>
    </div>
</div>
}

@code {
    private bool _loading;
    private string? _error;
    private readonly List<NotificationDto> _alerts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _alerts.Clear();
        try
        {
            var notifications = await Client.GetFromJsonAsync<List<NotificationDto>>("api/notifications?unreadOnly=true&role=Parent") ?? new();

            if (notifications.Count == 0)
            {
                await SeedNotificationsFromProgressAsync();
                notifications = await Client.GetFromJsonAsync<List<NotificationDto>>("api/notifications?unreadOnly=true&role=Parent") ?? new();
            }

            _alerts.AddRange(notifications);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task MarkAllAsRead()
    {
        try
        {
            await Client.PutAsync("api/notifications/mark-all-as-read?role=Parent", null);
            _alerts.Clear();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SeedNotificationsFromProgressAsync()
    {
        var courses = await Client.GetFromJsonAsync<List<ChildCourseDto>>("api/child/learning/courses") ?? new();
        foreach (var c in courses)
        {
            var message = c.PercentageComplete == 0
                ? $"{c.Title} has not started yet."
                : c.PercentageComplete < 100
                    ? $"{c.Title} is in progress at {c.PercentageComplete}%."
                    : $"{c.Title} has been completed successfully.";

            var payload = new
            {
                Title = "Learning Update",
                Message = message,
                Type = c.PercentageComplete >= 100 ? "Achievement" : "Info",
                ActionUrl = "/parent/progress"
            };

            await Client.PostAsJsonAsync("api/notifications/send?role=Parent", payload);
        }
    }

    private void HandleGoToSettings() => NavigationManager.NavigateTo("/parent/settings");

    private void HandleBack() => NavigationManager.NavigateTo("/parent/dashboard");

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
