@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/notifications"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager

@if (!RoleState.IsRoleLoaded)
{
    <Components.Shared.RoleLoading />
}
else
{
<div class="container py-3 parent-module">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h4 mb-1">Parent Notifications</h1>
            <div class="text-secondary">Recent alerts and system updates</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h6">Unread Alerts</h2>
            <ul class="mb-0">
                <li>Screen time limit exceeded (Today, 4:20 PM)</li>
                <li>New message from teacher (Today, 2:10 PM)</li>
                <li>Progress milestone reached (Yesterday)</li>
            </ul>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h6">Actions</h2>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary">Mark all as read</button>
                <button class="btn btn-outline-primary">Notification preferences</button>
            </div>
        </div>
    </div>
</div>
}

@code {
    private void HandleBack() => NavigationManager.NavigateTo("/parent/dashboard");

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
