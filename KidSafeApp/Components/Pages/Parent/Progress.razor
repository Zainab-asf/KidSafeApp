@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/progress"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject HttpClient Client

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<div class="container py-3 parent-module">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h4 mb-1">Parent Progress</h1>
            <div class="text-secondary">Track learning outcomes and weekly performance</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="row g-3">
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Completed Courses</div><div class="display-6 fw-bold">@_completedCourses</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Average Progress</div><div class="display-6 fw-bold">@_avgProgress%</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Total Lessons</div><div class="display-6 fw-bold">@_totalLessons</div></div></div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h2 class="h6">Recent Progress</h2>
            @if (_loading)
            {
                <div class="text-secondary">Loading...</div>
            }
            else if (_courses.Count == 0)
            {
                <div class="text-secondary">No learning data available yet.</div>
            }
            else
            {
                <ul class="mb-0">
                    @foreach (var c in _courses.OrderByDescending(c => c.PercentageComplete).Take(8))
                    {
                        <li>@c.Title - @c.PercentageComplete% (@c.CompletedLessons/@c.LessonCount lessons)</li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
}

@code {
    private bool _loading;
    private string? _error;
    private List<ChildCourseDto> _courses = new();
    private int _completedCourses;
    private int _avgProgress;
    private int _totalLessons;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _courses = await Client.GetFromJsonAsync<List<ChildCourseDto>>("api/child/learning/courses") ?? new();
            _completedCourses = _courses.Count(c => c.PercentageComplete >= 100);
            _avgProgress = _courses.Count == 0 ? 0 : (int)Math.Round(_courses.Average(c => c.PercentageComplete));
            _totalLessons = _courses.Sum(c => c.LessonCount);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleBack() => NavigationManager.NavigateTo("/parent/dashboard");

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
