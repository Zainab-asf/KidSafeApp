@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/settings"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject ParentDashboardApiClient ParentApiClient

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<ParentPageShell Title="Filters & Settings">

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger mt-3">@_error</div>
        }

        <section class="panel-card">
            <h3>Notification Preferences</h3>
            <div class="setting-list">
                <div class="setting-row">
                    <div>
                        <div class="setting-title">Email Alerts</div>
                        <small>Receive alerts via email</small>
                    </div>
                    <input class="form-check-input" type="checkbox" @bind="_settings.EmailNotificationsEnabled" />
                </div>

                <div class="setting-row">
                    <div>
                        <div class="setting-title">SMS Alerts</div>
                        <small>Receive alerts via SMS</small>
                    </div>
                    <input class="form-check-input" type="checkbox" @bind="_settings.PushNotificationsEnabled" />
                </div>

                <div class="setting-row">
                    <div>
                        <div class="setting-title">Blocked Messages</div>
                        <small>Alert when a message is blocked</small>
                    </div>
                    <input class="form-check-input" type="checkbox" @bind="_settings.BlockAdultContent" />
                </div>

                <div class="setting-row">
                    <div>
                        <div class="setting-title">Flagged Messages</div>
                        <small>Alert when a message is flagged</small>
                    </div>
                    <input class="form-check-input" type="checkbox" @bind="_settings.RequireParentApprovalForMessages" />
                </div>

                <div class="setting-row">
                    <div>
                        <div class="setting-title">Badge Earned</div>
                        <small>Alert when child earns a badge</small>
                    </div>
                    <input class="form-check-input" type="checkbox" @bind="_settings.AchievementNotifications" />
                </div>

                <div class="setting-row">
                    <div>
                        <div class="setting-title">Daily Report</div>
                        <small>Receive daily activity summary</small>
                    </div>
                    <input class="form-check-input" type="checkbox" @bind="_settings.MessageNotifications" />
                </div>

                <div class="setting-row">
                    <div>
                        <div class="setting-title">Weekly Report</div>
                        <small>Receive weekly safety report</small>
                    </div>
                    <input class="form-check-input" type="checkbox" @bind="_settings.CourseReminderNotifications" />
                </div>
            </div>
        </section>

        <section class="panel-card">
            <h3>Custom Alert Keywords</h3>
            <div class="keyword-box">
                <input class="form-control" placeholder="Add a keyword..." @bind="_keyword" />
                <button class="btn btn-success" @onclick="AddKeyword">Add</button>
            </div>
            <div class="keyword-list mt-3">
                @foreach (var keyword in _keywords)
                {
                    <div class="keyword-item">
                        <span>@keyword</span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-success" @onclick='() => ToggleKeyword(keyword)'>@(_keywordEnabled.Contains(keyword) ? "On" : "Off")</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick='() => RemoveKeyword(keyword)'>🗑️</button>
                        </div>
                    </div>
                }
            </div>
        </section>

        <div class="quick-grid">
            <button class="quick-card quick-primary" @onclick="SaveSettingsAsync">
                <div>
                    <div class="quick-title">Save Settings</div>
                    <small>@(_saving ? "Saving..." : "Apply all changes")</small>
                </div>
            </button>
            <button class="quick-card" @onclick="HandleBack">
                <div>
                    <div class="quick-title">Back to Dashboard</div>
                    <small>Return to overview</small>
                </div>
            </button>
        </div>
</ParentPageShell>
}

@code {
    private UserSettingsDto _settings = new()
    {
        ThemePreference = "light",
        LanguagePreference = "en",
        ParentEmail = string.Empty,
        Bio = string.Empty,
        AvatarUrl = string.Empty
    };

    private bool _saving;
    private string? _error;
    private string _keyword = string.Empty;
    private readonly List<string> _keywords = new() { "fight", "hate", "bully", "skip class" };
    private readonly HashSet<string> _keywordEnabled = new(StringComparer.OrdinalIgnoreCase) { "fight", "hate", "bully" };

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _error = null;
        try
        {
            _settings = await ParentApiClient.GetSettingsAsync() ?? _settings;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SaveSettingsAsync()
    {
        _error = null;
        _saving = true;
        try
        {
            var updated = await ParentApiClient.SaveSettingsAsync(_settings);
            if (updated is not null)
            {
                _settings = updated;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void AddKeyword()
    {
        var value = _keyword.Trim();
        if (string.IsNullOrWhiteSpace(value) || _keywords.Contains(value, StringComparer.OrdinalIgnoreCase)) return;
        _keywords.Add(value);
        _keywordEnabled.Add(value);
        _keyword = string.Empty;
    }

    private void ToggleKeyword(string keyword)
    {
        if (_keywordEnabled.Contains(keyword)) _keywordEnabled.Remove(keyword);
        else _keywordEnabled.Add(keyword);
    }

    private void RemoveKeyword(string keyword)
    {
        _keywords.RemoveAll(x => string.Equals(x, keyword, StringComparison.OrdinalIgnoreCase));
        _keywordEnabled.Remove(keyword);
    }

    private void HandleBack() => NavigationManager.NavigateTo("/parent/dashboard");
}
