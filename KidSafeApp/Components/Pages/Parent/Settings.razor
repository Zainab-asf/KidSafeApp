@namespace KidSafeApp.Components.Pages.Parent
@page "/parent/settings"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager

@if (!RoleState.IsRoleLoaded)
{
    <Components.Shared.RoleLoading />
}
else
{
<div class="container py-3 parent-module">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h4 mb-1">Parent Settings</h1>
            <div class="text-secondary">Configure controls and notifications</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h6">Safety Controls</h2>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" checked />
                <label class="form-check-label">Block mature content</label>
            </div>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" checked />
                <label class="form-check-label">Require approval for new contacts</label>
            </div>
            <label class="form-label mt-2">Daily screen time limit (minutes)</label>
            <input class="form-control" type="number" value="120" />
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h6">Notifications</h2>
            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" checked />
                <label class="form-check-label">Email alerts</label>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" checked />
                <label class="form-check-label">Push alerts</label>
            </div>
            <button class="btn btn-primary mt-3">Save Settings</button>
        </div>
    </div>
</div>
}

@code {
    private void HandleBack() => NavigationManager.NavigateTo("/parent/dashboard");

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
