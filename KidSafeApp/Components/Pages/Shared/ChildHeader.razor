@namespace KidSafeApp.Components.Pages.Shared

@inject KidSafeApp.States.AuthenticationState AuthState

<header class="ks-header">
  <div>
    <div class="ks-greeting-label">Hello,</div>
    <div class="ks-greeting-name">@DisplayName</div>
  </div>

  <div class="ks-header-actions">
    <button class="ks-icon-button" type="button" title="Back" @onclick="OnBack">
      ←
    </button>
    <button class="ks-icon-button" type="button" title="Logout" @onclick="OnLogout">
      ⎋
    </button>
    <button class="ks-icon-button ks-menu-button" type="button" title="Menu" @onclick="OnToggleMenu">
      ☰
    </button>
    <div class="ks-profile">
      <div class="ks-avatar">@AvatarLetter</div>
      <div class="ks-profile-text">
        <div class="ks-profile-name">@DisplayName</div>
        <div class="ks-profile-email">@RoleLabel</div>
      </div>
    </div>
  </div>
</header>

@code {
  [Parameter] public EventCallback OnToggleMenu { get; set; }

  [Parameter] public EventCallback OnBack { get; set; }

  [Parameter] public EventCallback OnLogout { get; set; }

  private string DisplayName => AuthState?.User?.Name ?? "User";
  private string AvatarLetter => string.IsNullOrWhiteSpace(DisplayName) ? "U" : DisplayName.Trim()[0].ToString().ToUpperInvariant();
  private string RoleLabel => AuthState?.User?.Role ?? string.Empty;
}
