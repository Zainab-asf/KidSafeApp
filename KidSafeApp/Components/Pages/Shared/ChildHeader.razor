@namespace KidSafeApp.Components.Pages.Shared

<header class="ks-header">
  <div>
    <div class="ks-greeting-label">Good Morning,</div>
    <div class="ks-greeting-name">Zainab</div>
  </div>

  <div class="ks-header-actions">
    <button class="ks-icon-button" type="button" title="Back" @onclick="OnBack">
      ←
    </button>
    <button class="ks-icon-button" type="button" title="Logout" @onclick="OnLogout">
      ⎋
    </button>
    <button class="ks-icon-button ks-menu-button" type="button" title="Menu" @onclick="OnToggleMenu">
      ☰
    </button>
    <input class="ks-search" placeholder="Search..." />

    <button class="ks-icon-button" title="Notifications">
      <span class="ks-icon-dot"></span>
    </button>

    <div class="ks-profile">
      <div class="ks-avatar">Z</div>
      <div class="ks-profile-text">
        <div class="ks-profile-name">Zainab</div>
        <div class="ks-profile-email">zainab@kidsafeapp.com</div>
      </div>
    </div>
  </div>
</header>

@code {
  [Parameter] public EventCallback OnToggleMenu { get; set; }

  [Parameter] public EventCallback OnBack { get; set; }

  [Parameter] public EventCallback OnLogout { get; set; }
}
