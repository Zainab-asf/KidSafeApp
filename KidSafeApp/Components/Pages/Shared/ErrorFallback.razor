@using Microsoft.AspNetCore.Components

<h3>Something went wrong</h3>
<p>The page threw an error while rendering.</p>

@if (Exception is not null)
{
    <pre style="white-space:pre-wrap">@Exception.ToString()</pre>
}

<button class="btn btn-primary" @onclick="Recover">Reload</button>

@code {
    [Parameter] public Exception? Exception { get; set; }

    [CascadingParameter(Name = "Exception")] public Exception? CascadedException { get; set; }

    [CascadingParameter] public ErrorBoundary? ErrorBoundary { get; set; }

    protected override void OnParametersSet()
    {
        Exception ??= CascadedException;
    }

    private void Recover() => ErrorBoundary?.Recover();
}
