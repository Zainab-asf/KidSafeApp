@namespace KidSafeApp.Components.Pages.Shared

@inject KidSafeApp.StateManagement.AuthenticationState AuthState
@inject KidSafeApp.StateManagement.RoleState RoleState
@inject KidSafeApp.Services.ParentDashboardApiClient ParentApiClient
@inject NavigationManager NavigationManager

@if (_loading)
{
    <div class="ks-loader py-5">
        <span class="spinner-border spinner-border-sm me-2"></span>
        Loading profile...
    </div>
}
else
{
    <!-- Success / Error Alerts -->
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success animate-fade-in mb-3">@_successMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger animate-fade-in mb-3">@_errorMessage</div>
    }

    <!-- Profile Card -->
    <section class="panel-card">
        <h3>👤 Profile Information</h3>

        <div class="ks-profile-header">
            <div class="ks-profile-avatar-wrap">
                <div class="ks-profile-avatar">
                    @if (!string.IsNullOrWhiteSpace(_settings.AvatarUrl))
                    {
                        <img src="@_settings.AvatarUrl" alt="Avatar" />
                    }
                    else
                    {
                        <span>@GetUserInitial()</span>
                    }
                </div>
                <button class="ks-avatar-change-btn" @onclick="ChangeAvatar" title="Change avatar">
                    📷
                </button>
            </div>
            <div class="ks-profile-meta">
                <div class="ks-profile-name-display">@(AuthState.User?.Name ?? "User")</div>
                <div class="ks-profile-role-display">@RoleState.CurrentRole</div>
            </div>
        </div>

        <div class="ks-profile-form">
            <div class="ks-form-row">
                <label class="form-label">Full Name</label>
                <input class="form-control" type="text" @bind="_name" placeholder="Enter your full name" />
            </div>

            <div class="ks-form-row">
                <label class="form-label">Email Address</label>
                <input class="form-control" type="email" @bind="_settings.ParentEmail" placeholder="Enter email address" />
            </div>

            <div class="ks-form-row">
                <label class="form-label">Phone Number</label>
                <input class="form-control" type="tel" @bind="_phone" placeholder="Enter phone number" />
            </div>

            <div class="ks-form-row">
                <label class="form-label">Bio</label>
                <textarea class="form-control" rows="3" @bind="_settings.Bio" placeholder="Tell us about yourself..."></textarea>
            </div>
        </div>
    </section>

    <!-- Password Change Section -->
    <section class="panel-card mt-3">
        <h3>🔐 Change Password</h3>
        <div class="ks-profile-form">
            <div class="ks-form-row">
                <label class="form-label">Current Password</label>
                <input class="form-control" type="password" @bind="_currentPassword" placeholder="Enter current password" />
            </div>

            <div class="ks-form-row">
                <label class="form-label">New Password</label>
                <input class="form-control" type="password" @bind="_newPassword" placeholder="Enter new password" />
                @if (_newPassword.Length > 0 && _newPassword.Length < 6)
                {
                    <div class="validation-message">Password must be at least 6 characters</div>
                }
            </div>

            <div class="ks-form-row">
                <label class="form-label">Confirm New Password</label>
                <input class="form-control" type="password" @bind="_confirmPassword" placeholder="Confirm new password" />
                @if (!string.IsNullOrWhiteSpace(_confirmPassword) && _newPassword != _confirmPassword)
                {
                    <div class="validation-message">Passwords do not match</div>
                }
            </div>
        </div>
    </section>

    <!-- Action Buttons -->
    <div class="ks-profile-actions">
        <button class="btn btn-primary btn-block" @onclick="SaveProfileAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Saving...</span>
            }
            else
            {
                <span>💾 Save Changes</span>
            }
        </button>
    </div>
}

@code {
    private bool _loading = true;
    private bool _saving = false;
    private string? _successMessage;
    private string? _errorMessage;

    private string _name = string.Empty;
    private string _phone = string.Empty;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    private UserSettingsDto _settings = new()
    {
        ThemePreference = "light",
        LanguagePreference = "en",
        ParentEmail = string.Empty,
        Bio = string.Empty,
        AvatarUrl = string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        _name = AuthState.User?.Name ?? string.Empty;
        await LoadSettingsAsync();
        _loading = false;
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            var settings = await ParentApiClient.GetSettingsAsync();
            if (settings is not null)
            {
                _settings = settings;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading settings: {ex.Message}");
        }
    }

    private async Task SaveProfileAsync()
    {
        _successMessage = null;
        _errorMessage = null;

        // Validate name
        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Full name is required.";
            return;
        }

        // Validate password if attempting to change
        if (!string.IsNullOrWhiteSpace(_newPassword))
        {
            if (_newPassword.Length < 6)
            {
                _errorMessage = "New password must be at least 6 characters.";
                return;
            }
            if (_newPassword != _confirmPassword)
            {
                _errorMessage = "New password and confirmation do not match.";
                return;
            }
            if (string.IsNullOrWhiteSpace(_currentPassword))
            {
                _errorMessage = "Current password is required to change password.";
                return;
            }
        }

        _saving = true;

        try
        {
            // Update name in auth state
            if (AuthState.User is not null)
            {
                AuthState.User.Name = _name;
            }

            // Save settings via API
            var updated = await ParentApiClient.SaveSettingsAsync(_settings);
            if (updated is not null)
            {
                _settings = updated;
            }

            // Clear password fields after successful save
            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;

            _successMessage = "Profile updated successfully! ✅";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save profile: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ChangeAvatar()
    {
        // Placeholder for avatar upload functionality
        // In a real app, this would open a file picker and upload to the server
        _successMessage = "Avatar upload coming soon! For now, enter an image URL in settings.";
    }

    private string GetUserInitial()
    {
        var name = AuthState.User?.Name;
        return string.IsNullOrWhiteSpace(name) ? "U" : name[..1].ToUpper();
    }
}
