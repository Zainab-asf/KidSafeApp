@namespace KidSafeApp.Components.Pages.Teacher
@page "/teacher/classes"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager

@if (!RoleState.IsRoleLoaded)
{
    <Components.Shared.RoleLoading />
}
else
{
<div class="container py-3 teacher-module">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h4 mb-1">Teacher Classes</h1>
            <div class="text-secondary">Manage classes and student groups</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h6">Class List</h2>
            <ul class="mb-3">
                <li>Grade 5-A (24 students)</li>
                <li>Grade 5-B (22 students)</li>
                <li>Grade 6-A (26 students)</li>
            </ul>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-primary">Create Class</button>
                <button class="btn btn-outline-primary">Manage Students</button>
            </div>
        </div>
    </div>
</div>
}

@code {
    private void HandleBack() => NavigationManager.NavigateTo("/teacher/dashboard");

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
