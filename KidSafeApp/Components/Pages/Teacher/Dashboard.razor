@namespace KidSafeApp.Components.Pages.Teacher
@page "/teacher/dashboard"

<PageTitle>Teacher Classroom Dashboard</PageTitle>

@inject KidSafeApp.StateManagement.RoleState RoleState
@inject NavigationManager NavigationManager
@inject TeacherDashboardApiClient DashboardApi
@inject KidSafeApp.StateManagement.AuthenticationState AuthState

@if (!AuthState.IsAuthenticated)
{
    <NavigateTo href="/login/teacher" replace="true" />
}
else if (!string.Equals(AuthState.User?.Role, "Teacher", StringComparison.OrdinalIgnoreCase))
{
    <NavigateTo href="/login/teacher" replace="true" />
}

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
    <TeacherPageShell Title="Teacher Classroom Dashboard">
        @if (_loading)
        {
            <div class="text-center py-5">
                <div class="spinner-border" style="color: var(--ks-green);" role="status"></div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }
        else
        {

        <!-- Hero card matching parent style -->
        <section class="hero-card">
            <div class="hero-avatar">👩‍🏫</div>
        <div class="hero-copy">
            <div class="hero-greeting">Good morning,</div>
            <div class="hero-title">@((AuthState.User?.Name) ?? "Teacher")</div>
            <div class="hero-subtitle">Courses: @(_dashboard?.Summary.TotalCourses ?? 0)</div>
        </div>
        <div class="hero-score">
            <div class="hero-score-value">@Math.Round(_dashboard?.Summary.AverageProgressPercent ?? 0, 0)%</div>
            <small>Avg Progress</small>
        </div>
        </section>

        <!-- Stat grid using parent tokens -->
        <section class="stats-grid">
            <article class="stat-card">
                <div class="stat-icon">📚</div>
                <div class="stat-value">@(_dashboard?.Summary.TotalLessons ?? 0)</div>
                <div class="stat-label">Total Lessons</div>
            </article>
            <article class="stat-card">
                <div class="stat-icon">⚠️</div>
                <div class="stat-value">@(_dashboard?.Summary.PendingLessonSubmissions ?? 0)</div>
                <div class="stat-label">Pending Reviews</div>
            </article>
            <article class="stat-card">
                <div class="stat-icon">✅</div>
                <div class="stat-value">@(_dashboard?.Summary.CompletedLessonSubmissions ?? 0)</div>
                <div class="stat-label">Completed</div>
            </article>
        </section>

        <!-- Progress and weekly chart reuse parent panel-card -->
        <section class="panel-card">
            <h3>This Week's Activity</h3>
            <div class="weekly-chart">
                @foreach (var day in _dashboard?.Weekly ?? new List<WeeklyPointDto>())
                {
                    <div class="week-col">
                        <div class="bar-stack">
                            <div class="bar-block safe" style="height:@day.Safe%"></div>
                            <div class="bar-block flagged" style="height:@day.Flagged%"></div>
                            <div class="bar-block blocked" style="height:@day.Blocked%"></div>
                        </div>
                        <small>@day.Day</small>
                    </div>
                }
            </div>
        </section>

        <!-- Recent alerts using parent list style -->
        <section class="panel-card">
            <h3>Recent Alerts</h3>
            <div class="parent-recent-list">
                @if (_dashboard?.Courses is null || !_dashboard.Courses.Any())
                {
                    <div class="parent-empty-state">No recent alerts.</div>
                }
                else
                {
                    @foreach (var c in _dashboard.Courses.Take(6))
                    {
                        <div class="parent-recent-item">
                            <div class="parent-recent-meta">
                                <strong>@c.Title</strong>
                                <small>@(c.IsPublished ? "Published" : "Draft")</small>
                            </div>
                            <span class="parent-alert-badge badge-info">Info</span>
                        </div>
                    }
                }
            </div>
        </section>

        <section class="quick-grid">
            <button class="quick-card quick-primary" @onclick="GoToClasses">
                <div class="quick-title">Manage Students</div>
                <small>Open class management</small>
            </button>
            <button class="quick-card" @onclick="GoToReports">
                <div class="quick-title">View Flagged</div>
                <small>Open flagged messages</small>
            </button>
            <button class="quick-card" @onclick="GoToNotifications">
                <div class="quick-title">Notifications</div>
                <small>Open alerts feed</small>
            </button>
            <button class="quick-card" @onclick="GoToSettings">
                <div class="quick-title">Settings</div>
                <small>Profile & preferences</small>
            </button>
        </section>
        }
    </TeacherPageShell>
}

@code {
    private TeacherDashboardDto? _dashboard;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _dashboard = await DashboardApi.GetDashboardAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleBack() => NavigationManager.NavigateTo("/", replace: true);

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }

    private void GoToClasses() => NavigationManager.NavigateTo("/teacher/classes");

    private void GoToAssignments() => NavigationManager.NavigateTo("/teacher/assignments");

    private void GoToReports() => NavigationManager.NavigateTo("/teacher/reports");
    private void GoToNotifications() => NavigationManager.NavigateTo("/parent/notifications");
    private void GoToSettings() => NavigationManager.NavigateTo("/parent/settings");

}