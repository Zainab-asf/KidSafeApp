@namespace KidSafeApp.Components.Pages.Teacher
@page "/teacher/dashboard"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject HttpClient Client
@inject KidSafeApp.States.AuthenticationState AuthState

@if (!AuthState.IsAuthenticated)
{
    <NavigateTo href="/login/teacher" replace="true" />
}
else if (!string.Equals(AuthState.User?.Role, "Teacher", StringComparison.OrdinalIgnoreCase))
{
    <NavigateTo href="/unauthorized" replace="true" />
}

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<div class="portal">
    <header class="portal-header">
        <div>
            <h1 class="portal-title">Teacher Portal 👩‍🏫</h1>
            <div class="portal-subtitle">Simple classroom overview for daily teaching.</div>
        </div>

        <div class="portal-actions">
            <button class="btn btn-outline-secondary" type="button" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" type="button" @onclick="HandleLogout">Logout</button>
        </div>
    </header>

    <section class="portal-grid">
        <div class="portal-card">
            <div class="portal-card-title">Courses 📚</div>
            <div class="portal-stat">@_summary.TotalCourses</div>
            <div class="portal-muted">@_summary.PublishedCourses published</div>
        </div>

        <div class="portal-card">
            <div class="portal-card-title">Pending Reviews ⏳</div>
            <div class="portal-stat">@_summary.PendingLessonSubmissions</div>
            <div class="portal-muted">Lesson submissions pending completion</div>
        </div>

        <div class="portal-card">
            <div class="portal-card-title">Assignments 📝</div>
            <div class="portal-stat">@_summary.TotalLessons</div>
            <div class="portal-muted">@_summary.PublishedLessons published lessons</div>
        </div>

        <div class="portal-card">
            <div class="portal-card-title">Student Activity 📈</div>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="small text-danger">@_error</div>
            }
            else if (_loading)
            {
                <div class="small text-secondary">Loading...</div>
            }
            else if (_courses.Count == 0)
            {
                <div class="small text-secondary">No course activity yet.</div>
            }
            else
            {
                <ul class="portal-list">
                    @foreach (var c in _courses.Take(3))
                    {
                        <li>@c.Title - @(c.IsPublished ? "Published" : "Draft")</li>
                    }
                </ul>
            }
        </div>
    </section>

    <section class="portal-wide">
        <div class="portal-card portal-card-wide">
            <div class="portal-card-title">Quick Actions ⚡</div>
            <div class="portal-controls">
                <button class="btn btn-primary" type="button" @onclick="GoToAssignments">Create Assignment</button>
                <button class="btn btn-outline-primary" type="button" @onclick="GoToClasses">Open Gradebook</button>
                <button class="btn btn-outline-primary" type="button" @onclick="GoToReports">View Reports</button>
            </div>
        </div>
    </section>
</div>
}

@code {
    private TeacherSummaryDto _summary = new();
    private List<CourseDto> _courses = new();
    private bool _loading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _summary = await Client.GetFromJsonAsync<TeacherSummaryDto>("api/teacher/courses/summary") ?? new();
            _courses = await Client.GetFromJsonAsync<List<CourseDto>>("api/teacher/courses") ?? new();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleBack() => NavigationManager.NavigateTo("/", replace: true);

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }

    private void GoToClasses() => NavigationManager.NavigateTo("/teacher/classes");

    private void GoToAssignments() => NavigationManager.NavigateTo("/teacher/assignments");

    private void GoToReports() => NavigationManager.NavigateTo("/teacher/reports");
}
