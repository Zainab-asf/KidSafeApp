@namespace KidSafeApp.Components.Pages.Teacher
@page "/teacher/reports"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager

@if (!RoleState.IsRoleLoaded)
{
    <Components.Shared.RoleLoading />
}
else
{
<div class="container py-3 teacher-module">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h4 mb-1">Teacher Reports</h1>
            <div class="text-secondary">Performance and activity reports</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="HandleBack">Back</button>
            <button class="btn btn-outline-danger" @onclick="HandleLogout">Logout</button>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Average Score</div><div class="display-6 fw-bold">82%</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Participation</div><div class="display-6 fw-bold">91%</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Pending Reviews</div><div class="display-6 fw-bold">5</div></div></div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h2 class="h6">Reports</h2>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-primary">Generate Weekly Report</button>
                <button class="btn btn-outline-primary">Download CSV</button>
            </div>
        </div>
    </div>
</div>
}

@code {
    private void HandleBack() => NavigationManager.NavigateTo("/teacher/dashboard");

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
