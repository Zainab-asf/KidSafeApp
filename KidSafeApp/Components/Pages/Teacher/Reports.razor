@namespace KidSafeApp.Components.Pages.Teacher
@page "/teacher/reports"

@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager
@inject HttpClient Client

@if (!RoleState.IsRoleLoaded)
{
    <RoleLoading />
}
else
{
<TeacherPageShell Title="Teacher Reports">

    <div class="row g-3">
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Average Progress</div><div class="display-6 fw-bold">@_summary.AverageProgressPercent%</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Published Courses</div><div class="display-6 fw-bold">@_summary.PublishedCourses / @_summary.TotalCourses</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100"><div class="card-body"><div class="text-secondary">Pending Reviews</div><div class="display-6 fw-bold">@_summary.PendingLessonSubmissions</div></div></div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h2 class="h6">Reports</h2>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }
            else if (_loading)
            {
                <div class="text-secondary">Loading report data...</div>
            }
            else
            {
                <div class="small mb-3 text-secondary">Lessons: @_summary.PublishedLessons published / @_summary.TotalLessons total • Completed submissions: @_summary.CompletedLessonSubmissions</div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-primary" @onclick="LoadAsync">Generate Weekly Report</button>
                    <button class="btn btn-outline-primary" @onclick="LoadAsync">Refresh</button>
                </div>
            }
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h2 class="h6">Courses Snapshot</h2>
            @if (_courses.Count == 0)
            {
                <div class="text-secondary">No courses found.</div>
            }
            else
            {
                <ul class="mb-0">
                    @foreach (var c in _courses)
                    {
                        <li>@c.Title — @c.Lessons.Count lessons — @(c.IsPublished ? "Published" : "Draft")</li>
                    }
                </ul>
            }
        </div>
    </div>
</TeacherPageShell>
}

@code {
    private TeacherSummaryDto _summary = new();
    private List<CourseDto> _courses = new();
    private bool _loading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _summary = await Client.GetFromJsonAsync<TeacherSummaryDto>("api/teacher/courses/summary") ?? new();
            _courses = await Client.GetFromJsonAsync<List<CourseDto>>("api/teacher/courses") ?? new();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleBack() => NavigationManager.NavigateTo("/teacher/dashboard");

    private void HandleLogout()
    {
        RoleState.Reset();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
