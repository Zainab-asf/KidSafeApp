@using KidSafeApp.Shared.DTOs.Admin

<EditForm Model="Model" OnValidSubmit="HandleSubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row g-2">
        <div class="col-md-6">
            <label class="form-label">Name</label>
            <InputText class="form-control" @bind-Value="Model.Name" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Role</label>
            <InputSelect class="form-select" @bind-Value="Model.Role">
                <option>Admin</option>
                <option>Parent</option>
                <option>Teacher</option>
                <option>Child</option>
            </InputSelect>
        </div>
        <div class="col-md-6">
            <label class="form-label">Username</label>
            <InputText class="form-control" @bind-Value="Model.Username" />
        </div>
        @if (IsChildRole)
        {
            <div class="col-md-6">
                <label class="form-label">Registration No</label>
                <InputText class="form-control" @bind-Value="Model.RegistrationNo" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Class</label>
                <InputSelect class="form-select" @bind-Value="Model.ClassRoomId">
                    <option value="">Select class</option>
                    @foreach (var classRoom in ClassRooms.OrderBy(c => c.Name))
                    {
                        <option value="@classRoom.Id">@classRoom.Name (@classRoom.Grade-@classRoom.Section)</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6">
                <label class="form-label">Course (Optional)</label>
                <InputSelect class="form-select" @bind-Value="Model.CourseId">
                    <option value="">Select course</option>
                    @foreach (var course in Courses.OrderBy(c => c.Title))
                    {
                        <option value="@course.Id">@course.Title</option>
                    }
                </InputSelect>
            </div>
        }
        else if (IsTeacherRole)
        {
            <div class="col-md-6">
                <label class="form-label">Assign Class (Optional)</label>
                <InputSelect class="form-select" @bind-Value="Model.ClassRoomId">
                    <option value="">Select class</option>
                    @foreach (var classRoom in ClassRooms.OrderBy(c => c.Name))
                    {
                        <option value="@classRoom.Id">@classRoom.Name (@classRoom.Grade-@classRoom.Section)</option>
                    }
                </InputSelect>
            </div>
        }
        <div class="col-md-6">
            <label class="form-label">Password</label>
            <InputText type="password" class="form-control" @bind-Value="Model.Password" />
        </div>
        <div class="col-12 d-flex align-items-center gap-3 mt-2">
            <label class="form-check-label">
                <InputCheckbox class="form-check-input me-2" @bind-Value="Model.IsActive" />
                Active
            </label>
            <label class="form-check-label">
                <InputCheckbox class="form-check-input me-2" @bind-Value="Model.IsApproved" />
                Approved
            </label>
            <button type="submit" class="btn btn-success ms-auto" disabled="@IsSubmitting">Create user</button>
        </div>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired] public AdminCreateUserDto Model { get; set; } = default!;
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public IReadOnlyList<AdminClassRoomDto> ClassRooms { get; set; } = Array.Empty<AdminClassRoomDto>();
    [Parameter] public IReadOnlyList<AdminCourseLiteDto> Courses { get; set; } = Array.Empty<AdminCourseLiteDto>();

    private bool IsChildRole => string.Equals(Model.Role, "Child", StringComparison.OrdinalIgnoreCase);
    private bool IsTeacherRole => string.Equals(Model.Role, "Teacher", StringComparison.OrdinalIgnoreCase);

    private Task HandleSubmitAsync() => OnSubmit.InvokeAsync();
}
