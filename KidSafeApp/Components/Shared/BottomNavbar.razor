@namespace KidSafeApp.Components.Shared
@inject KidSafeApp.States.RoleState RoleState
@inject NavigationManager NavigationManager

<nav class="ks-bottom-nav" role="navigation" aria-label="Bottom navigation">
    @if (RoleState.IsRoleLoaded)
    {
        @switch (RoleState.CurrentRole)
        {
            case KidSafeApp.States.AppRole.Child:
                <NavLink class="ks-bottom-link" href="/child/dashboard" Match="NavLinkMatch.All">
                    <span class="ks-bottom-icon" aria-hidden="true">🏠</span>
                    <span class="ks-bottom-text">Home</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/child/chat">
                    <span class="ks-bottom-icon" aria-hidden="true">💬</span>
                    <span class="ks-bottom-text">Chat</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/child/tasks">
                    <span class="ks-bottom-icon" aria-hidden="true">📚</span>
                    <span class="ks-bottom-text">Tasks</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/child/profile">
                    <span class="ks-bottom-icon" aria-hidden="true">👤</span>
                    <span class="ks-bottom-text">Profile</span>
                </NavLink>
                break;
            case KidSafeApp.States.AppRole.Parent:
                <NavLink class="ks-bottom-link" href="/parent/dashboard" Match="NavLinkMatch.All">
                    <span class="ks-bottom-icon" aria-hidden="true">🏠</span>
                    <span class="ks-bottom-text">Home</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/parent/progress">
                    <span class="ks-bottom-icon" aria-hidden="true">📊</span>
                    <span class="ks-bottom-text">Reports</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/parent/notifications">
                    <span class="ks-bottom-icon" aria-hidden="true">🔔</span>
                    <span class="ks-bottom-text">Notifications</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/parent/profile">
                    <span class="ks-bottom-icon" aria-hidden="true">👤</span>
                    <span class="ks-bottom-text">Profile</span>
                </NavLink>
                break;
            case KidSafeApp.States.AppRole.Teacher:
                <NavLink class="ks-bottom-link" href="/teacher/dashboard" Match="NavLinkMatch.All">
                    <span class="ks-bottom-icon" aria-hidden="true">🏠</span>
                    <span class="ks-bottom-text">Home</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/teacher/classes">
                    <span class="ks-bottom-icon" aria-hidden="true">👥</span>
                    <span class="ks-bottom-text">Students</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/teacher/reports">
                    <span class="ks-bottom-icon" aria-hidden="true">📄</span>
                    <span class="ks-bottom-text">Reports</span>
                </NavLink>
                <NavLink class="ks-bottom-link" href="/teacher/profile">
                    <span class="ks-bottom-icon" aria-hidden="true">👤</span>
                    <span class="ks-bottom-text">Profile</span>
                </NavLink>
                break;
        }
    }
</nav>