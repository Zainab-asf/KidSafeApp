@* Inline SVG icons (currentColor) — avoids missing Bootstrap Icons font in WebView *@
<span class="ks-svg-icon @CssClass" aria-hidden="true">
    @switch (Icon)
    {
        case KsSvgIconKind.Search:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            break;
        case KsSvgIconKind.ArrowClockwise:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            break;
        case KsSvgIconKind.Calendar:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            break;
        case KsSvgIconKind.Students:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            break;
        case KsSvgIconKind.ChatMonitored:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a4 4 0 0 1-4 4H7l-4 4V7a4 4 0 0 1 4-4h14a4 4 0 0 1 4 4z"/></svg>
            break;
        case KsSvgIconKind.Flagged:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><path d="M4 22v-7"/></svg>
            break;
        case KsSvgIconKind.BlockedUsers:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m4.93 4.93 14.14 14.14"/></svg>
            break;
        case KsSvgIconKind.LegendDot:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6" fill="currentColor"/></svg>
            break;
        case KsSvgIconKind.QuickChildChat:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a4 4 0 0 1-4 4H8l-3 3V7a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4z"/><path d="M12 7v6"/><path d="M9 10h6"/></svg>
            break;
        case KsSvgIconKind.QuickParentPortal:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 21a6 6 0 0 0-12 0"/><circle cx="12" cy="7" r="4"/><path d="M22 21a8 8 0 0 0-14.93-4"/></svg>
            break;
        case KsSvgIconKind.QuickTeacherModule:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12 3.293 2.597 9.086a1 1 0 0 0 0 1.828l9.404 5.793a2 2 0 0 0 2.006 0z"/><path d="M22 10v6"/><path d="M12 13v10"/><path d="m7 15-4.5 4.5"/></svg>
            break;
        case KsSvgIconKind.QuickSettings:
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v2"/><path d="M12 2v2"/><path d="M4.93 17.657l1.414-1.414"/><path d="M17.657 6.343 19.07 7.757"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M6.343 6.343 7.757 4.93"/><path d="M17.657 17.657l1.414 1.414"/><circle cx="12" cy="12" r="4"/></svg>
            break;
        case KsSvgIconKind.NotificationSeverity:
            @if (string.Equals(Severity, "Blocked", StringComparison.OrdinalIgnoreCase))
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
            }
            else if (string.Equals(Severity, "Warning", StringComparison.OrdinalIgnoreCase))
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-9-14a2 2 0 0 0-3.48 0l-9 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
            }
            break;
    }
</span>

@code {
    [Parameter]
    public KsSvgIconKind Icon { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    /// <summary>For <see cref="KsSvgIconKind.NotificationSeverity"/>.</summary>
    [Parameter]
    public string Severity { get; set; } = "";
}
