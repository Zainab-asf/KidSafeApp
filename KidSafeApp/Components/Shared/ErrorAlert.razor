@namespace KidSafeApp.Components.Shared
@using KidSafeApp.Services
@using KidSafeApp.Models
@using KidSafeApp.Models.Enums
@implements IAsyncDisposable
@inject ErrorService ErrorService

<div class="error-notification-container">
    @foreach (var notification in ErrorService.Notifications)
    {
        <div class="error-notification alert alert-@GetAlertClass(notification.Type) alert-dismissible fade show" role="alert">
            <div class="notification-content">
                @if (!string.IsNullOrWhiteSpace(notification.Title))
                {
                    <strong>@notification.Title</strong>
                }
                <span>@notification.Message</span>
            </div>
            <button type="button" class="btn-close" aria-label="Close" @onclick="() => DismissNotification(notification.Id)"></button>
        </div>
    }
</div>

@code {
    private Dictionary<Guid, Task> _autoCloseTimers = new();

    protected override void OnInitialized()
    {
        ErrorService.OnNotificationChanged += OnNotificationChanged;
    }

    private void OnNotificationChanged()
    {
        // Schedule auto-close for new notifications
        foreach (var notification in ErrorService.Notifications)
        {
            if (!_autoCloseTimers.ContainsKey(notification.Id))
            {
                _autoCloseTimers[notification.Id] = Task.Delay(notification.DurationMs)
                    .ContinueWith(_ =>
                    {
                        if (ErrorService.Notifications.FirstOrDefault(n => n.Id == notification.Id) != null)
                        {
                            ErrorService.RemoveNotification(notification.Id);
                        }
                    });
            }
        }

        StateHasChanged();
    }

    private void DismissNotification(Guid notificationId)
    {
        ErrorService.RemoveNotification(notificationId);
        _autoCloseTimers.Remove(notificationId);
    }

    private string GetAlertClass(NotificationType type) => type switch
    {
        NotificationType.Error   => "danger",
        NotificationType.Success => "success",
        NotificationType.Warning => "warning",
        NotificationType.Info    => "info",
        _                        => "secondary"
    };

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        ErrorService.OnNotificationChanged -= OnNotificationChanged;
        await Task.CompletedTask;
    }
}


